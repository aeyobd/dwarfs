@article{dekel+silk1986,
  title = {The Origin of Dwarf Galaxies, Cold Dark Matter, and Biased Galaxy Formation},
  author = {Dekel, A. and Silk, J.},
  year = 1986,
  month = apr,
  journal = {\apj},
