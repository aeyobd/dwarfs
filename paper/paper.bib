@misc{barbosa+2025,
  title = {The {{DECam MAGIC}} Survey: A Wide-Field Photometric Metallicity Study of the Sculptor Dwarf Spheroidal Galaxy},
  shorttitle = {The {{DECam MAGIC}} Survey},
  author = {Barbosa, Fabr{\'i}cia O. and Chiti, Anirudh and Limberg, Guilherme and Pace, Andrew and Cerny, William and Rossi, Silvia and Carlin, Jeffrey L. and Stringfellow, Guy and Placco, Vinicius and Atzerberg, Kaia and {Carballo-Bello}, Julio A. and Chaturvedi, Astha and Choi, Yumi and Crnojevic, Denija and {Drlica-Wagner}, Alex and Ji, Alexander and Kallivayalil, Nitya and {Mart{\'i}nez-V{\'a}zquez}, Clara and Medina, Gustavo and Noel, Noelia and Sand, David and Vivas, Kathy and Bom, Clecio and Ferguson, Peter and {Mutlu-Pakdil}, Bur{\c c}in and Navabi, Mahdieh and Riley, Alexander H. and Sakowska, Joanna and Zenteno, Alfredo},
  year = 2025,
  month = apr,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2504.03593},
  url = {https://ui.adsabs.harvard.edu/abs/2025arXiv250403593B},
  urldate = {2025-04-28},
  abstract = {The metallicity distribution function and internal chemical variations of a galaxy are fundamental to understand its formation and assembly history. In this work, we analyze photometric metallicities for 3883 stars over seven half-light radii (\$\textbackslash rm r\_h\$) in the Sculptor dwarf spheroidal (Scl dSph) galaxy, using new narrow-band imaging data from the Mapping the Ancient Galaxy in CaHK (MAGIC) survey conducted with the Dark Energy Camera (DECam) at the 4-m Blanco Telescope. This work demonstrates the scientific potential of MAGIC using the Scl dSph galaxy, one of the most well-studied satellites of the Milky Way. Our sample ranges from \$\textbackslash rm [Fe/H] \textbackslash approx - 4.0\$ to \$\textbackslash rm [Fe/H] \textbackslash approx - 0.6\$, includes six extremely metal-poor candidates (\$\textbackslash rm [Fe/H] \textbackslash leq -3.0\$) without previous spectroscopic observations, and is almost three times larger than the largest spectroscopic metallicity dataset in the Scl dSph. Our spatially unbiased sample of metallicities provides a more accurate representation of the metallicity distribution function, revealing a more metal-rich peak than observed in the most recent spectroscopic sample. It also reveals a break in the metallicity gradient, with a strong change in the slope: from \$-3.35 \textbackslash pm 0.18 \textbackslash rm \textbackslash{} dex \textbackslash, deg\textasciicircum\textbraceleft -1\textbraceright\$ for stars inside \$\textbackslash sim 1\textbackslash{} \textbackslash rm r\_h\$ to \$-0.56 \textbackslash pm 0.26 \textbackslash rm \textbackslash{} dex \textbackslash, deg\textasciicircum\textbraceleft -1\textbraceright\$ for the outer part of the Scl dSph. Our study demonstrates that combining photometric metallicity analysis with the wide field of view of DECam offers an efficient and unbiased approach for studying the stellar populations of dwarf galaxies in the Local Group.},
  langid = {english},
  keywords = {Astrophysics of Galaxies,Solar and Stellar Astrophysics},
  annotation = {ADS Bibcode: 2025arXiv250403593B},
  file = {/Users/daniel/Zotero/storage/JGNNPJ3B/Barbosa et al. - 2025 - The DECam MAGIC Survey A Wide-field Photometric Metallicity Study of the Sculptor Dwarf Spheroidal.pdf}
}
