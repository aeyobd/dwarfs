@article{kim+2025,
  title = {Nearby Stellar Substructures in the {{Galactic}} Halo from {{DESI Milky Way Survey Year}} 1 {{Data Release}}},
  author = {Kim, Bokyoung and Koposov, Sergey E. and Li, Ting S. and Lilleengen, Sophia and Cooper, Andrew P. and Carrillo, Andreia and Valluri, Monica and Riley, Alexander H. and Han, Jiwon Jesse and Aguilar, Jessica Nicole and Ahlen, Steven and e Silva, Leandro Beraldo and Bianchi, Davide and Brooks, David and Bystr{\"o}m, Amanda and Claybaugh, Todd and Cole, Shaun and Dawson, Kyle and de la Macorra, Axel and {Forero-Romero}, Jaime and Gnedin, Oleg Y. and Gontcho, Satya Gontcho A. and Gutierrez, Gaston and Guy, Julien and Honscheid, Klaus and Kehoe, Robert and Kizhuprakkat, Namitha and Landriau, Martin and Guillou, Laurent Le and Levi, Michael and Medina, Gustavo E. and Meisner, Aaron and Miquel, Ramon and Moustakas, John and Poppett, Claire and Prada, Francisco and Rossi, Graziano and S{\'a}nchez, Eusebio and Schubnell, Michael and Sharples, Ray and Sprayberry, David and Hern{\'a}ndez, Jos{\'e} Arturo Trelles and Weaver, Benjamin Alan and Zou, Hu},
  year = 2025,
  month = may,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {540},
  number = {1},
  eprint = {2504.20327},
  primaryclass = {astro-ph},
  pages = {264--288},
  issn = {0035-8711, 1365-2966},
  doi = {10.1093/mnras/staf705},
  url = {http://arxiv.org/abs/2504.20327},
  urldate = {2025-07-28},
  abstract = {We report five nearby (\$d\_\textbraceleft\textbackslash mathrm\textbraceleft helio\textbraceright\textbraceright{} {$<$} 5\$ kpc) stellar substructures in the Galactic halo from a subset of 138,661 stars in the Dark Energy Spectroscopic Instrument (DESI) Milky Way Survey Year 1 Data Release. With an unsupervised clustering algorithm, HDBSCAN*, these substructures are independently identified in Integrals of Motion (\$E\_\textbraceleft\textbackslash mathrm\textbraceleft tot\textbraceright\textbraceright\$, \$L\_\textbraceleft\textbackslash mathrm z\textbraceright\$, \$\textbackslash log\textbraceleft J\_r\textbraceright\$, \$\textbackslash log\textbraceleft J\_z\textbraceright\$) space and Galactocentric cylindrical velocity space (\$V\_\textbraceleft R\textbraceright\$, \$V\_\textbraceleft\textbackslash phi\textbraceright\$, \$V\_\textbraceleft z\textbraceright\$). We associate all identified clusters with known nearby substructures (Helmi streams, M18-Cand10/MMH-1, Sequoia, Antaeus, and ED-2) previously reported in various studies. With metallicities precisely measured by DESI, we confirm that the Helmi streams, M18-Cand10, and ED-2 are chemically distinct from local halo stars. We have characterised the chemodynamic properties of each dynamic group, including their metallicity dispersions, to associate them with their progenitor types (globular cluster or dwarf galaxy). Our approach for searching substructures with HDBSCAN* reliably detects real substructures in the Galactic halo, suggesting that applying the same method can lead to the discovery of new substructures in future DESI data. With more stars from future DESI data releases and improved astrometry from the upcoming Gaia Data Release 4, we will have a more detailed blueprint of the Galactic halo, offering a significant improvement in our understanding of the formation and evolutionary history of the Milky Way Galaxy.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/DUZFNFBZ/Kim et al. - 2025 - Nearby stellar substructures in the Galactic halo from DESI Milky Way Survey Year 1 Data Release.pdf}
}

@article{kim+peter+hargis2018,
  title = {Missing Satellites Problem: Completeness Corrections to the Number of Satellite Galaxies in the Milky Way Are Consistent with Cold Dark Matter Predictions},
  shorttitle = {Missing Satellites Problem},
  author = {Kim, Stacy Y. and Peter, Annika H. G. and Hargis, Jonathan R.},
  year = 2018,
  month = nov,
  journal = {\prl},
  volume = {121},
  pages = {211302},
  publisher = {APS},
  issn = {0031-9007},
  doi = {10.1103/PhysRevLett.121.211302},
  url = {https://ui.adsabs.harvard.edu/abs/2018PhRvL.121u1302K},
  urldate = {2025-07-24},
  abstract = {A critical challenge to the cold dark matter (CDM) paradigm is that there are fewer satellites observed around the Milky Way than found in simulations of dark matter substructure. We show that there is a match between the observed satellite counts corrected by the detection efficiency of the Sloan Digital Sky Survey (for luminosities L {$\greaterequivlnt$}340 L{$\odot$} ) and the number of luminous satellites predicted by CDM, assuming an empirical relation between stellar mass and halo mass. The "missing satellites problem," cast in terms of number counts, is thus solved. We also show that warm dark matter models with a thermal relic mass smaller than 4 keV are in tension with satellite counts, putting pressure on the sterile neutrino interpretation of recent x-ray observations. Importantly, the total number of Milky Way satellites depends sensitively on the spatial distribution of satellites, possibly leading to a "too many satellites" problem. Measurements of completely dark halos below 1 08 M{$\odot$}, achievable with substructure lensing and stellar stream perturbations, are the next frontier for tests of CDM.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,Cosmology,High Energy Physics - Phenomenology,to read},
  annotation = {ADS Bibcode: 2018PhRvL.121u1302K},
  file = {/Users/daniel/Zotero/storage/ZIG9NDD5/Kim et al. - 2018 - Missing Satellites Problem Completeness Corrections to the Number of Satellite Galaxies in the Milk.pdf}
}
