  journal = {\pasp},
  volume = {106},
  pages = {1225},
  publisher = {IOP},
  issn = {0004-6280},
  doi = {10.1086/133500},
  url = {https://ui.adsabs.harvard.edu/abs/1994PASP..106.1225G},
  urldate = {2025-07-14},
  abstract = {Dwarf spheroidal galaxies are the most insignificant extragalactic stellar systems in terms of their visibility, but potentially very significant in terms of their role in the formation and evolution of much more luminous galaxies. We discuss the present observational data and their implications for theories of the formation and evolution of both dwarf and giant galaxies. The putative dark matter content of these low-surface-brightness systems is of particular interest, as is their chemical evolution. Surveys for new dwarf spheroidals hidden behind the stars of our Galaxy and those which are not bound to giant galaxies may give new clues as to the origins of this unique class of galaxy. (SECTION: Invited Review Paper)},
  langid = {english},
  keywords = {Astronomy,Astrophysics,Brightness Distribution,Chemical Evolution,Dark Matter,Dwarf Galaxies,Dynamic Models,Galactic Evolution,Galactic Halos,Galactic Mass,Galactic Structure,GALAXIES: EVOLUTION,GALAXIES: FORMATION,GALAXIES: PECULIAR,Kinematics,Spatial Distribution,Spectrographs,Spheroids},
  annotation = {ADS Bibcode: 1994PASP..106.1225G},
  file = {/Users/daniel/Zotero/storage/B5W8D3BX/Gallagher and Wyse - 1994 - Dwarf Spheroidal Galaxies Keystones of Galaxy Evolution.pdf}
}
