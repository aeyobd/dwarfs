@article{borukhovetskaya+2022,
  title = {The Tidal Evolution of the Fornax Dwarf Spheroidal and Its Globular Clusters},
  author = {Borukhovetskaya, Alexandra and Errani, Rapha{\"e}l and Navarro, Julio F. and Fattahi, Azadeh and {Santos-Santos}, Isabel},
  year = 2022,
  month = feb,
  journal = {\mnras},
  volume = {509},
  pages = {5330--5339},
  issn = {0035-8711},
  doi = {10.1093/mnras/stab2912},
  url = {https://ui.adsabs.harvard.edu/abs/2022MNRAS.509.5330B},
  urldate = {2023-10-15},
  abstract = {The dark matter content of the Fornax dwarf spheroidal galaxy inferred from its kinematics is substantially lower than expected from LCDM cosmological simulations. We use N-body simulations to examine whether this may be the result of Galactic tides. We find that, despite improved proper motions from the Gaia mission, the pericentric distance of Fornax remains poorly constrained, mainly because its largest velocity component is roughly antiparallel to the solar motion. Translating Fornax's proper motion into a Galactocentric velocity is, thus, sensitively dependent on Fornax's assumed distance: the observed distance uncertainty, \$\textbackslash pm 8\textbackslash,\textbraceleft\textbraceleft\textbackslash rm per\textbackslash,cent\textbraceright\textbraceright\$, implies pericentric distances that vary between rperi \textasciitilde{} 50 and \textasciitilde 150 kpc. Our simulations show that for rperi in the lower range of that estimate, an LCDM subhalo with maximum circular velocity Vmax = 40 km s-1 (or virial mass \$M\_\textbraceleft 200\textbraceright\textbackslash approx 10\textasciicircum\textbraceleft 10\textbraceright\textbackslash, \textbackslash rm M\_\textbackslash odot\$, as expected from LCDM) would be tidally stripped to Vmax \textasciitilde{} 23 km s-1 over 10 Gyr. This would reduce the dark mass within the Fornax stellar half-mass radius to about half its initial value, bringing it into agreement with observations. Tidal stripping affects mainly Fornax's dark matter halo; its stellar component is affected little, losing less than \$5\textbackslash,\textbraceleft\textbraceleft\textbackslash rm per\textbackslash,cent\textbraceright\textbraceright\$ of its initial mass in the process. We also explore the effect of Galactic tides on the dynamical friction decay times of Fornax's population of globular clusters (GCs) and find little evidence for substantial changes, compared with models run in isolation. A population of GCs with initial orbital radii between 1 and 2 kpc is consistent with the present-day spatial distribution of Fornax GCs, despite assuming a cuspy halo. Neither the dark matter content nor the spatial distribution of GCs of Fornax seems inconsistent with a simple model where Fornax inhabits a tidally stripped cuspy cold dark matter halo.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,dark matter,galaxies: dwarf,galaxies: evolution,idealized simulations},
  annotation = {ADS Bibcode: 2022MNRAS.509.5330B},
  file = {/Users/daniel/Zotero/storage/BE5VIJJQ/Borukhovetskaya et al. - 2022 - The tidal evolution of the Fornax dwarf spheroidal.pdf}
}
