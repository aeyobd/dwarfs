  keywords = {Abundance,Astrophysics,Big Bang Cosmology,Cold Plasmas,Cosmology,COSMOLOGY,Dark Matter,Dwarf Galaxies,Galactic Evolution,Galactic Structure,GALAXIES: CLUSTERING,GALAXIES: FORMATION,GALAXIES: INTERNAL MOTIONS,GALAXIES: STRUCTURE,Local Group (Astronomy),Mass To Light Ratios,Stellar Evolution,Stellar Winds,Supernovae,to read,Virgo Galactic Cluster},
  annotation = {ADS Bibcode: 1986ApJ...303...39D},
  file = {/Users/daniel/Zotero/storage/FC2M8FL7/Dekel and Silk - 1986 - The Origin of Dwarf Galaxies, Cold Dark Matter, and Biased Galaxy Formation.pdf}
