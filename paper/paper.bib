@misc{sola+2025,
  title = {{{STRRINGS}}: {{STReams}} in {{Residual Images}} of {{Nearby GalaxieS}}},
  shorttitle = {{{STRRINGS}}},
  author = {Sola, E. and Chemaly, D. and Belokurov, V. and M{\"u}ller, O. and {Ardern-Arentsen}, A. and Davies, E. Y. and {Laguna-Miralles}, J. and Myeong, G. and Panagiotakis, K. and Zhang, H. and Erkal, D. and Koposov, S. E. and Lang, D. and Nibauer, J.},
  year = 2025,
  month = aug,
  number = {arXiv:2508.02154},
  eprint = {2508.02154},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2508.02154},
  url = {http://arxiv.org/abs/2508.02154},
  urldate = {2025-08-08},
  abstract = {Tidal features from galaxy mergers, particularly stellar streams, offer valuable insights into galaxy assembly and dark matter halo properties. This paper aims to identify a large sample of nearby stellar streams suitable for detailed modelling and comparison with simulations to enable population-level constraints on halo properties. We visually inspect and compile a tidal feature catalogue for \$19,387\$ galaxies with redshift \$z \textbackslash leq 0.02\$ from the Siena Galaxy Atlas 2020 using original, model, and residual images from the DESI Legacy Imaging Surveys. Residual images, produced by subtracting models of all sources, enhance the detectability of faint asymmetries such as tidal features. We find that \$11.9 \textbackslash pm 0.2\textbackslash\%\$ of galaxies host tidal features, more frequently around early-type than late-type galaxies. The tidal feature fraction increases with stellar mass, from \$2.4 \textbackslash pm 0.4\textbackslash\%\$ at \$\textbackslash sim10\textasciicircum 8\$M\$\_\textbackslash odot\$ to \$36.5 \textbackslash pm 1.2\textbackslash\%\$ at \$\textbackslash sim 5\textbackslash times10\textasciicircum\textbraceleft 11\textbraceright\$M\$\_\textbackslash odot\$. From this, we present the first release of STRRINGS: STReams in Residual Images of Nearby GalaxieS, a subsample of 35 galaxies with long, narrow streams suitable for modelling. We segment these streams and derive their geometry, surface brightness, colours, and stellar masses. The median \$g\$-band surface brightness is 26.8 mag\$\textbackslash,\$arcsec\$\textasciicircum\textbraceleft -2\textbraceright\$, reaching 27.5 mag\$\textbackslash,\$arcsec\$\textasciicircum\textbraceleft -2\textbraceright\$ for the faintest stream. Mass ratios are consistent with minor mergers, and we identify five potential dwarf galaxy progenitors. Our streams are typically longer (median 124 kpc) than the literature, with comparable widths. Stream mass correlates with length and colour, and wider streams lie at larger galactocentric radii. STRRINGS will be expanded and used to constrain halo properties in future work.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/N772V7YT/Sola et al. - 2025 - STRRINGS STReams in Residual Images of Nearby GalaxieS.pdf}
}
