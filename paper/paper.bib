@article{tautvaisiene+2015,
  title = {The Gaia-{{ESO}} Survey: {{CNO}} Abundances in the Open Clusters Trumpler 20, {{NGC}} 4815, and {{NGC}} 6705},
  shorttitle = {The Gaia-{{ESO}} Survey},
  author = {Tautvai{\v s}ien{\.e}, G. and Drazdauskas, A. and Mikolaitis, {\v S}. and Barisevi{\v c}ius, G. and Puzeras, E. and Stonkut{\.e}, E. and Chorniy, Y. and Magrini, L. and Romano, D. and Smiljanic, R. and Bragaglia, A. and Carraro, G. and Friel, E. and Morel, T. and Pancino, E. and Donati, P. and {Jim{\'e}nez-Esteban}, F. and Gilmore, G. and Randich, S. and Jeffries, R. D. and Vallenari, A. and Bensby, T. and Flaccomio, E. and {Recio-Blanco}, A. and Costado, M. T. and Hill, V. and Jofr{\'e}, P. and Lardo, C. and {de Laverny}, P. and Masseron, T. and Moribelli, L. and Sousa, S. G. and Zaggia, S.},
  year = 2015,
