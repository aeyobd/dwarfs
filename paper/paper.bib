@article{mcmillan2011,
  title = {Mass Models of the {{Milky Way}}},
  author = {McMillan, Paul J.},
  year = 2011,
  month = jul,
  journal = {\mnras},
  volume = {414},
  pages = {2446--2457},
  issn = {0035-8711},
  doi = {10.1111/j.1365-2966.2011.18564.x},
  url = {https://ui.adsabs.harvard.edu/abs/2011MNRAS.414.2446M},
  urldate = {2024-04-12},
  abstract = {We present a simple method for fitting parametrized mass models of the Milky Way to observational constraints. We take a Bayesian approach which allows us to take into account input from photometric and kinematic data, and expectations from theoretical modelling. This provides us with a best-fitting model, which is a suitable starting point for dynamical modelling. We also determine a probability density function on the properties of the model, which demonstrates that the mass distribution of the Galaxy remains very uncertain. For our choices of parametrization and constraints, we find disc scalelengths of 3.00 \textpm{} 0.22 and 3.29 \textpm{} 0.56 kpc for the thin and thick discs, respectively, a solar radius of 8.29 \textpm{} 0.16 kpc and a circular speed at the Sun of 239 \textpm{} 5 km s-1, a total stellar mass of 6.43 \textpm{} 0.63 \texttimes{} 1010 M{$\odot$}, a virial mass of 1.26 \textpm{} 0.24 \texttimes{} 1012 M{$\odot$} and a local dark matter density of 0.40 \textpm{} 0.04 GeV cm-3. We find some correlations between the best-fitting parameters of our models (for example, between the disc scalelengths and the solar radius), which we discuss. The chosen disc scaleheights are shown to have little effect on the key properties of the model.},
  keywords = {Astrophysics - Astrophysics of Galaxies,Galaxy: fundamental parameters,Galaxy: kinematics and dynamics,methods: statistical},
  annotation = {ADS Bibcode: 2011MNRAS.414.2446M},
  file = {/Users/daniel/Zotero/storage/5L8TKL6Y/McMillan - 2011 - Mass models of the Milky Way.pdf;/Users/daniel/Zotero/storage/JTHZ4MYG/McMillan - 2011 - Mass models of the Milky Way.pdf}
}
