@article{fattahi+2013,
  title = {Galaxy Pairs in the Local Group},
  author = {Fattahi, A. and Navarro, J. F. and Starkenburg, E. and Barber, C. R. and McConnachie, A. W.},
  year = 2013,
  month = apr,
  journal = {\mnras},
  volume = {431},
  pages = {L73-L77},
