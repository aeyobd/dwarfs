@article{veronesi+rossi+vanvelzen2023,
  title = {The Most Luminous {{AGN}} Do Not Produce the Majority of the Detected Stellar-Mass Black Hole Binary Mergers in the Local Universe},
  author = {Veronesi, Niccol{\`o} and Rossi, Elena Maria and {van~Velzen}, Sjoert},
  year = 2023,
  month = dec,
  journal = {Mon. Not. R. Astron. Soc.},
  volume = {526},
  number = {4},
  pages = {6031--6040},
  issn = {0035-8711},
  doi = {10.1093/mnras/stad3157},
  url = {https://doi.org/10.1093/mnras/stad3157},
  urldate = {2026-02-03},
  abstract = {Despite the increasing number of gravitational wave (GW) detections, the astrophysical origin of binary black hole (BBH) mergers remains elusive. A promising formation channel for BBHs is inside accretion discs around supermassive black holes, that power active galactic nuclei (AGN). In this paper, we test for the first time the spatial correlation between observed GW events and AGN. To this end, we assemble all sky catalogues with 1,412 (242) AGN with a bolometric luminosity greater than 1045.5erg\,s-1 (\$10\textasciicircum\textbraceleft 46\textbraceright\textbackslash, \textbraceleft\textbackslash rm erg\textbackslash, s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$) with spectroscopic redshift of z {$\leq$} 0.3 from the Milliquas catalogue, version 7.7b. These AGN are cross-matched with localization volumes of BBH mergers observed in the same redshift range by the LIGO and Virgo interferometers during their first three observing runs. We find that the fraction of the detected mergers originated in AGN brighter than \$10\textasciicircum\textbraceleft 45.5\textbraceright\textbackslash, \textbraceleft\textbackslash rm erg\textbackslash, s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ (\$10\textasciicircum\textbraceleft 46\textbraceright\textbackslash, \textbraceleft\textbackslash rm erg\textbackslash, s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$) cannot be higher than 0.49 (0.17) at a 95~per~cent credibility level. Our upper limits imply a limited BBH merger production efficiency of the brightest AGN, while most or all GW events may still come from lower luminosity ones. Alternatively, the AGN formation path for merging stellar-mass BBHs may be actually overall subdominant in the local Universe. To our knowledge, ours are the first observational constraints on the fractional contribution of the AGN channel to the observed BBH mergers.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/YTGNZ5EB/Veronesi et al. - 2023 - The most luminous AGN do not produce the majority of the detected stellar-mass black hole binary mer.pdf}
}
