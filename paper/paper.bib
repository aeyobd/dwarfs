@article{nidever+2024,
  title = {First {{JWST}} Results Find {{No}} Alpha-Bimodality in {{M31}}},
  author = {Nidever, David and Gilbert, Karoline and Tollerud, Erik and Siders, Charles and Escala, Ivanna and Allende Prieto, Carlos and Smith, Verne and Cunha, Katia and Debattista, Victor and Ting, Yuan-Sen and Kirby, Evan and Guhathakurta, Puragra},
  year = 2024,
  month = feb,
  volume = {56},
  pages = {428.5},
  url = {https://ui.adsabs.harvard.edu/abs/2024AAS...24342805N},
  urldate = {2024-03-22},
  abstract = {The recent era of large, ground-based abundance surveys has unraveled the chemical structures of our Milky Way galaxy. The most striking abundance feature is the alpha-abundance bimodality. The low-alpha stars are younger (1-8 Gyr) while the high-alpha stars are older (8-12 Gyr) and have a thicker distribution. While there are a number of models that can reproduce the Milky Way alpha-bimodality, none are strongly favored by the data. However, they do make different predictions about the prevalence of the alpha-bimodality in Milky Way-mass galaxies. Our Cycle 1 JWST NIRspec program has obtained high-S/N, medium-resolution spectra of over 100 stars in one M31 disk field. We have measured stellar parameters, radial velocities, and alpha-abundances using a set of synthetic spectra. No alpha-bimodality exists in the M31 JWST abundances and the data can be explainedy by a single, high star formation efficiency evolutionary track similar to what is seen in the MW bulge. While this result is somewhat surprising, the larger accretion and merger rate of M31 is likely responsible for the different chemical pattern.},
  langid = {english},
  annotation = {ADS Bibcode: 2024AAS...24342805N}
}
