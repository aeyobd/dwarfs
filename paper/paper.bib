@article{dillamore+sanders2026,
  title = {Geometry of the {{Milky Way}}'s Dark Matter from Dynamical Models of the Tilted Stellar Halo},
  author = {Dillamore, Adam M. and Sanders, Jason L.},
  year = 2026,
  month = feb,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {546},
  number = {4},
  eprint = {2510.00095},
  primaryclass = {astro-ph},
  pages = {stag226},
  issn = {0035-8711, 1365-2966},
  doi = {10.1093/mnras/stag226},
  url = {http://arxiv.org/abs/2510.00095},
  urldate = {2026-03-20},
  abstract = {The shape and orientation of the Milky Way's dark matter halo remain poorly constrained. Observations of the accreted stellar halo show that it is triaxial and tilted with respect to the disc. If this configuration is long-lived, it can place constraints on the shape and orientation of the dark matter halo that can support it close to steady state. We use a novel method to fit equilibrium orbit-superposition (Schwarzschild) models to the stellar halo in a realistic Milky Way potential with a tilted dark matter halo. We assume that the long axes of each halo and the disc normal are coplanar. These models are matched to parametric density fits and velocity anisotropy measurements of Gaia Sausage-Enceladus (GSE) stars at radii \$r\textbackslash in[6,60]\$ kpc. The observations are consistent with a (near-)prolate dark matter halo whose density has a short-to-long axis ratio of \$q\_\textbackslash mathrm\textbraceleft dm\textbraceright =0.87\_\textbraceleft -0.09\textbraceright\textasciicircum\textbraceleft +0.05\textbraceright\$. The long axis is inclined at an angle of \${$\beta\_\backslash$}mathrm\textbraceleft dm\textbraceright =43\_\textbraceleft -8\textbraceright\textasciicircum\textbraceleft +22\textbraceright\textbackslash,\textasciicircum\textbackslash circ\$ to the disc plane, which exceeds the stellar halo tilt by \$\textbackslash approx18\textasciicircum\textbackslash circ\$. Spherical haloes cannot support the observed structure of the GSE in equilibrium. The best-fitting dynamical GSE model has a radius-dependent shape and orientation; between radii of 6 and 60\textasciitilde kpc the tilt increases from \${$\beta\_$}*(r)\textbackslash approx10\textasciicircum\textbackslash circ\$ to \$\textbackslash approx35\textasciicircum\textbackslash circ\$. Our model provides a good fit to the observed triaxial structure and dynamics of the GSE. It is therefore an excellent source of realistic initial conditions for simulations of the halo, such as for investigating perturbations from satellites or the Galactic bar.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/X8VRPXDE/Dillamore and Sanders - 2026 - Geometry of the Milky Way's dark matter from dynamical models of the tilted stellar halo.pdf}
}

@misc{ding+2025,
  title = {The {{Draco Dwarf Spheroidal Galaxy}} in the {{First Year}} of {{DESI Data}}},
