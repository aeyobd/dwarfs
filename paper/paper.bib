@article{whalen+2020,
  title = {Internal Wave-Driven Mixing: Governing Processes and Consequences for Climate},
  shorttitle = {Internal Wave-Driven Mixing},
  author = {Whalen, Caitlin B. and {de Lavergne}, Casimir and Naveira Garabato, Alberto C. and Klymak, Jody M. and MacKinnon, Jennifer A. and Sheen, Katy L.},
  year = 2020,
  month = nov,
  journal = {Nat. Rev. Earth Environ.},
  volume = {1},
  number = {11},
