@misc{chun+2025,
  title = {The {{Role}} of {{Pre-Processing}} in {{Tidal Feature Formation}} within {{Galaxy Clusters}}},
  author = {Chun, Kyungwon and Shin, Jihye and Ko, Jongwan and Smith, Rory and Park, So-myoung and Nam, Songhee},
  year = 2025,
  month = sep,
  number = {arXiv:2509.22802},
  eprint = {2509.22802},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2509.22802},
  url = {http://arxiv.org/abs/2509.22802},
  urldate = {2025-11-05},
  abstract = {We investigate the formation of tidal features, such as tidal tails, streams, and shell-like structures, composed of stars stripped from satellites within galaxy clusters. For this, we use multiresolution cosmological \$N-\$body simulations with the ``galaxy replacement technique". We find that the fraction of satellites with tidal features increases with the mass of the host clusters but is not related to the dynamical state of the clusters. Although the strong tidal field in the cluster environment accelerates the mass loss of the satellites, only 20\textbackslash\% of tidal-featured galaxies form their tidal features purely due to tidal perturbation in the cluster environment, without any interactions with other galaxies before falling into the cluster. In contrast, the majority (80\textbackslash\%) is affected by the preprocessing, as they experienced merging events with other galaxies before infalling into the cluster. Among this preprocessing population, 45\textbackslash\% of all tidal-featured galaxies form their tidal features after passing the pericenter of the cluster, affected by both preprocessing and the tidal field of the cluster, whereas 35\textbackslash\% of all tidal-featured galaxies form their tidal features before reaching the pericenter, primarily due to preprocessing. Notably, this fraction increases from 35\textbackslash\% to 40-50\textbackslash\% when we focus only on galaxies with brighter surface brightness limits or higher stellar mass. Therefore, our results highlight that preprocessing is an important channel for forming tidal features within clusters. However, the importance of preprocessing may be further amplified in observations, since more massive galaxies, which are commonly associated with preprocessing, are preferentially detected.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,to read},
  file = {/Users/daniel/Zotero/storage/5Q7I6IGN/Chun et al. - 2025 - The Role of Pre-Processing in Tidal Feature Formation within Galaxy Clusters.pdf}
}
