@article{ho+2012,
  title = {Stellar Kinematics of the Andromeda {{II}} Dwarf Spheroidal Galaxy},
  author = {Ho, Nhung and Geha, M. and Munoz, R. R. and Guhathakurta, P. and Kalirai, J. and Gilbert, K. M. and Tollerud, E. and Bullock, J. and Beaton, R. L. and Majewski, S. R.},
  year = 2012,
  month = oct,
  journal = {\apj},
  volume = {758},
