  eprint = {2509.21822},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2509.21822},
  url = {http://arxiv.org/abs/2509.21822},
  urldate = {2025-11-05},
  abstract = {We investigate the spatial distribution, kinematics, and metallicity of stars in the Draco dwarf spheroidal galaxy using data from the Dark Energy Spectroscopic Instrument (DESI). We identify 155 high probability members of Draco using line of sight velocity and metallicity information derived from DESI spectroscopy along with \textbraceleft\textbackslash it Gaia\textbraceright{} DR3 proper motions. We find a mean line of sight velocity of \$ -290.62\textbackslash pm0.80\$ km s\$\textasciicircum\textbraceleft -1\textbraceright\$ with dispersion = \$9.57\textasciicircum\textbraceleft +0.66\textbraceright\_\textbraceleft -0.62\textbraceright\$ km s\$\textasciicircum\textbraceleft -1\textbraceright\$ and mean metallicity \$\textbackslash rm\textbraceleft [Fe/H]\textbraceright\$ = \$-2.10\textbackslash pm0.04\$, consistent with previous results. We also find that Draco has a steep metallicity gradient within the half-light radius, and a metallicity gradient that flattens beyond the half-light radius. We identify eight high probability members outside the King tidal radius, four of which we identify for the first time. These extra-tidal stars are not preferentially aligned along the orbit of Draco. We compute an average surface brightness of 34.02 mag \$\textbackslash rm arcsec\textasciicircum\textbraceleft -2\textbraceright\$ within an elliptical annulus from the King tidal radius of 48.1 arcmin to 81 arcmin.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,to read},
  file = {/Users/daniel/Zotero/storage/H6RJNKAJ/Ding et al. - 2025 - The Draco Dwarf Spheroidal Galaxy in the First Year of DESI Data.pdf}
}
