  urldate = {2025-09-18},
  abstract = {We analyse in detail the spatial distribution and kinematic properties of two different stellar populations in Andromeda II dwarf spheroidal galaxy. We obtained their detailed surface density maps together with their radial density profiles. The two populations differ not only in age and metallicity, but also in their spatial distribution and kinematics. Old stars ({$\greaterequivlnt$}11 Gyr) follow a round distribution well fitted by truncated density profiles. These stars rotate around the projected optical major axis of the galaxy with line-of-sight velocities vlos(rh) = 16 \textpm{} 3 km s-1 and a velocity gradient of 2.06 \textpm{} 0.21 km s-1 arcmin-1. Intermediate-age stars ({$\lessequivlnt$}9 Gyr) concentrate in the centre of the galaxy and form an elongated structure extending along the projected optical major axis. This structure appears to rotate with a velocity gradient of 2.24 \textpm{} 0.22 km s-1 arcmin-1 and around the optical minor axis. The centres of rotation and kinetic position angles (PAkin) of both populations differ. For intermediate-age stars we obtained PAkin = 18{$^\circ$} \textpm{} 2{$^\circ$} and for the old ones PAkin = 63{$^\circ$} \textpm{} 3{$^\circ$} in good agreement with photometric PA measured from isopleths fitted to the photometry. We conclude that the two stellar populations may not be fully relaxed and thus be the result of a merger occurred at redshift z {$\sim$} 1.75.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: dwarf,galaxies: evolution,galaxies: individual: Andromeda II,galaxies: interactions,galaxies: kinematics and dynamics,Local Group,stellar halos},
  annotation = {ADS Bibcode: 2017MNRAS.469.4999D},
