@article{dhillon2002,
  title = {On the Use of {{12CO}}/{{13CO}} as a Test of Common-Envelope Evolution},
  author = {Dhillon, V. S. and Littlefair, S. P. and Marsh, T. R. and Sarna, M. J. and Boakes, E. H.},
  year = 2002,
  month = oct,
  journal = {Astronomy and Astrophysics},
  volume = {393},
  pages = {611--615},
  issn = {0004-6361},
  doi = {10.1051/0004-6361:20021045},
  url = {https://ui.adsabs.harvard.edu/abs/2002A&A...393..611D},
  urldate = {2023-11-07},
  abstract = {We present K-band echelle spectra of the cataclysmic variable SS Cyg and the pre-cataclysmic variable V471 Tau in order to measure the strengths of the 12CO and 13CO bands at 2.3525 and 2.3448 mu m, respectively, and so perform the observational test of the common-envelope model of close binary star evolution proposed by Sarna et al. (\textbackslash cite\textbraceleft sarna95\textbraceright ). Although we find evidence of an absorption feature coincident with the expected wavelength of 13CO in both objects, we attribute it instead to a cluster of neutral atomic absorption features (primarily due to Ti I) possibly arising from star-spots on the surfaces of the rapidly rotating secondary stars in these systems, thereby rendering the test inconclusive. We present a modified observational test of common-envelope evolution, based on the observation of the 13CO bands at 2.3739 and 2.4037 mu m, which is insensitive to spectral contamination by star-spots.},
  keywords = {abundances,Astrophysics,binaries: spectroscopic,cataclysmic variables,infrared: stars,novae,nuclear reactions,nucleosynthesis,stars: individual: SS Cyg,stars: individual: V471 Tau},
  annotation = {ADS Bibcode: 2002A\&A...393..611D},
  file = {/Users/daniel/Zotero/storage/6S5KCI56/Dhillon et al. - 2002 - On the use of 12CO13CO as a test of common-envelo.pdf}
}
