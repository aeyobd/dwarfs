@inproceedings{
  title = {First Results from the Triangulum Extended Survey: Insights into the Dynamical History of {{M33}}},
  shorttitle = {First Results from the Triangulum Extended Survey},
  booktitle = {Dynamical {{Masses}} of {{Local Group Galaxies}}},
  author = {Gilbert, K. M. and Quirk, A. C. N. and Cullinane, L. R. and Smercina, A. and Guhathakurta, P.},
  year = 2025,
  month = jan,
  volume = {379},
  pages = {123--128},
  doi = {10.1017/S1743921323001448},
  url = {https://ui.adsabs.harvard.edu/abs/2025IAUS..379..123G},
  urldate = {2026-02-26},
  abstract = {The Triangulum Extended (TREX) Survey is a spectroscopic survey\dag{} that targets resolved stars of all ages throughout the disk of Triangulum (M33). We summarize the first results from the TREX Survey, including the discovery of a kinematically hot, halo-like population throughout M33's inner disk in both the old and intermediate-age populations and evidence that the youngest stars have been dynamically heated. We also discuss the implications for our understanding of M33's dynamical history in the context of recent results from the Panchromatic Hubble Andromeda Treasury: Triangulum Extended Region (PHATTER) Survey.},
  langid = {english},
  keywords = {Disk galaxies,Galaxy evolution,Galaxy stellar halos,Local Group,Triangulum Galaxy},
  annotation = {ADS Bibcode: 2025IAUS..379..123G}
}
