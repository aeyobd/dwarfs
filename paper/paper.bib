@article{walker+2007,
  title = {The Michigan/{{MIKE}} Fiber System Survey of Stellar Radial Velocities in Dwarf Spheroidal Galaxies: Acquisition and Reduction of Data},
  shorttitle = {The Michigan/{{MIKE}} Fiber System Survey of Stellar Radial Velocities in Dwarf Spheroidal Galaxies},
  author = {Walker, Matthew G. and Mateo, Mario and Olszewski, Edward W. and Bernstein, Rebecca and Sen, Bodhisattva and Woodroofe, Michael},
  year = 2007,
  month = aug,
  journal = {\apjs},
  volume = {171},
  pages = {389--418},
  publisher = {IOP},
  issn = {0067-0049},
  doi = {10.1086/517886},
  url = {https://ui.adsabs.harvard.edu/abs/2007ApJS..171..389W},
  urldate = {2025-04-06},
  abstract = {We introduce a stellar velocity survey of dwarf spheroidal galaxies, undertaken using the Michigan/MIKE Fiber System (MMFS) at the Magellan/Clay 6.5 m telescope at Las Campanas Observatory. As of 2006 November we have used MMFS to collect 6415 high-resolution (R=20,000-25,000) spectra from 5180 stars in four dwarf spheroidal galaxies: Carina, Fornax, Sculptor, and Sextans. Spectra sample the range 5140-5180 \AA, which includes the prominent magnesium triplet absorption feature. We measure radial velocity (RV) to a median precision of 2.0 km s-1 for stars as faint as V\textasciitilde 20.5. From the spectra we also are able to measure the strength of iron and magnesium absorption features using spectral indices that correlate with effective temperature, surface gravity, and chemical abundance. Measurement of line strength allows us to identify interloping foreground stars independently of velocity and to examine the metallicity distribution among dSph members. Here we present detailed descriptions of MMFS, our target selection and spectroscopic observations, the data reduction procedure, and error analysis. We compare our RV results to previously published measurements for individual stars. In some cases we find evidence for a mild, velocity-dependent offset between the RVs that we measure using the magnesium triplet and previously published RV measurements derived from the infrared calcium triplet. In companion papers we will present the complete data sets and kinematic analyses of these new observations. This paper includes data obtained with the 6.5 m Magellan Telescopes located at Las Campanas Observatory, Chile.},
  langid = {english},
  keywords = {Astrophysics,Galaxies: Dwarf,Galaxies: Kinematics and Dynamics,Galaxies: Local Group,Techniques: Radial Velocities},
  annotation = {ADS Bibcode: 2007ApJS..171..389W},
  file = {/Users/daniel/Zotero/storage/5RZ8DXAC/Walker et al. - 2007 - The MichiganMIKE Fiber System Survey of Stellar Radial Velocities in Dwarf Spheroidal Galaxies Acq.pdf}
}
