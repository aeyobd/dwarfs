@article{verberne+2024,
  title = {Improved Constraints on Galactic Centre Ejection of Hypervelocity Stars Based on Novel Search Method},
  author = {Verberne, Sill and Rossi, Elena Maria and Koposov, Sergey E and Marchetti, Tommaso and Kuijken, Konrad and Penoyre, Zephyr and Evans, Fraser A and Souropanis, Dimitris and Tohill, Cl{\'a}r-Br{\'i}d},
  year = 2024,
  month = sep,
  journal = {Mon. Not. R. Astron. Soc.},
  volume = {533},
  number = {3},
  pages = {2747--2761},
  issn = {0035-8711},
  doi = {10.1093/mnras/stae1888},
  url = {https://doi.org/10.1093/mnras/stae1888},
  urldate = {2026-02-03},
  abstract = {Hypervelocity stars (HVSs) are stars which have been ejected from the Galactic Centre (GC) at velocities of up to a few thousand \$\textbackslash text\textbraceleft km\textbraceright\textbackslash, \textbackslash text\textbraceleft s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$. They are tracers of the Galactic potential and can be used to infer properties of the GC, such as the initial mass function and assembly history. HVSs are rare, however, with only about a dozen promising candidates discovered so far. In this work, we make use of a novel, highly efficient method to identify new HVS candidates in Gaia. This method uses the nearly radial trajectories of HVSs to infer their distances and velocities based on their position and Gaia proper motion alone. Through comparison of inferred distances with Gaia parallaxes and photometry, we identified 600 HVS candidates with G \&lt; 20 including the previously discovered S5-HVS1, out of which we obtained ground-based follow-up observations for 196 stars. As we found no new HVSs based on their radial velocity, we used detailed HVS ejection simulations to significantly improve previous HVS ejection rate constraints. In particular, the ejection rate of HVSs more massive than 1 \$\textbackslash mathrm\textbraceleft M\_\textbackslash odot \textbraceright\$ cannot be higher than \$10\textasciicircum\textbraceleft -5\textbraceright\$ yr\$\textasciicircum\textbraceleft -1\textbraceright\$ at \$2\textbackslash sigma\$ significance. Additionally, we predict that there are 5--45 unbound HVSs in the complete Gaia catalogue (\$1\textbackslash sigma\$ interval), most of which will be main-sequence stars of a few M\$\_\textbackslash odot\$ at heliocentric distances of tens to hundreds of kpc. By comparing our results to literature HVS candidates, we find an indication of either a time-dependent ejection rate of HVSs or a non-GC origin of previously identified HVS candidates.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/FX8L3YR3/Verberne et al. - 2024 - Improved constraints on galactic centre ejection of hypervelocity stars based on novel search method.pdf}
}
