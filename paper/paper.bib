@article{WF1992,
  title = {A Planetary System around the Millisecond Pulsar {{PSR1257}} + 12},
  author = {Wolszczan, A. and Frail, D. A.},
  year = 1992,
  month = jan,
  journal = {Nature},
  volume = {355},
