@misc{errani+2023,
  title = {Ursa Major {{III}}/{{UNIONS}} 1: The Darkest Galaxy Ever Discovered?},
  shorttitle = {Ursa Major {{III}}/{{UNIONS}} 1},
  author = {Errani, Rapha{\"e}l and Navarro, Julio F. and Smith, Simon E. T. and McConnachie, Alan W.},
  year = 2023,
  month = nov,
  journal = {arXiv e-prints},
  doi = {10.48550/arXiv.2311.10134},
  url = {https://ui.adsabs.harvard.edu/abs/2023arXiv231110134E},
  urldate = {2023-11-29},
  abstract = {The recently-discovered stellar system Ursa Major III/UNIONS 1 (UMa3/U1) is the faintest known Milky Way satellite to date. With a stellar mass of \$16\textasciicircum\textbraceleft +6\textbraceright\_\textbraceleft -5\textbraceright\textbackslash,\textbackslash rm M\_\textbackslash odot\$ and a half-light radius of \$3\textbackslash pm1\$ pc, it is either the darkest galaxy ever discovered or the faintest self-gravitating star cluster known to orbit the Galaxy. Its line-of-sight velocity dispersion suggests the presence of dark matter, although current measurements are inconclusive because of the unknown contribution to the dispersion of potential binary stars. We use N-body simulations to show that, if self-gravitating, the system could not survive in the Milky Way tidal field for more than a single orbit (roughly 0.4 Gyr), which strongly suggests that the system is stabilized by the presence of large amounts of dark matter. If UMa3/U1 formed at the centre of a \textasciitilde\$10\textasciicircum 9\textbackslash rm M\_\textbackslash odot\$ cuspy LCDM halo, its velocity dispersion would be predicted to be of order \textasciitilde 1 km/s. This is roughly consistent with the current estimate, which, neglecting binaries, places \$\textbackslash sigma\_\textbraceleft\textbackslash rm los\textbraceright\$ in the range 1 to 4 km/s. Because of its dense cusp, such a halo should be able to survive the Milky Way tidal field, keeping UMa3/U1 relatively unscathed until the present time. This implies that UMa3/U1 is in all likelihood the faintest and densest dwarf galaxy satellite of the Milky Way, with important implications for alternative dark matter models, and for the minimum halo mass threshold for luminous galaxy formation in the LCDM cosmology.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  annotation = {ADS Bibcode: 2023arXiv231110134E},
  file = {/Users/daniel/Zotero/storage/3A74B5XN/Errani et al. - 2023 - Ursa Major IIIUNIONS 1 the darkest galaxy ever d.pdf}
}
