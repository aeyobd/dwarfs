  author = {Tonry, J. L. and Stubbs, C. W. and Lykke, K. R. and Doherty, P. and Shivvers, I. S. and Burgett, W. S. and Chambers, K. C. and Hodapp, K. W. and Kaiser, N. and Kudritzki, R.-P. and Magnier, E. A. and Morgan, J. S. and Price, P. A. and Wainscoat, R. J.},
