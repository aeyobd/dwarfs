  annotation = {ADS Bibcode: 2023MNRAS.tmp.3595H},
  file = {/Users/daniel/Zotero/storage/TFWZZ7F3/Hollands et al. - 2023 - Measuring the Initial-Final Mass-Relation using wi.pdf}
