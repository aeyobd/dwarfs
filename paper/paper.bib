@article{bullock+johnston2005,
  title = {Tracing Galaxy Formation with Stellar Halos. {{I}}. {{Methods}}},
  author = {Bullock, James S. and Johnston, Kathryn V.},
  year = 2005,
  month = dec,
  journal = {\apj},
  volume = {635},
  pages = {931--949},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/497422},
  url = {https://ui.adsabs.harvard.edu/abs/2005ApJ...635..931B},
  urldate = {2025-05-27},
  abstract = {If the favored hierarchical cosmological model is correct, then the Milky Way system should have accreted \textasciitilde 100-200 luminous satellite galaxies in the past \textasciitilde 12 Gyr. We model this process using a hybrid semianalytic plus N-body approach that distinguishes explicitly between the evolution of light and dark matter in accreted satellites. This distinction is essential to our ability to produce a realistic stellar halo, with mass and density profile much like that of our own Galaxy, and a surviving satellite population that matches the observed number counts and structural parameter distributions of the satellite galaxies of the Milky Way. Our accreted stellar halos have density profiles that typically drop off with radius faster than the dark matter and follow power laws at r{$>$}\textasciitilde 30 kpc with {$\rho$}\textasciitilde r-{$\alpha$}, {$\alpha$}\textasciitilde =3-4. They are well fit by Hernquist profiles over the full radial range. We find that stellar halos are assembled from the inside out, with the majority of mass (\textasciitilde 80\%) coming from the \textasciitilde 15 most massive accretion events. The satellites that contribute to the stellar halo have median accretion times of \textasciitilde 9 Gyr in the past, while surviving satellite systems have median accretion times of \textasciitilde 5 Gyr in the past. This implies that stars associated with the inner halo should be quite different chemically from stars in surviving satellites and also from stars in the outer halo or those liberated in recent disruption events. We briefly discuss the expected spatial structure and phase-space structure for halos formed in this manner. Searches for this type of structure offer a direct test of whether cosmology is indeed hierarchical on small scales.},
  langid = {english},
  keywords = {Astrophysics,Cosmology: Dark Matter,dynamics theory,Galaxies: Dwarf,Galaxies: Evolution,Galaxies: Formation,Galaxies: Halos,Galaxies: Kinematics and Dynamics,Galaxies: Local Group,Galaxy: Evolution,Galaxy: Formation,Galaxy: Halo,Galaxy: Kinematics and Dynamics},
  annotation = {ADS Bibcode: 2005ApJ...635..931B},
  file = {/Users/daniel/Zotero/storage/E4MHQLUY/Bullock and Johnston - 2005 - Tracing Galaxy Formation with Stellar Halos. I. Methods.pdf}
}
