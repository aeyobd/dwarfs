@article{wille+2022,
  title = {Intense Atmospheric Rivers Can Weaken Ice Shelf Stability at the Antarctic Peninsula},
  author = {Wille, Jonathan D. and Favier, Vincent and Jourdain, Nicolas C. and Kittel, Christoph and Turton, Jenny V. and Agosta, C{\'e}cile and Gorodetskaya, Irina V. and Picard, Ghislain and Codron, Francis and Santos, Christophe Leroy-Dos and Amory, Charles and Fettweis, Xavier and Blanchet, Juliette and Jomelli, Vincent and Berchet, Antoine},
  year = 2022,
