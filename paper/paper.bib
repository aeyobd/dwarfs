  doi = {10.3847/2041-8213/ae1608},
  url = {http://arxiv.org/abs/2507.17820},
  urldate = {2025-11-05},
  abstract = {Star formation from metal-free gas, the hallmark of the first generation of Population III stars, was long assumed to occur only in the very early Universe. We report the discovery of MPG-CR3 (Metal-Pristine Galaxy COSMOS Redshift 3; hereafter CR3), an extremely metal-poor galaxy at redshift \$z= 3.193\textbackslash pm0.016\$. From JWST, VLT, and Subaru observations, CR3 exhibits exceptionally strong Ly\$\textbackslash alpha\$, H\$\textbackslash alpha\$, and He I \$\textbackslash lambda\$10830 emission. We measure rest-frame equivalent widths of EW\$\_0\$(Ly\$\textbackslash alpha\$) \$=822\textbackslash pm101\$ Angstrom and EW\$\_0\$(H\$\textbackslash alpha\$) \$=2814\textbackslash pm327\$ Angstrom, among the highest seen in star-forming systems. No metal lines, e.g. [O III] \$\textbackslash lambda\textbackslash lambda4959,5007\$, C IV \$\textbackslash lambda\textbackslash lambda1548,1550\$, have statistically significant detections, placing a 2-\$\textbackslash sigma\$ upper limit on the gas-phase metallicity of 12+log(O/H) {$<$} 6.52 (\$Z {$<$} 7\textbackslash times10\textasciicircum\textbraceleft -3\textbraceright\textbackslash{} Z\_\textbackslash odot\$) with strong-line calibration established by JWST, making it the most metal-poor galaxy known at cosmic noon. Considering systematic uncertainties of \$\textbackslash gtrsim 0.3\$ dex in the calibrations, the most conservative 2-\$\textbackslash sigma\$ upper limit is set to 12+log(O/H) {$<$} 6.95. The observed Ly\$\textbackslash alpha\$/H\$\textbackslash alpha\$ flux ratio is \$13.9\textbackslash pm2.5\$, indicating negligible dust attenuation. Spectral energy distribution modeling with Pop III stellar templates indicates a very young (\$\textbackslash sim2\$ Myr), low-mass (\$M\_* \textbackslash approx 6.1\textbackslash times 10\textasciicircum 5 M\_\textbackslash odot\$) stellar population. Further, the photometric redshifts reveal that CR3 could reside in a slightly underdense environment (\$\textbackslash delta \textbackslash approx -0.12\$). CR3 provides evidence that first-generation star formation could persist well after the epoch of reionization, challenging the conventional view that pristine star formation ended by \$z\textbackslash gtrsim6\$.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics},
  file = {/Users/daniel/Zotero/storage/72335BW7/Cai et al. - 2025 - A Metal-Free Galaxy at $z = 3.19$ Evidence of Late Population III Star Formation at Cosmic Noon.pdf}
}
