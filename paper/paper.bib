@misc{WWJ2024,
  title = {Modeling the Galactic Chemical Evolution of Helium},
  author = {Weller, Miqaela K. and Weinberg, David H. and Johnson, James W.},
  year = 2024,
  month = apr,
  journal = {arXiv e-prints},
  doi = {10.48550/arXiv.2404.08765},
  url = {https://ui.adsabs.harvard.edu/abs/2024arXiv240408765W},
  urldate = {2024-04-17},
  abstract = {We examine the galactic chemical evolution (GCE) of \$\textasciicircum 4\$He in one-zone and multi-zone models, with particular attention to theoretical predictions and empirical constraints on IMF-averaged yields. Published models of massive star winds and core collapse supernovae span a factor of 2 -- 3 in the IMF-averaged \$\textasciicircum 4\$He yield, \$y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright\$. Published models of intermediate mass, asymptotic giant branch (AGB) stars show better agreement on the IMF-averaged yield, \$y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft AGB\textbraceright\textbraceright\$, and they predict that more than half of this yield comes from stars with \$M=4-8 M\_\textbackslash odot\$, making AGB \$\textasciicircum 4\$He enrichment rapid compared to Fe enrichment from Type Ia supernovae. Although our GCE models include many potentially complicating effects, the short enrichment time delay and mild metallicity dependence of the predicted yields makes the results quite simple: across a wide range of metallicity and age, the non-primordial \$\textasciicircum 4\$He mass fraction \$\textbackslash Delta Y = Y-Y\_\textbraceleft\textbackslash mathrm\textbraceleft P\textbraceright\textbraceright\$ is proportional to the abundance of promptly produced \$\textbackslash alpha\$-elements, like oxygen, with \$\textbackslash Delta Y/Z\_\textbraceleft\textbackslash mathrm\textbraceleft O\textbraceright\textbraceright{} \textbackslash approx (y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright +y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft AGB\textbraceright\textbraceright )/y\textbackslash mathrm\textbraceleft\_\textbraceleft O\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright\$. Reproducing solar abundances with our fiducial choice of the oxygen yield \$y\textbackslash mathrm\textbraceleft\_\textbraceleft O\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright =0.0071\$ implies \$y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright +y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft AGB\textbraceright\textbraceright{} \textbackslash approx 0.022\$, i.e., \$0.022M\_\textbackslash odot\$ of net \$\textasciicircum 4\$He production per solar mass of star formation. Our GCE models with this yield normalization are consistent with most available observations, though the implied \$y\textbackslash mathrm\textbraceleft\_\textbraceleft He\textbraceright\textasciicircum\textbraceleft CC\textbraceright\textbraceright\$ is low compared to most of the published massive star models. More precise measurements of \$\textbackslash Delta Y\$ in stars and gas across a wide range of metallicity and [\$\textbackslash alpha\$/Fe] ratio could test our models more stringently, either confirming the simple picture suggested by our calculations or revealing surprises in the evolution of the second most abundant element.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  annotation = {ADS Bibcode: 2024arXiv240408765W},
  file = {/Users/daniel/Zotero/storage/DWUE4H69/Weller et al. - 2024 - Modeling the Galactic Chemical Evolution of Helium.pdf}
}
