@article{gallagher+wyse1994,
  title = {Dwarf Spheroidal Galaxies: Keystones of Galaxy Evolution},
  shorttitle = {Dwarf Spheroidal Galaxies},
  author = {Gallagher, III, John S. and Wyse, Rosemary F. G.},
  year = 1994,
