  shorttitle = {The Araucaria Project},
  author = {Karczmarek, Paulina and Pietrzy{\'n}ski, Grzegorz and Gieren, Wolfgang and Narloch, Weronika and Hajdu, Gergely and Rojas Garc{\'i}a, Gonzalo and Ka{\l}uszy{\'n}ski, Miko{\l}aj and G{\'o}rski, Marek and Suchomska, Ksenia and Graczyk, Dariusz and Pilecki, Bogumi{\l} and Wielg{\'o}rski, Piotr and Zgirski, Bart{\l}omiej and Taormina, M{\'o}nica and Sadh, Mradumay},
  year = 2021,
  month = apr,
  journal = {\apjs},
  volume = {253},
  pages = {42},
  issn = {0067-0049},
  doi = {10.3847/1538-4365/abdf60},
  url = {https://ui.adsabs.harvard.edu/abs/2021ApJS..253...42K},
  urldate = {2025-09-23},
  abstract = {Deep near-infrared (NIR) J- and K-band photometry of three Local Group dwarf spheroidal galaxies---Fornax, Carina, and Sculptor---is made available for the community. Until now, these data have only been used by the Araucaria Project to determine distances using the tip of the red giant branch and RR Lyrae stars. Now, we present the entire data collection in the form of a database, consisting of accurate J- and K-band magnitudes, sky coordinates, ellipticity measurements, and timestamps of observations, complemented by stars' loci in their reference images. The depth of our photometry reaches about 22 mag at the 5{$\sigma$} level, and is comparable to NIR surveys, such as the UKIRT Infrared Deep Sky Survey (UKIDSS) or the VISTA Hemisphere Survey (VHS). Small overlap with VHS and no overlap with UKIDSS makes our database a unique source of quality photometry.},
  langid = {english},
  keywords = {1145,416,792,83,Astronomy databases,Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,Dwarf galaxies,Infrared photometry,Observational astronomy,Sculptor,to read},
  annotation = {ADS Bibcode: 2021ApJS..253...42K},
  file = {/Users/daniel/Zotero/storage/BL6R8E6A/Karczmarek et al. - 2021 - The araucaria project deep near-infrared photometric maps of local and sculptor group galaxies. I..pdf}
}
