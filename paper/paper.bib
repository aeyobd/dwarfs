@article{zhu+2016,
  title = {A Discrete Chemo-Dynamical Model of the Dwarf Spheroidal Galaxy Sculptor: Mass Profile, Velocity Anisotropy and Internal Rotation},
  shorttitle = {A Discrete Chemo-Dynamical Model of the Dwarf Spheroidal Galaxy Sculptor},
  author = {Zhu, Ling and {van de Ven}, Glenn and Watkins, Laura L. and Posti, Lorenzo},
  year = 2016,
  month = nov,
  journal = {\mnras},
  volume = {463},
  pages = {1117--1135},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stw2081},
  url = {https://ui.adsabs.harvard.edu/abs/2016MNRAS.463.1117Z},
  urldate = {2025-04-28},
  abstract = {We present a new discrete chemo-dynamical axisymmetric modelling technique, which we apply to the dwarf spheroidal galaxy Sculptor. The major improvement over previous Jeans models is that realistic chemical distributions are included directly in the dynamical modelling of the discrete data. This avoids loss of information due to spatial binning and eliminates the need for hard cuts to remove contaminants and to separate stars based on their chemical properties. Using a combined likelihood in position, metallicity and kinematics, we find that our models naturally separate Sculptor stars into a metal-rich and a metal-poor population. Allowing for non-spherical symmetry, our approach provides a central slope of the dark matter density of {$\gamma$} = 0.5 \textpm{} 0.3. The metal-rich population is nearly isotropic (with {$\beta$} \_r\textasciicircum\textbraceleft red\textbraceright{} = 0.0\textpm{} 0.1), while the metal-poor population is tangentially anisotropic (with {$\beta$} \_r\textasciicircum\textbraceleft blue\textbraceright{} = -0.2\textpm{} 0.1) around the half-light radius of 0.26 kpc. A weak internal rotation of the metal-rich population is revealed with vmax/{$\sigma$}0 = 0.15 \textpm{} 0.15. We run tests using mock data to show that a discrete data set with {$\sim$}6000 stars is required to distinguish between a core ({$\gamma$} = 0) and cusp ({$\gamma$} = 1), and to constrain the possible internal rotation to better than 1{$\sigma$} confidence with our model. We conclude that our discrete chemo-dynamical modelling technique provides a flexible and powerful tool to robustly constrain the internal dynamics of multiple populations, and the total mass distribution in a stellar system.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: dwarf,galaxies: kinematics and dynamics},
  annotation = {ADS Bibcode: 2016MNRAS.463.1117Z},
  file = {/Users/daniel/Zotero/storage/MDP7TQQF/Zhu et al. - 2016 - A discrete chemo-dynamical model of the dwarf spheroidal galaxy Sculptor mass profile, velocity ani.pdf}
}
