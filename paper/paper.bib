@article{scaioni2018,
  title = {Recognition of Landslides in Lunar Impact Craters},
  author = {Scaioni, Marco and Yordanov, Vasil and Brunetti, Maria and Melis, Maria and Zinzi, Angelo and Kang, Zhizhong and Giommi, Paolo},
