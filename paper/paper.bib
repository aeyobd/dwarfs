@article{christensen+2012,
  title = {Gravitationally Lensed Galaxies at 2 {$<$} z {$<$} 3.5: Direct Abundance Measurements of Ly {$\alpha$} Emitters},
  shorttitle = {Gravitationally Lensed Galaxies at 2 {$<$} z {$<$} 3.5},
  author = {Christensen, Lise and Laursen, Peter and Richard, Johan and Hjorth, Jens and {Milvang-Jensen}, Bo and {Dessauges-Zavadsky}, Miroslava and Limousin, Marceau and Grillo, Claudio and Ebeling, Harald},
