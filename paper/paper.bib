@article{eskridge1988,
  title = {The Structure of the Sculptor Dwarf Elliptical Galaxy. {{I}}. {{The}} Radial Profile},
  author = {Eskridge, Paul B.},
  year = 1988,
  month = jun,
  journal = {\aj},
  volume = {95},
  pages = {1706},
  issn = {0004-6256},
  doi = {10.1086/114767},
  url = {https://ui.adsabs.harvard.edu/abs/1988AJ.....95.1706E},
  urldate = {2024-03-25},
  abstract = {The radial profile of the Sculptor dwarf elliptical galaxy has been determined from automated star counts of UK Schmidt Telescope Unit (UKSTU) plates. The ellipticity (e = 0.34 +/- 0.04) and position angle (P.A.(1950.0) = 95.4\textasciicircum deg\textasciicircum{} +/- 4.3\textasciicircum deg\textasciicircum ) are in agreement with those determined by Hodge (1961b). These profiles have been compared with King (1966) models with a range of tidal and core radii. None have been found to give an excellent fit. The best fit achieved has r\_t\_ = 95' and r\_c\_ = 8.9', and has a standard deviation of {$\sigma$} = 0.28 and {$\chi$}\textasciicircum 2\textasciicircum{} = 0.71 (indicating a 95+ \% confidence limit). Accepting these as roughly the correct values for the core and tidal radii, and using other data from the literature, the mass of the Galaxy has been estimated as M\_G\_\textasciitilde 1.5 +/- 1.1 X 10\textasciicircum 11\textasciicircum{} M\_sun\_. However, the data deviate from this model significantly at large radii, there is an observed overdensity above that expected for the King model beyond R\_maj\_ = 50'. This overdensity is roughly a 2{$\sigma$} effect above the determined background level, and accounts for \textasciitilde 13\% of the stars counted. This compares well with the results of Innanen and Papp (1979) that \textasciitilde 10\% of Sculptor's variable stars are found beyond R\_maj\_=53' (Hodge's 1961b value for r\_t\_). Exponential law fits have also been made, following the suggestion (Faber and Lin 1983) that the halo dwarfs are as well fit by exponential laws as are many disk systems. The mean best fit has an exponential scale of {$\gamma$}= -0.053 +/- 0.001 arcmin\textasciicircum -1\textasciicircum, with a standard deviation of {$\sigma$}= 0.51 and {$\chi$}\textasciicircum 2\textasciicircum{} = 3.8 (still a 95\% + confidence limit). Given the distance modulus of Kunkel and Demers (1977), this implies a physical scale length of r\_e\_\textasciitilde 0.43 kpc. While the data show the same excess with respect to the exponential law fits as found for the King model fits, this excess is not more severe than is seen in many disk systems. The current data, therefore, do not argue against the hypothesis that the halo dwarfs are the results of ram-pressure stripping of dI systems by the Galactic halo.},
  langid = {english},
  keywords = {Astrophysics,Dwarf Galaxies,Elliptical Galaxies,Galactic Mass,Galactic Structure,GALAXIES: GENERAL,Globular Clusters,Radial Distribution,Schmidt Telescopes,Sculptor,Star Formation Rate,to read,Variable Stars},
  annotation = {ADS Bibcode: 1988AJ.....95.1706E},
  file = {/Users/daniel/Zotero/storage/4D5JAP3S/Eskridge - 1988 - The Structure of the Sculptor Dwarf Elliptical Gal.pdf}
}
