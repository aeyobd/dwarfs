@article{SPv1997,
  title = {Stability Criteria for Mass Transfer in Binary Stellar Evolution.},
  author = {Soberman, G. E. and Phinney, E. S. and {van den Heuvel}, E. P. J.},
  year = 1997,
  month = nov,
