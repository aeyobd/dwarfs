  author = {Junais and Cejudo, Ignacio Ruiz and Arencibia, Sergio Guerra and Trujillo, Ignacio and Alarcon, Miguel R. and {Serra-Ricart}, Miquel and Knapen, Johan H. and Duc, Pierre-Alain},
  year = 2025,
