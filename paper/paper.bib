  urldate = {2025-07-24},
  abstract = {The extreme dwarfs of the Local Group, GR 8, Draco, and Ursa Minor have high densities of dark matter. If the dark matter is dissipationless, then there is a simple relation between the redshift of turnaround z\_turn\_ and its current mean density. We find three surprising alternatives for the dSph's. If the dark matter follows the light, then z\_turn\_ {$>$} 30. If we adopt a density profile so that the mean density becomes low enough to be barely consistent with the standard density fluctuation spectrum of cold dark matter (z\_turn\_ {$<$}\textasciitilde{} 10), then the mass-to-light ratios, M/L {$>$} 1000 M\_sun\_L\_sun\_. The last alternative is dissipational dark matter. In this case, the additional collapse factor owing to dissipation allows a later epoch of formation. If the dSph's are composed of weakly interacting massive particles (WIMPs) that mutually annihilate, Draco and Ursa Minor are below the threshold for detection with GRO. However, denser or closer lumps might be seen. If their halos are made of brown dwarfs, the dSph's are excellent targets for dark matter searches.},
  langid = {english},
  keywords = {Astrophysics,Dark Matter,Density Distribution,Dwarf Galaxies,Galactic Evolution,Galactic Structure,GALAXIES: INTERNAL MOTIONS,GALAXIES: STRUCTURE,Local Group (Astronomy),Mass To Light Ratios,Metallicity,Particle Interactions,to read,Ursa Minor},
  annotation = {ADS Bibcode: 1990ApJ...356L..43L},
