@article{lu+2015,
  title = {Star Formation and Stellar Mass Assembly in Dark Matter Haloes: From Giants to Dwarfs},
  shorttitle = {Star Formation and Stellar Mass Assembly in Dark Matter Haloes},
  author = {Lu, Zhankui and Mo, H. J. and Lu, Yu and Katz, Neal and Weinberg, Martin D. and {van den Bosch}, Frank C. and Yang, Xiaohu},
