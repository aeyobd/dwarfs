@article{delosreyes+2022,
  title = {Simultaneous Constraints on the Star Formation History and Nucleosynthesis of Sculptor {{dSph}}},
  author = {{de los Reyes}, Mithi A. C. and Kirby, Evan N. and Ji, Alexander P. and Nu{\~n}ez, Evan H.},
  year = 2022,
  month = jan,
  journal = {\apj},
  volume = {925},
  pages = {66},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/ac332b},
  url = {https://ui.adsabs.harvard.edu/abs/2022ApJ...925...66D},
  urldate = {2025-04-14},
  abstract = {We demonstrate that using up to seven stellar abundance ratios can place observational constraints on the star formation histories (SFHs) of Local Group dSphs, using Sculptor dSph as a test case. We use a one-zone chemical evolution model to fit the overall abundance patterns of {$\alpha$} elements (which probe the core-collapse supernovae that occur shortly after star formation), s-process elements (which probe AGB nucleosynthesis at intermediate delay times), and iron-peak elements (which probe delayed Type Ia supernovae). Our best-fit model indicates that Sculptor dSph has an ancient SFH, consistent with previous estimates from deep photometry. However, we derive a total star formation duration of \textasciitilde 0.9 Gyr, which is shorter than photometrically derived SFHs. We explore the effect of various model assumptions on our measurement and find that modifications to these assumptions still produce relatively short SFHs of duration {$\lessequivlnt$}1.4 Gyr. Our model is also able to compare sets of predicted nucleosynthetic yields for supernovae and AGB stars, and can provide insight into the nucleosynthesis of individual elements in Sculptor dSph. We find that observed [Mn/Fe] and [Ni/Fe] trends are most consistent with sub-M Ch Type Ia supernova models, and that a combination of "prompt" (delay times similar to core-collapse supernovae) and "delayed" (minimum delay times {$\greaterequivlnt$}50 Myr) r-process events may be required to reproduce observed [Ba/Mg] and [Eu/Mg] trends.},
  langid = {english},
  keywords = {1131,1436,1569,1616,2171,416,420,573,Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,Sculptor},
  annotation = {ADS Bibcode: 2022ApJ...925...66D},
  file = {/Users/daniel/Zotero/storage/KW847DPE/de los Reyes et al. - 2022 - Simultaneous Constraints on the Star Formation History and Nucleosynthesis of Sculptor dSph.pdf}
}
