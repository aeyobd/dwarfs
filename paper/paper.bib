  author = {Hayes, Christian R. and Masseron, Thomas and Sobeck, Jennifer and {Garc{\'i}a-Hern{\'a}ndez}, D. A. and Allende Prieto, Carlos and Beaton, Rachael L. and Cunha, Katia and Hasselquist, Sten and Holtzman, Jon A. and J{\"o}nsson, Henrik and Majewski, Steven R. and Shetrone, Matthew and Smith, Verne V. and Almeida, Andr{\'e}s},
  year = 2022,
