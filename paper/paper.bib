@misc{atzberger+2024,
  title = {Chemical Abundances in the Leiptr Stellar Stream: A Disrupted Ultra-Faint Dwarf Galaxy?},
  shorttitle = {Chemical Abundances in the Leiptr Stellar Stream},
  author = {Atzberger, Kaia R. and Usman, Sam A. and Ji, Alexander P. and Cullinane, Lara R. and Erkal, Denis and Hansen, Terese T. and Lewis, Geraint F. and Li, Ting S. and Limberg, Guilherme and Luna, Alice and Martell, Sarah L. and McKenzie, Madeleine and Pace, Andrew B. and Zucker, Daniel B.},
  year = 2024,
  month = oct,
  number = {arXiv:2410.17312},
  eprint = {2410.17312},
  publisher = {arXiv},
  url = {http://arxiv.org/abs/2410.17312},
  urldate = {2024-11-06},
  abstract = {Chemical abundances of stellar streams can be used to determine the nature of a stream's progenitor. Here we study the progenitor of the recently discovered Leiptr stellar stream, which was previously suggested to be a tidally disrupted halo globular cluster. We obtain high-resolution spectra of five red giant branch stars selected from the Gaia DR2 STREAMFINDER catalog with Magellan/MIKE. One star is a clear non-member. The remaining four stars display chemical abundances consistent with those of a low-mass dwarf galaxy: they have a low mean metallicity, \$\textbackslash langle\textbraceleft\textbackslash rm[Fe/H]\textbraceright\textbackslash rangle = -2.2\$; they do not all have identical metallicities; and they display low [\$\textbackslash alpha\$/Fe] \$\textbackslash sim 0\$ and [Sr/Fe] and [Ba/Fe] \$\textbackslash sim -1\$. This pattern of low \$\textbackslash alpha\$ and neutron-capture element abundances is only found in intact dwarf galaxies with stellar mass \$\textbackslash lesssim 10\textasciicircum 5 M\_\textbackslash odot\$. Although more data are needed to be certain, Leiptr's chemistry is consistent with being the lowest-mass dwarf galaxy stream without a known intact progenitor, possibly in the mass range of ultra-faint dwarf galaxies. Leiptr thus preserves a record of one of the lowest-mass early accretion events into the Milky Way.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  file = {/Users/daniel/Zotero/storage/EL2FYPTX/Atzberger et al. - 2024 - Chemical Abundances in the Leiptr Stellar Stream A Disrupted Ultra-faint Dwarf Galaxy.pdf;/Users/daniel/Zotero/storage/5U4HLFJW/2410.html}
}

