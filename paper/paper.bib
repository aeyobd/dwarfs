@article{starkenburg+2019,
  title = {The Pristine Survey -- {{VII}}. {{A}} Cleaner View of the Galactic Outer Halo Using Blue Horizontal Branch Stars},
  author = {Starkenburg, Else and Youakim, Kris and Martin, Nicolas and Thomas, Guillaume and Aguado, David S and Arentsen, Anke and Carlberg, Raymond G and Gonz{\'a}lez~Hern{\'a}ndez, Jonay I and Ibata, Rodrigo and Longeard, Nicolas and McConnachie, Alan W and Navarro, Julio and {S{\'a}nchez-Janssen}, Rub{\'e}n and Venn, Kim A},
