  urldate = {2025-07-25},
  abstract = {An attempt is made to report on a computer simulation of the Magellanic Stream based on the assumption that the stream is tidal debris from the last passage of the Magellanic Clouds past the Galaxy. Some general considerations are discussed along with elementary dynamical limitations on the mass of the Galaxy, the nature of the Magellanic Stream, and the equations used in the simulation. Possible improvements of the simulation are examined, a best-fitting orbit is obtained for the Magellanic Clouds and Stream, and the mass of the Galaxy is determined. The results obtained indicate that the mass of the Galaxy as measured by the orbit of the Magellanic Clouds is significantly larger than the mass as measured out to the sun, the mass as felt by the Magellanic Clouds is probably 450 billion solar masses, the circular velocity of the Galaxy's rotation is about 290 km/s and the Magellanic orbit may have an eccentricity of 0.6 or 0.7.},
  langid = {english},
  keywords = {Angular Distribution,Astronomical Models,Astrophysics,Computerized Simulation,dynamics theory,Galactic Rotation,Gravitational Effects,Magellanic Clouds,Milky Way Galaxy,Orbit Calculation,Radial Velocity,Space Debris,Tides,to read},
  annotation = {ADS Bibcode: 1977MNRAS.181...59L},
  file = {/Users/daniel/Zotero/storage/NQHFMT7L/Lin and Lynden-Bell - 1977 - Simulation of the Magellanic Stream to estimate the total mass of the Milky Way..pdf}
}
