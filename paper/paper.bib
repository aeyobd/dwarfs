@article{pace+2020,
  title = {Multiple Chemodynamic Stellar Populations of the Ursa Minor Dwarf Spheroidal Galaxy},
  author = {Pace, Andrew B. and Kaplinghat, Manoj and Kirby, Evan and Simon, Joshua D. and Tollerud, Erik and Mu{\~n}oz, Ricardo R. and C{\^o}t{\'e}, Patrick and Djorgovski, S. G. and Geha, Marla},
  year = 2020,
  month = jul,
  journal = {\mnras},
  volume = {495},
  pages = {3022--3040},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/staa1419},
  url = {https://ui.adsabs.harvard.edu/abs/2020MNRAS.495.3022P},
  urldate = {2024-11-27},
  abstract = {We present a Bayesian method to identify multiple (chemodynamic) stellar populations in dwarf spheroidal galaxies (dSphs) using velocity, metallicity, and positional stellar data without the assumption of spherical symmetry. We apply this method to a new Keck/Deep Imaging Multi-Object Spectrograph (DEIMOS) spectroscopic survey of the Ursa Minor (UMi) dSph. We identify 892 likely members, making this the largest UMi sample with line-of-sight velocity and metallicity measurements. Our Bayesian method detects two distinct chemodynamic populations with high significance (in logarithmic Bayes factor, ln B \textasciitilde{} 33). The metal-rich ([Fe/H] = -2.05 \textpm{} 0.03) population is kinematically colder (radial velocity dispersion of \$\textbackslash sigma \_v=4.9\_\textbraceleft -1.0\textbraceright\textasciicircum\textbraceleft +0.8\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft km\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$) and more centrally concentrated than the metal-poor (\$[\textbraceleft\textbackslash rm Fe/H\textbraceright ]=-2.29\_\textbraceleft -0.06\textbraceright\textasciicircum\textbraceleft +0.05\textbraceright\$) and kinematically hotter population (\$\textbackslash sigma \_v =11.5\_\textbraceleft -0.8\textbraceright\textasciicircum\textbraceleft +0.9\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft km\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$). Furthermore, we apply the same analysis to an independent Multiple Mirror Telescope (MMT)/Hectochelle data set and confirm the existence of two chemodynamic populations in UMi. In both data sets, the metal-rich population is significantly flattened ({$\epsilon$} = 0.75 \textpm{} 0.03) and the metal-poor population is closer to spherical (\$\textbackslash epsilon =0.33\_\textbraceleft -0.09\textbraceright\textasciicircum\textbraceleft +0.12\textbraceright\$). Despite the presence of two populations, we are able to robustly estimate the slope of the dynamical mass profile. We found hints for prolate rotation of order \$\textbraceleft\textbackslash sim\textbraceright 2 \textbackslash, \textbackslash mathrm\textbraceleft km\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft s\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ in the MMT data set, but further observations are required to verify this. The flattened metal-rich population invalidates assumptions built into simple dynamical mass estimators, so we computed new astrophysical dark matter annihilation (J) and decay profiles based on the rounder, hotter metal-poor population and inferred \$\textbackslash log \_\textbraceleft 10\textbraceright\textbraceleft (J(0\textbraceleft\textasciicircum\textbraceleft\textbackslash circ\textbraceright\_\textbraceleft.\textbraceright\textbraceright 5)/\textbraceleft\textbackslash rm GeV\textasciicircum\textbraceleft 2\textbraceright{} \textbackslash, cm\textasciicircum\textbraceleft -5\textbraceright\textbraceright )\textbraceright\textbackslash approx 19.1\$ for the Keck data set. Our results paint a more complex picture of the evolution of UMi than previously discussed.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,cosmology: dark matter,galaxies: evolution,galaxies: individual: Ursa Minor dSph,galaxies: kinematics and dynamics,Local Group,Ursa Minor},
  annotation = {ADS Bibcode: 2020MNRAS.495.3022P},
  file = {/Users/daniel/Zotero/storage/II3H4NKW/Pace et al. - 2020 - Multiple chemodynamic stellar populations of the Ursa Minor dwarf spheroidal galaxy.pdf}
}
