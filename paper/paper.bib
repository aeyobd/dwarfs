@article{mashchenko+couchman+sills2005,
  title = {Modeling Star Formation in Dwarf Spheroidal Galaxies: A Case for Extended Dark Matter Halos},
  shorttitle = {Modeling Star Formation in Dwarf Spheroidal Galaxies},
