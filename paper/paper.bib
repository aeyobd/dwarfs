@article{wheeler+2019,
  title = {Be It Therefore Resolved: Cosmological Simulations of Dwarf Galaxies with 30 Solar Mass Resolution},
  shorttitle = {Be It Therefore Resolved},
  author = {Wheeler, Coral and Hopkins, Philip F and Pace, Andrew B and {Garrison-Kimmel}, Shea and {Boylan-Kolchin}, Michael and Wetzel, Andrew and Bullock, James S and Kere{\v s}, Du{\v s}an and {Faucher-Gigu{\`e}re}, Claude-Andr{\'e} and Quataert, Eliot},
  year = 2019,
  month = dec,
  journal = {\mnras},
  volume = {490},
  number = {3},
  pages = {4447--4463},
  issn = {0035-8711},
  doi = {10.1093/mnras/stz2887},
  url = {https://doi.org/10.1093/mnras/stz2887},
  urldate = {2025-05-27},
  abstract = {We study a suite of extremely high-resolution cosmological Feedback in Realistic Environments simulations of dwarf galaxies (\$M\_\textbraceleft\textbackslash rm halo\textbraceright{} \textbackslash lesssim 10\textasciicircum\textbraceleft 10\textbraceright\textbackslash rm \textbackslash, M\_\textbraceleft\textbackslash odot \textbraceright\$), run to z~= 0 with \$30\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ resolution, sufficient (for the first time) to resolve the internal structure of individual supernovae remnants within the cooling radius. Every halo with \$M\_\textbraceleft\textbackslash rm halo\textbraceright{} \textbackslash gtrsim 10\textasciicircum\textbraceleft 8.6\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ is populated by a resolved stellar galaxy, suggesting very low-mass dwarfs may be ubiquitous in the field. Our ultra-faint dwarfs (UFDs; \$M\_\textbraceleft\textbackslash ast \textbraceright\textbackslash lt 10\textasciicircum\textbraceleft 5\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$) have their star formation (SF) truncated early (z {$\greaterequivlnt$} 2), likely by reionization, while classical dwarfs (\$M\_\textbraceleft\textbackslash ast \textbraceright\textbackslash gt 10\textasciicircum\textbraceleft 5\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$) continue forming stars to z \&lt; 0.5. The systems have bursty star formation histories, forming most of their stars in periods of elevated SF strongly clustered in both space and time. This allows our dwarf with M*/Mhalo \&gt; 10-4 to form a dark matter core \$\textbraceleft\textbackslash gt\textbraceright 200\textbackslash rm \textbackslash, pc\$, while lower mass UFDs exhibit cusps down to \$\textbraceleft\textbackslash lesssim\textbraceright 100\textbackslash rm \textbackslash, pc\$, as expected from energetic arguments. Our dwarfs with \$M\_\textbraceleft\textbackslash ast \textbraceright\textbackslash gt 10\textasciicircum\textbraceleft 4\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ have half-mass radii (R1/2) in agreement with Local Group (LG) dwarfs (dynamical mass versus R1/2 and stellar rotation also resemble observations). The lowest mass UFDs are below surface brightness limits of current surveys but are potentially visible in next-generation surveys (e.g. LSST). The stellar metallicities are lower than in LG dwarfs; this may reflect pre-enrichment of the LG by the massive hosts or Pop-III stars. Consistency with lower resolution studies implies that our simulations are numerically robust (for a given physical model).},
  langid = {english},
  keywords = {dynamics theory,to read},
  file = {/Users/daniel/Zotero/storage/F4SZ8B6Y/Wheeler et al. - 2019 - Be it therefore resolved cosmological simulations of dwarf galaxies with 30 solar mass resolution.pdf;/Users/daniel/Zotero/storage/AZZRBADE/5588613.html}
}
