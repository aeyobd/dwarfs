@article{pena-guerrero+2017,
  title = {Carbon Abundances in Starburst Galaxies of the Local Universe},
  author = {{Pe{\~n}a-Guerrero}, Mar{\'i}a A. and Leitherer, Claus and {de Mink}, Selma and Wofford, Aida and Kewley, Lisa},
