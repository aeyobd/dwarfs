  urldate = {2024-03-25},
  abstract = {The two-dimensional structure of the Sculptor dwarf elliptical galaxy has been investigated using automated starcounts from United Kingdom Schmidt Telescope Unit (UKSTU) plates. The overall shape of the 2-D contours is similar to that obtained by Hodge (1961b). The existence of nonsymmetric structure in Sculptor has been probed by fitting the starcount data with smooth, symmetric, concentric elliptical contours, then subtracting these fits from the actual data and examining the residual maps. Significant asymmetries are found in the data from all plates, with a maximum density contrast of \textasciitilde{} + 30\% above what is expected for a symmetric fit. All the structure clearly detected is at distances less than or on the order of the core radius. These structures have a physical size of \textasciitilde 150 pc, and a core crossing time of \textasciitilde 10\textasciicircum 8\textasciicircum{} yr. This would seem to imply that they are either bound, or are very young structures. It is possible, however, that they are remnant high-energy star groups, of the sort conjectured by Hodge and Michie (1969), left over from the formation epoch of the system. Calculations following work by Tremaine (1981) indicate that the structures seen should have a decay time due to interaction with the Sculptor core of \textasciitilde 10\textasciicircum 10\textasciicircum{} yr, which is roughly the apparent age of the bulk of Sculptor stars (DaCosta 1984). An estimate of the current ratio of kinetic to potential energy for these structures reinforces the supposition that they are currently dissipating in the tidal field of the Sculptor core.},
  langid = {english},
  keywords = {Astrophysics,Charge Coupled Devices,Dwarf Galaxies,Elliptical Galaxies,Galactic Structure,GALAXIES: INDIVIDUAL,GALAXIES: LOCAL GROUP,GALAXIES: STRUCTURE,Gravitational Fields,H I Regions,Kinetic Energy,Potential Energy,Schmidt Telescopes,Sculptor,Star Formation,Stellar Magnitude,to read,Universe},
  annotation = {ADS Bibcode: 1988AJ.....96.1336E},
