@article{yang+2025b,
  title = {Tidal {{Suppression}} of {{Fuzzy Dark Matter Heating}} in {{Milky Way Satellite Galaxies}}},
  author = {Yang, Yu-Ming and Zhang, Zhao-Chen and Bi, Xiao-Jun and Yin, Peng-Fei},
  year = 2025,
  month = sep,
  journal = {ApJL},
  volume = {990},
  number = {2},
  eprint = {2507.01686},
  primaryclass = {astro-ph},
  pages = {L67},
  issn = {2041-8205, 2041-8213},
  doi = {10.3847/2041-8213/adff81},
  url = {http://arxiv.org/abs/2507.01686},
  urldate = {2025-11-05},
  abstract = {Many previous studies have imposed stringent constraints on the particle mass of fuzzy dark matter (FDM) by analyzing observations of Galactic satellite galaxies, which show no significant evidence of the heating effect predicted by FDM. However, these analyses have generally neglected the tidal influence of the Milky Way, which can substantially suppress the FDM-induced heating effect in satellites. This oversight arises from computational challenges of accurately capturing the tidal effects in FDM simulations. In this study, we present a novel simulation framework that, for the first time, enables the simulation of an FDM-stellar system within an observationally motivated gravitational potential of the Milky Way. This framework incorporates the diverse Galactic components, including the gravitational influence of the Large Magellanic Cloud. Using the Fornax dwarf galaxy as a case study, we demonstrate that tidal effects significantly alleviate the tension between observational data and the predicted heating effect for an FDM particle mass of \$m\_a\textbackslash sim 10\textasciicircum\textbraceleft -22\textbraceright\$ eV.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,High Energy Physics - Phenomenology},
  file = {/Users/daniel/Zotero/storage/VHT6CSK2/Yang et al. - 2025 - Tidal Suppression of Fuzzy Dark Matter Heating in Milky Way Satellite Galaxies.pdf}
}
