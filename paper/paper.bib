@article{lacey+cole1993,
  title = {Merger Rates in Hierarchical Models of Galaxy Formation},
  author = {Lacey, Cedric and Cole, Shaun},
  year = 1993,
  month = jun,
  journal = {\mnras},
  volume = {262},
  number = {3},
  pages = {627--649},
  issn = {0035-8711},
  doi = {10.1093/mnras/262.3.627},
  url = {https://doi.org/10.1093/mnras/262.3.627},
  urldate = {2025-08-18},
  abstract = {We present an analytical description of the merging of virialized haloes which is applicable to any hierarchical model in which structure grows via gravitational instability. The formulae are an extension of the Press-Schechter model. The dependence of the merger rate on halo mass, epoch, the spectrum of initial density fluctuations and the density parameter \textohm 0 is explicitly quantified. We calculate the distribution of halo formation times and survival times. We also describe a Monte Carlo method for constructing representative histories of merger events leading to formation of haloes of a prescribed mass.Applying these results to the age distribution of rich clusters of galaxies, we infer that a high value of the density parameter (\textohm 0 {$\greaterequivlnt$} 0.5) is required to reproduce the substantial fraction of rich clusters that exhibit significant substructure, if such substructure only persists for a time 0.2t0 after a merger, where t0 is the present age of the universe. We also investigate the rate of infall of satellite galaxies into galactic discs, by combining our Monte Carlo technique for halo mergers with an estimate of the time required for dynamical friction to erode the orbits of the baryonic cores of the accreted galaxies. We find that, even for \textohm 0 = 1, the infall rate is low (provided that the satellite orbits are not too eccentric), and that we would expect only a modest fraction of stellar discs to be thickened or disrupted by this process.},
  langid = {english},
  keywords = {Cosmology,to read},
  file = {/Users/daniel/Zotero/storage/GJR7DQ96/Lacey and Cole - 1993 - Merger rates in hierarchical models of galaxy formation.pdf;/Users/daniel/Zotero/storage/EYIWGCU2/262.3.html}
}
