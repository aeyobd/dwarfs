@misc{johnson2025,
  title = {Constraints on Radial Gas Flows in the Milky Way Disk Revealed by Large Stellar Age Catalogs},
  author = {Johnson, James W.},
  year = 2025,
  month = oct,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2510.05223},
  url = {https://ui.adsabs.harvard.edu/abs/2025arXiv251005223J},
  urldate = {2026-03-17},
  abstract = {Disk galaxies like the Milky Way are expected to experience gas flows carrying matter toward their centers. This paper investigates the role of these radial gas flows in models of Galactic chemical evolution (GCE). We follow five different parameterizations of the Galactocentric radial velocity, \$v\_\textbraceleft r,g\textbraceright\$, of the interstellar medium (ISM). Relative to the \$v\_\textbraceleft r,g\textbraceright =0\$ limit, all models predict stellar metallicity to decline less significantly with age in the outer disk and more significantly in the inner disk. This outcome arises because radial flows cannot remove gas from one region of the Galaxy without placing it elsewhere, leading to opposing effects on enrichment timescales between the inner and outer Galaxy. This prediction is at odds with recent observational constraints, which indicate remarkably minimal decline in metallicity (\$\textbackslash lesssim\$\$0.1\$ dex) between young (\$\textbackslash sim\$\$0-2\$ Gyr) and old populations (\$\textbackslash sim\$\$8-10\$ Gyr) across the \textbackslash textit\textbraceleft entire\textbraceright{} Galactic disk. Radial gas flows cannot be the sole explanation of this result at all Galactocentric radii. Our models reproduce this result at \$Rrsim6\$ kpc if the flow velocity is relatively constant in both radius and time near \$v\_\textbraceleft r,g\textbraceright\textbackslash approx-1\$ km/s. In agreement with previous GCE models, all of our flow prescriptions lead to lower metallicities and steeper radial gradients relative to static models. Exploiting this universal outcome, we identify mixing effects and the relative rates of star formation and metal-poor accretion as the processes that establish the ISM metallicity at low redshift. We provide a suite of analytic formulae describing radial metallicity gradient evolution based on this connection.},
  langid = {english},
  keywords = {Astrophysics of Galaxies},
  annotation = {ADS Bibcode: 2025arXiv251005223J},
  file = {/Users/daniel/Zotero/storage/YAENCG9I/Johnson - 2025 - Constraints on radial gas flows in the milky way disk revealed by large stellar age catalogs.pdf}
}
