@misc{wyse+1999,
  title = {The Low-Mass Stellar {{IMF}} at High Redshift: Faint Stars in the Ursa Minor Dwarf Spheroidal Galaxy},
  shorttitle = {The Low-Mass Stellar {{IMF}} at High Redshift},
  author = {Wyse, R. F. G. and Gilmore, G. and Feltzing, S. and Houdashelt, M.},
