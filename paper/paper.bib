@article{matthee+2021,
  title = {The {{X-SHOOTER}} Lyman {$\alpha$} Survey at z = 2 ({{XLS-z2}}) {{I}}: What Makes a Galaxy a Lyman {$\alpha$} Emitter?},
  shorttitle = {The {{X-SHOOTER}} Lyman {$\alpha$} Survey at z = 2 ({{XLS-z2}}) {{I}}},
  author = {Matthee, Jorryt and Sobral, David and Hayes, Matthew and Pezzulli, Gabriele and Gronke, Max and Schaerer, Daniel and Naidu, Rohan P. and R{\"o}ttgering, Huub and Calhau, Jo{\~a}o and {Paulino-Afonso}, Ana and Santos, S{\'e}rgio and Amor{\'i}n, Ricardo},
  year = 2021,
  month = jul,
  journal = {MNRAS},
  volume = {505},
  pages = {1382--1412},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stab1304},
  url = {https://ui.adsabs.harvard.edu/abs/2021MNRAS.505.1382M},
  urldate = {2024-10-15},
  abstract = {We present the first results from the X-SHOOTER Lyman {$\alpha$} survey at z = 2 (XLS-z2). XLS-z2 is a deep spectroscopic survey of 35 Lyman {$\alpha$} emitters (LAEs) utilizing {$\approx$}90 h of exposure time with Very Large Telescope/X-SHOOTER and covers rest-frame Ly {$\alpha$} to H {$\alpha$} emission with R {$\approx$} 4000. We present the sample selection, the observations, and the data reduction. Systemic redshifts are measured from rest-frame optical lines for 33/35 sources. In the stacked spectrum, our LAEs are characterized by an interstellar medium with little dust, a low metallicity, and a high ionization state. The ionizing sources are young hot stars that power strong emission lines in the optical and high-ionization lines in the ultraviolet (UV). The LAEs exhibit clumpy UV morphologies and have outflowing kinematics with blueshifted Si II absorption, a broad [O III] component, and a red-skewed Ly {$\alpha$} line. Typically, 30 per cent of the Ly {$\alpha$} photons escape, of which one quarter on the blue side of the systemic velocity. A fraction of Ly {$\alpha$} photons escape directly at the systemic suggesting clear channels enabling an {$\approx$}10 per cent escape of ionizing photons, consistent with an inference based on Mg II. A combination of a low effective H I column density, a low dust content, and young starburst determines whether a star-forming galaxy is observed as an LAE. The first is possibly related to outflows and/or a fortunate viewing angle, while we find that the latter two in LAEs are typical for their stellar mass of 109 M{$\odot$}.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,dark ages,first stars,galaxies: formation,galaxies: ISM,galaxies: starburst,reionization},
  annotation = {ADS Bibcode: 2021MNRAS.505.1382M},
  file = {/Users/daniel/Zotero/storage/8CA4BDZF/Matthee et al. - 2021 - The X-SHOOTER Lyman α survey at z = 2 (XLS-z2) I what makes a galaxy a Lyman α emitter.pdf}
}
