@article{herwig+austin+lattanzio2006,
  title = {Nuclear Reaction Rate Uncertainties and Astrophysical Modeling: Carbon Yields from Low-Mass Giants},
  shorttitle = {Nuclear Reaction Rate Uncertainties and Astrophysical Modeling},
  author = {Herwig, Falk and Austin, Sam M. and Lattanzio, John C.},
  year = 2006,
  month = feb,
  journal = {PhRvC},
  volume = {73},
  pages = {25802},
  publisher = {APS},
  issn = {0556-2813},
  doi = {10.1103/PhysRevC.73.025802},
  url = {https://ui.adsabs.harvard.edu/abs/2006PhRvC..73b5802H},
  urldate = {2024-05-10},
  abstract = {Calculations that demonstrate the influence of three key nuclear reaction rates on the evolution of asymptotic giant branch stars have been carried out. We study the case of a star with an initial mass of 2M{$\odot$} and a metallicity of Z=0.01, somewhat less than the solar metallicity. The dredge-up of nuclear processed material from the interior of the star and the yield predictions for carbon are sensitive to the rate of the 14N(p,{$\gamma$})15O and triple-{$\alpha$} reactions. These reactions dominate the H- and He-burning shells of stars in this late evolutionary phase. Published uncertainty estimates for each of these two rates propagated through stellar evolution calculations cause uncertainties in carbon enrichment and yield predictions of about a factor of 2. The other important He-burning reaction, 12C({$\alpha$},{$\gamma$})16O, although associated with the largest uncertainty in our study, does not have a significant influence on the abundance evolution compared with other modeling uncertainties. This finding remains valid when the entire evolution from the main sequence to the tip of the asymptotic giant branch is considered. We discuss the experimental sources of the rate uncertainties addressed here and give some outlooks for future work.},
  langid = {english},
  keywords = {26.20.+f,97.10.Cv,97.60.-s,Astrophysics,Hydrostatic stellar nucleosynthesis,Late stages of stellar evolution,Nuclear Experiment,Stellar structure interiors evolution nucleosynthesis ages},
  annotation = {ADS Bibcode: 2006PhRvC..73b5802H},
  file = {/Users/daniel/Zotero/storage/QMY286ZB/Herwig et al. - 2006 - Nuclear reaction rate uncertainties and astrophysi.pdf}
}
