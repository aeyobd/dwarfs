@article{suarez-andres+2017,
  title = {{{CNO}} Behaviour in Planet-Harbouring Stars. {{II}}. {{Carbon}} Abundances in Stars with and without Planets Using the {{CH}} Band},
  author = {{Su{\'a}rez-Andr{\'e}s}, L. and Israelian, G. and Gonz{\'a}lez Hern{\'a}ndez, J. I. and Adibekyan, V. {\relax Zh}. and Delgado Mena, E. and Santos, N. C. and Sousa, S. G.},
  year = 2017,
