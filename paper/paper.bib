@article{evans+marchetti+rossi2022,
  title = {Constraints on the Galactic Centre Environment from Gaia Hypervelocity Stars {{II}}: The Evolved Population},
  shorttitle = {Constraints on the Galactic Centre Environment from Gaia Hypervelocity Stars {{II}}},
  author = {Evans, F A and Marchetti, T and Rossi, E M},
  year = 2022,
  month = dec,
  journal = {Mon. Not. R. Astron. Soc.},
  volume = {517},
  number = {3},
  pages = {3469--3484},
  issn = {0035-8711},
  doi = {10.1093/mnras/stac2865},
  url = {https://doi.org/10.1093/mnras/stac2865},
  urldate = {2026-02-03},
  abstract = {A dynamical encounter between a stellar binary and Sgr A* in the Galactic Centre (GC) can tidally separate the binary and eject one member with a velocity beyond the escape speed of the Milky Way. These hypervelocity stars (HVSs) can offer insight into the stellar populations in the GC environment. In a previous work, our simulations showed that the lack of main sequence HVS candidates with precise astrometric uncertainties and radial velocities in current data releases from the Gaia space mission places a robust upper limit on the ejection rate of HVSs from the GC of \$3\textbackslash times 10\textasciicircum\textbraceleft -2\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft yr\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$. We improve this constraint in this work by additionally considering the absence of post-main sequence HVSs in Gaia Early Data Release 3 as well as the existence of the HVS candidate S5-HVS1. This evidence offers degenerate joint constraints on the HVS ejection rate and the stellar initial mass function (IMF) in the GC. For a top-heavy GC IMF as suggested by recent works, our modelling motivates an HVS ejection rate of \$\textbackslash eta =0.7\_\textbraceleft -0.5\textbraceright\textasciicircum\textbraceleft +1.5\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft -4\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft yr\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$. This preferred ejection rate can be as large as \$10\textasciicircum\textbraceleft -2\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft yr\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$ for a very top-light IMF and as low as 10\$\textasciicircum\textbraceleft -4.5\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft yr\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$ if the IMF is extremely top-heavy. Constraints will improve further with future Gaia data releases, regardless of how many HVS candidates are found therewithin.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/QLSP228P/Evans et al. - 2022 - Constraints on the galactic centre environment from gaia hypervelocity stars II the evolved populat.pdf}
}
