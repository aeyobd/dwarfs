@misc{cheng+2026,
  title = {Bottom-Heavy Initial Mass Functions Reveal Hidden Mass in Early Galaxies},
  author = {Cheng, Chloe M. and Slob, Martje and Kriek, Mariska and Beverage, Aliza G. and {van Dokkum}, Pieter G. and Bezanson, Rachel and Brammer, Gabriel and Conroy, Charlie and {de Graaff}, Anna and Eftekhari, Elham and Feldmann, Robert and Goesaert, Wout M. and Gu, Meng and Leja, Joel and Lorenz, Brian and Mancera Pi{\~n}a, Pavel E. and {Mart{\'i}n-Navarro}, Ignacio and Newman, Andrew B. and Price, Sedona H. and Shapley, Alice E. and Sharda, Piyush and Suess, Katherine A. and {van der Wel}, Arjen and Weisz, Daniel R.},
  year = 2026,
  month = jan,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.20864},
  url = {https://ui.adsabs.harvard.edu/abs/2026arXiv260120864C},
  urldate = {2026-02-03},
  abstract = {JWST observations have revealed that massive galaxies formed and evolved far faster than predicted by galaxy formation models, with many having already assembled a large mass in stars \$\textbackslash sim12\$ billion years ago [1-7]. However, masses of distant galaxies are highly uncertain, as they assume a distribution of stellar birth masses (the initial mass function [IMF]) similar to that in the Milky Way (MW). Specifically, the contribution from low-mass stars, which make up the bulk of stellar mass, is not directly observed, but inferred based on an extrapolation of the MW IMF. Here, we provide the first robust measurements of the IMF beyond the local Universe. Using ultra-deep spectra of nine massive, quiescent galaxies at \$z\textbackslash sim0.7\$ from the ambitious JWST-IMFERNO program, extended to bluer wavelengths with deep spectra from LEGA-C [8], we find that these distant galaxies have excess low-mass stars. In other words, they have more bottom-heavy IMFs than the MW. For the oldest two galaxies, which are direct descendants of JWST's "impossibly early" galaxies, the bottom-heavy IMFs increase their stellar masses by a factor of \$3-4\$. These galaxies thus amplify the tension with galaxy formation models.},
  keywords = {Astrophysics of Galaxies},
  annotation = {ADS Bibcode: 2026arXiv260120864C},
  file = {/Users/daniel/Zotero/storage/4RRLLVAW/Cheng et al. - 2026 - Bottom-heavy initial mass functions reveal hidden mass in early galaxies.pdf}
}
