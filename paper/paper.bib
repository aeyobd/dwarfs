@article{battaglia+2008a,
  title = {Analysis and Calibration of {{Ca II}} Triplet Spectroscopy of Red Giant Branch Stars from {{VLT}}/{{FLAMES}} Observations},
  author = {Battaglia, G. and Irwin, M. and Tolstoy, E. and Hill, V. and Helmi, A. and Letarte, B. and Jablonka, P.},
  year = 2008,
  month = jan,
  journal = {\mnras},
  volume = {383},
  pages = {183--199},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1111/j.1365-2966.2007.12532.x},
  url = {https://ui.adsabs.harvard.edu/abs/2008MNRAS.383..183B},
  urldate = {2024-07-16},
  abstract = {We demonstrate that low-resolution Ca II triplet (CaT) spectroscopic estimates of the overall metallicity ([Fe/H]) of individual red giant branch (RGB) stars in two nearby dwarf spheroidal galaxies (dSphs) agree to \textpm 0.1-0.2 dex with detailed high-resolution spectroscopic determinations for the same stars over the range -2.5 {$<$} [Fe/H] {$<$} -0.5. For this study, we used a sample of 129 stars observed in low- and high-resolution modes with VLT/FLAMES in the Sculptor and Fornax dSphs. We also present the data-reduction steps we used in our low-resolution analysis and show that the typical accuracy of our velocity and CaT [Fe/H] measurement is \textasciitilde 2 km s-1 and 0.1 dex, respectively. We conclude that CaT-[Fe/H] relations calibrated on globular clusters can be applied with confidence to RGB stars in composite stellar populations over the range -2.5 {$<$} [Fe/H] {$<$} -0.5.},
  langid = {english},
  keywords = {Astrophysics,Sculptor},
  annotation = {ADS Bibcode: 2008MNRAS.383..183B},
  file = {/Users/daniel/Zotero/storage/8AC7DX2X/Battaglia et al. - 2008 - Analysis and calibration of Ca II triplet spectroscopy of red giant branch stars from VLTFLAMES obs.pdf}
}
