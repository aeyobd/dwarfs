@article{omeara+2001,
  title = {The Deuterium to Hydrogen Abundance Ratio toward a Fourth {{QSO}}: {{HS}} 0105+1619},
  shorttitle = {The Deuterium to Hydrogen Abundance Ratio toward a Fourth {{QSO}}},
  author = {O'Meara, John M. and Tytler, David and Kirkman, David and Suzuki, Nao and Prochaska, Jason X. and Lubin, Dan and Wolfe, Arthur M.},
  year = 2001,
