@misc{lucchini+2025,
  title = {The {{LMC Corona}} as {{Evidence}} for a {{First Passage}}},
  author = {Lucchini, Scott and Han, Jiwon Jesse and Mishra, Sapna and Fox, Andrew J.},
  year = 2025,
