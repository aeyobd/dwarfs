@article{sestito+2023b,
  title = {The Extended 'stellar Halo' of the Ursa Minor Dwarf Galaxy},
  author = {Sestito, Federico and Zaremba, Daria and Venn, Kim A. and D'Aoust, Lina and Hayes, Christian and Jensen, Jaclyn and Navarro, Julio F. and Jablonka, Pascale and {Fern{\'a}ndez-Alvar}, Emma and Glover, Jennifer and McConnachie, Alan W. and Chen{\'e}, Andr{\'e}-Nicolas},
  year = 2023,
  month = oct,
  journal = {\mnras},
  volume = {525},
  pages = {2875--2890},
  issn = {0035-8711},
  doi = {10.1093/mnras/stad2427},
  url = {https://ui.adsabs.harvard.edu/abs/2023MNRAS.525.2875S},
  urldate = {2024-03-07},
  abstract = {Stellar candidates in the Ursa Minor (UMi) dwarf galaxy have been found using a new Bayesian algorithm applied to Gaia EDR3 data. Five of these targets are located in the extreme outskirts of UMi, from \textasciitilde 5 to 12 elliptical half-light radii (rh), where rh(UMi) = 17.32 \textpm{} 0.11 arcmin, and have been observed with the high-resolution Gemini Remote Access to CFHT ESPaDOnS Spectrograph at the Gemini North telescope. Precise radial velocities ({$\sigma$}RV {$<$} 2 km s-1) and metallicities (\$\textbackslash sigma \_\textbraceleft\textbackslash rm \textbraceleft\textbraceleft\textbackslash rm [Fe/H]\textbraceright\textbraceright\textbraceright\textbackslash{} \textbackslash{} 0.2\$ dex) confirm their memberships of UMi. Detailed analysis of the brightest and outermost star (Target 1, at \textasciitilde 12rh), yields precision chemical abundances for the {$\alpha$} (Mg, Ca, and Ti), odd-Z (Na, K, and Sc), Fe-peak (Fe, Ni, and Cr), and neutron-capture (Ba) elements. With data from the literature and APOGEE data release 17, we find the chemical patterns in UMi are consistent with an outside-in star-formation history that includes yields from core-collapse supernovae, asymptotic giant branch stars, and Type Ia supernovae. Evidence for a knee in the [{$\alpha$}/Fe] ratios near [Fe/H] \textasciitilde{} -2.1 indicates a low star-formation efficiency similar to that in other dwarf galaxies. Detailed analysis of the surface number density profile shows evidence that UMi's outskirts have been populated by tidal effects, likely as a result of completing multiple orbits around the Galaxy.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,galaxies: dwarf,galaxies: evolution,galaxies: formation,galaxies: individual: Ursa Minor,stars: abundances,stars: Population II,Ursa Minor},
  annotation = {ADS Bibcode: 2023MNRAS.525.2875S},
  file = {/Users/daniel/Zotero/storage/CB5R2KU7/Sestito et al. - 2023 - The extended 'stellar halo' of the Ursa Minor dwar.pdf}
}
