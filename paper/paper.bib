@article{erb+2010,
  title = {Physical Conditions in a Young, Unreddened, Low-Metallicity Galaxy at High Redshift},
  author = {Erb, Dawn K. and Pettini, Max and Shapley, Alice E. and Steidel, Charles C. and Law, David R. and Reddy, Naveen A.},
  year = 2010,
  month = aug,
  journal = {ApJ},
  volume = {719},
  pages = {1168--1190},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/719/2/1168},
  url = {https://ui.adsabs.harvard.edu/abs/2010ApJ...719.1168E},
  urldate = {2024-05-21},
  abstract = {Increasingly large samples of galaxies are now being discovered at redshifts z \textasciitilde{} 5-6 and higher. Many of these objects are inferred to be young, low in mass, and relatively unreddened, but detailed analysis of their high quality spectra will not be possible until the advent of future facilities. In this paper, we shed light on the physical conditions in a plausibly similar low-mass galaxy by presenting the analysis of the rest-frame optical and UV spectra of Q2343-BX418, an L* galaxy at z = 2.3 with a very low mass-to-light ratio and unusual properties: BX418 is young ({$<$}100 Myr), low mass (M sstarf \textasciitilde{} 109 M sun), low in metallicity (Z \textasciitilde{} 1/6 Z sun), and unreddened (E(B - V) \textasciitilde = 0.02, UV continuum slope {$\beta$} = -2.1). We infer a metallicity 12 + log(O/H) = 7.9 \textpm{} 0.2 from the rest-frame optical emission lines. We also determine the metallicity via the direct, electron temperature method, using the ratio O III] {$\lambda\lambda$}1661, 1666/[O III] {$\lambda$}5007 to determine the electron temperature and finding 12 + log(O/H) = 7.8 \textpm{} 0.1. These measurements place BX418 among the most metal-poor galaxies observed in emission at high redshift. The rest-frame UV spectrum, which represents \textasciitilde 12 hr of integration with the Keck telescope, contains strong emission from Ly{$\alpha$} (with rest-frame equivalent width 54 \AA ), He II {$\lambda$}1640 (both stellar and nebular), C III] {$\lambda\lambda$}1907, 1909 and O III] {$\lambda\lambda$}1661, 1666. The C IV/C III] ratio indicates that the source of ionization is unlikely to be an active galactic nucleus. Analysis of the He II, O III], and C III] line strengths indicates a very high ionization parameter log U \textasciitilde{} -1, while Ly{$\alpha$} and the interstellar absorption lines indicate that outflowing gas is highly ionized over a wide range of velocities. It remains to be determined how many of BX418's unique spectral features are due to its global properties, such as low metallicity and dust extinction, and how many are indicative of a short-lived phase in the early evolution of an otherwise normal star-forming galaxy. Based on data obtained at the W. M. Keck Observatory, which is operated as a scientific partnership among the California Institute of Technology, the University of California, and NASA, and was made possible by the generous financial support of the W. M. Keck Foundation.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,galaxies: abundances,galaxies: evolution,galaxies: high-redshift},
  annotation = {ADS Bibcode: 2010ApJ...719.1168E},
  file = {/Users/daniel/Zotero/storage/X7WL2MCF/Erb et al. - 2010 - Physical Conditions in a Young, Unreddened, Low-me.pdf}
}
