@article{grillmair2009,
  title = {Four New Stellar Debris Streams in the Galactic Halo},
  author = {Grillmair, C. J.},
  year = 2009,
  month = mar,
  journal = {\apj},
  volume = {693},
  pages = {1118--1127},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/693/2/1118},
  url = {https://ui.adsabs.harvard.edu/abs/2009ApJ...693.1118G},
  urldate = {2025-05-16},
  abstract = {We report on the detection of four new stellar debris streams and a new dwarf galaxy candidate in the Sloan Digital Sky Survey. Three of the streams, ranging between 3 and 15 kpc in distance and spanning between 37{$^\circ$} and 84{$^\circ$} on the sky, are very narrow and are most probably tidal streams originating in extant or disrupted globular clusters. The fourth stream is much broader, roughly 45 kpc distant, at least 53{$^\circ$} in length, and is most likely the tidal debris from a dwarf galaxy. As each of the streams spans multiple constellations, we extend tradition and designate them the Acheron, Cocytos, Lethe, and Styx streams. At the same distance and apparently embedded in the Styx stream is a \textasciitilde 1 kpc wide concentration of stars with an apparently similar color-magnitude distribution, which we designate Bootes III. Given its very low surface density, its location within the stream, and its apparently disturbed morphology, we argue that Bootes III may be the progenitor of Styx and in possibly the final throes of tidal dissolution. While the current data do not permit strong constraints, preliminary orbit estimates for the streams do not point to any likely progenitors among the known globular clusters and dwarf galaxies.},
  langid = {english},
  keywords = {Astrophysics,Bootes III,Galaxy: halo,Galaxy: structure,globular clusters: general},
  annotation = {ADS Bibcode: 2009ApJ...693.1118G},
  file = {/Users/daniel/Zotero/storage/257D3BN9/Grillmair - 2009 - Four New Stellar Debris Streams in the Galactic Halo.pdf}
}
