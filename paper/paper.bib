  shorttitle = {Spectral Properties of Cool Stars},
  author = {Brewer, John M. and Fischer, Debra A. and Valenti, Jeff A. and Piskunov, Nikolai},
  year = 2016,
  month = aug,
  journal = {Astrophys. J. Suppl. Ser.},
  volume = {225},
  pages = {32},
