@article{tsai2023,
  title = {The {{Evolution}} of {{Population III}} and {{Extremely Metal-poor Binary Stars}}},
  author = {Tsai, Sung-Han and Chen, Ke-Jung and Whalen, Daniel and Ou, Po-Sheng and Woods, Tyrone E.},
  year = 2023,
