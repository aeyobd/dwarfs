@article{tully+2013,
  title = {Cosmicflows-2: The Data},
  shorttitle = {Cosmicflows-2},
  author = {Tully, R. Brent and Courtois, H{\'e}l{\`e}ne M. and Dolphin, Andrew E. and Fisher, J. Richard and H{\'e}raudeau, Philippe and Jacobs, Bradley A. and Karachentsev, Igor D. and Makarov, Dmitry and Makarova, Lidia and Mitronova, Sofia and Rizzi, Luca and Shaya, Edward J. and Sorce, Jenny G. and Wu, Po-Feng},
