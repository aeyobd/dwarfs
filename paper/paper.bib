@article{sanderson+2020,
  title = {Synthetic Gaia Surveys from the {{FIRE}} Cosmological Simulations of Milky Way-Mass Galaxies},
  author = {Sanderson, Robyn E. and Wetzel, Andrew and Loebman, Sarah and Sharma, Sanjib and Hopkins, Philip F. and {Garrison-Kimmel}, Shea and {Faucher-Gigu{\`e}re}, Claude-Andr{\'e} and Kere{\v s}, Du{\v s}an and Quataert, Eliot},
  year = 2020,
  month = jan,
  journal = {\apjs},
  volume = {246},
