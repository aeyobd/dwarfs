@article{lake1990,
  title = {The Distribution of Dark Matter in Draco and Ursa Minor},
  author = {Lake, George},
  year = 1990,
  month = jun,
  journal = {\mnras},
  volume = {244},
  pages = {701},
  publisher = {OUP},
  issn = {0035-8711},
  url = {https://ui.adsabs.harvard.edu/abs/1990MNRAS.244..701L},
  urldate = {2025-04-28},
  abstract = {Draco and Ursa Minor both have published velocity dispersions of \textasciitilde 10 km s\textasciicircum -1\textasciicircum{} implying large amounts of dark matter. Previous assumptions that the dark matter distribution followed the light led to central densities 2-3 orders of magnitude greater than in other dwarf galaxies. I construct models where the stellar distribution function is isothermal and use star counts to constrain the mass distribution. Even with these different assumptions, the dark matter densities are high. For a constant density halo, the best fit values are {$\rho$} \textasciitilde 0.2 M\_sun\_ pc\textasciicircum -3\textasciicircum{} and the lower limits are D {$\rho>$}\textasciitilde{} 0.1 M\_sun\_ pc\textasciicircum -3\textasciicircum. Draco is poorly fitted with a uniform density halo, but good fits are obtained using a dark matter distribution with a core radius. In this model, the apparent cut-off radius has nothing to do with galactic tides. For comparison, King's empirical formula was refitted. The derived tidal radii, r\_t\_, are only lower limits, r\_t.D\_ {$>$} 25 arcmin and r\_t.UM\_ {$>$} 35 arcmin. If the dark matter follows the light, then {$\rho\_$}0.D\_ {$>$}\textasciitilde{} 0.4 M\_sun\_ pc\textasciicircum -3\textasciicircum{} and {$\rho\_$}0.UM\_ {$>$}\textasciitilde{} 0.2 M\_sun\_ pc\textasciicircum -3\textasciicircum. Both have M/L\_V\_ {$>$} 25 M\_sun\_/L\_sun\_. In all the models, the central column density of dark matter is as large as that of bright galaxies, i.e. 100-300M\_sun\_ pc\textasciicircum -2\textasciicircum. Since the central surface brightnesses are low, Ursa Minor and Draco are excellent targets for dark matter searches.},
  langid = {english},
  keywords = {Astrophysics,Brightness Distribution,Dark Matter,Dwarf Galaxies,Galactic Structure,Irregular Galaxies,Isothermal Processes,Mass Distribution,Spiral Galaxies,Star Distribution,to read,Ursa Minor},
  annotation = {ADS Bibcode: 1990MNRAS.244..701L},
  file = {/Users/daniel/Zotero/storage/CVGIGGJR/Lake - 1990 - The distribution of dark matter in Draco and Ursa Minor..pdf}
}
