  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,catalogues,techniques: image processing,virtual observatory tools},
  annotation = {ADS Bibcode: 2020MNRAS.491..129C},
