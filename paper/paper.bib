@article{sales+helmi+battaglia2010,
  title = {The {{Effect}} of {{Tidal Stripping}} on {{Composite Stellar Populations}} in {{Dwarf Spheroidal Galaxies}}},
  author = {Sales, Laura V. and Helmi, Amina and Battaglia, Giuseppina},
