@article{ritter+2018,
  title = {{{NuGrid}} Stellar Data Set - {{II}}. {{Stellar}} Yields from {{H}} to {{Bi}} for Stellar Models with {{MZAMS}} = 1-25 {{M}}{$\odot$} and {{Z}} = 0.0001-0.02},
  author = {Ritter, C. and Herwig, F. and Jones, S. and Pignatari, M. and Fryer, C. and Hirschi, R.},
  year = 2018,
