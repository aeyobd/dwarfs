@article{penarrubia+2015,
  title = {A Timing Constraint on the (Total) Mass of the Large Magellanic Cloud},
  author = {Pe{\~n}arrubia, Jorge and G{\'o}mez, Facundo A. and Besla, Gurtina and Erkal, Denis and Ma, Yin-Zhe},
  year = 2015,
  month = dec,
  journal = {Monthly Notices of the Royal Astronomical Society Letters},
  volume = {456},
  number = {1},
  pages = {L54-L58},
  issn = {1745-3925},
  doi = {10.1093/mnrasl/slv160},
  url = {https://doi.org/10.1093/mnrasl/slv160},
  urldate = {2024-10-29},
  abstract = {This paper explores the effect of the Large Magellanic Cloud (LMC) on the mass estimates obtained from the timing argument. We show that accounting for the presence of the LMC systematically lowers the Local Group mass (MLG) derived from the relative motion of the Milky Way--Andromeda pair. Motivated by this result, we apply a Bayesian technique devised by Pe\~narrubia et~al. to simultaneously fit (i) distances and velocities of galaxies within 3~Mpc and (ii) the relative motion between the Milky Way and Andromeda derived from HST observations, with the LMC mass (MLMC) as a free parameter. Our analysis returns a Local Group mass \$M\_\textbraceleft\textbackslash rm LG\textbraceright =2.64\textasciicircum\textbraceleft +0.42\textbraceright\_\textbraceleft -0.38\textbraceright\textbackslash times 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash,\textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ at a 68~per~cent confidence level. The masses of the Milky Way, \$M\_\textbraceleft\textbackslash rm MW\textbraceright =1.04\_\textbraceleft -0.23\textbraceright\textasciicircum\textbraceleft +0.26\textbraceright\textbackslash times 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash,\textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$, and Andromeda, \$M\_\textbraceleft\textbraceleft\textbackslash rm M\textbraceright 31\textbraceright =1.33\_\textbraceleft -0.33\textbraceright\textasciicircum\textbraceleft +0.39\textbraceright\textbackslash times 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash,\textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$, are consistent with previous estimates that neglect the impact of the LMC on the observed Hubble flow. We find a (total) LMC mass \$M\_\textbraceleft\textbackslash rm LMC\textbraceright =0.25\_\textbraceleft -0.08\textbraceright\textasciicircum\textbraceleft +0.09\textbraceright\textbackslash times 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash,\textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$, which is indicative of an extended dark matter halo and supports the scenario where this galaxy is just past its first pericentric approach. Consequently, these results suggest that the LMC may induce significant perturbations on the Galactic potential.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: evolution,Galaxy: kinematics and dynamics,Magellanic Clouds,to read},
  file = {/Users/daniel/Zotero/storage/AH64WLMY/Peñarrubia et al. - 2015 - A timing constraint on the (total) mass of the Large Magellanic Cloud.pdf;/Users/daniel/Zotero/storage/RV8CBCEF/2589502.html}
}
