@article{papastergis+2012,
  title = {A Direct Measurement of the Baryonic Mass Function of Galaxies and Implications for the Galactic Baryon Fraction},
  author = {Papastergis, Emmanouil and Cattaneo, Andrea and Huang, Shan and Giovanelli, Riccardo and Haynes, Martha P.},
  year = 2012,
  month = nov,
  journal = {\apj},
  volume = {759},
  pages = {138},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/759/2/138},
