@article{johnson+2023,
  title = {Dwarf Galaxy Archaeology from Chemical Abundances and Star-Formation Histories},
  author = {Johnson, James W. and Conroy, Charlie and Johnson, Benjamin D. and Peter, Annika H. G. and Cargile, Phillip A. and Bonaca, Ana and Naidu, Rohan P. and Woody, Turner and Ting, Yuan-Sen and Han, Jiwon Jesse and Speagle, Joshua S.},
