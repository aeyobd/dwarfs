@article{yaaqib+petersen+penarrubia2024,
  title = {The Radial Variation of the {{LMC-induced}} Reflex Motion of the Milky Way Disc Observed in the Stellar Halo},
  author = {Yaaqib, Rashid and Petersen, Michael S. and Pe{\~n}arrubia, Jorge},
  year = 2024,
