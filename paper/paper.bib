@article{
  title = {The Magellanic Edges Survey {{I}}: Description and First Results},
  shorttitle = {The Magellanic Edges Survey {{I}}},
  author = {Cullinane, L. R. and Mackey, A. D. and Da Costa, G. S. and Koposov, S. E. and Belokurov, V. and Erkal, D. and Koch, A. and Kunder, A. and Nataf, D. M.},
  year = 2020,
  month = sep,
  journal = {Mon. Not. R. Astron. Soc.},
  volume = {497},
  pages = {3055--3075},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/staa2048},
  url = {https://ui.adsabs.harvard.edu/abs/2020MNRAS.497.3055C},
  urldate = {2026-02-26},
  abstract = {We present an overview of, and first science results from, the Magellanic Edges Survey (MagES), an ongoing spectroscopic survey mapping the kinematics of red clump and red giant branch stars in the highly substructured periphery of the Magellanic Clouds. In conjunction with Gaia astrometry, MagES yields a sample of \textasciitilde 7000 stars with individual 3D velocities that probes larger galactocentric radii than most previous studies. We outline our target selection, observation strategy, data reduction, and analysis procedures, and present results for two fields in the northern outskirts ({$>$}10{$^\circ$} on-sky from the centre) of the Large Magellanic Cloud (LMC). One field, located in the vicinity of an arm-like overdensity, displays apparent signatures of perturbation away from an equilibrium disc model. This includes a large radial velocity dispersion in the LMC disc plane, and an asymmetric line-of-sight velocity distribution indicative of motions vertically out of the disc plane for some stars. The second field reveals 3D kinematics consistent with an equilibrium disc, and yields Vcirc = 87.7 \textpm{} 8.0 km s-1 at a radial distance of \textasciitilde 10.5 kpc from the LMC centre. This leads to an enclosed mass estimate for the LMC at this radius of (1.8 \textpm{} 0.3) \texttimes{} 1010 M{$\odot$}.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: kinematics and dynamics,galaxies: stellar content,galaxies: structure,Magellanic Clouds,stars: kinematics and dynamics},
  annotation = {ADS Bibcode: 2020MNRAS.497.3055C},
  file = {/Users/daniel/Zotero/storage/PDB8N92Z/Cullinane et al. - 2020 - The magellanic edges survey I description and first results.pdf}
}
