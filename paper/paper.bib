@article{hollands2023,
  title = {Measuring the {{Initial-Final Mass-Relation}} Using Wide Double White Dwarf Binaries from {{Gaia DR3}}},
  author = {Hollands, M. A. and Littlefair, S. P. and Parsons, S. G.},
