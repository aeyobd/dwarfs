@article{cehula2023,
  title = {A Theory of Mass Transfer in Binary Stars},
  author = {Cehula, Jakub and Pejcha, Ond{\v r}ej},
  year = 2023,
  month = sep,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {524},
  pages = {471--490},
  issn = {0035-8711},
  doi = {10.1093/mnras/stad1862},
  url = {https://ui.adsabs.harvard.edu/abs/2023MNRAS.524..471C},
  urldate = {2023-11-18},
  abstract = {Calculation of the mass transfer (MT) rate \$\textbackslash dot\textbraceleft M\textbraceright\_\textbackslash text\textbraceleft d\textbraceright\$ of a Roche lobe overflowing star is a fundamental task in binary star evolution theory. Most of the existing MT prescriptions are based on a common set of assumptions that combine optically thick and optically thin regimes with different flow geometries. In this work, we develop a new model of MT based on the assumption that the Roche potential sets up a nozzle converging on the inner Lagrangian point and that the gas flows mostly along the axis connecting both stars. We derive a set of 1D hydrodynamic equations governing the gas flow with \$\textbackslash dot\textbraceleft M\textbraceright\_\textbackslash text\textbraceleft d\textbraceright\$ determined as the eigenvalue of the system. The inner boundary condition directly relates our model to the structure of the donor obtained from 1D stellar evolution codes. We obtain an algebraic solution for the polytropic equation-of-state (EOS). This gives \$\textbackslash dot\textbraceleft M\textbraceright\_\textbackslash text\textbraceleft d\textbraceright\$ within a factor of 0.9 to 1.0 of existing optically thick prescriptions and reduces to the existing optically thin prescription for isothermal gas. For a realistic EOS, we find that \$\textbackslash dot\textbraceleft M\textbraceright\_\textbackslash text\textbraceleft d\textbraceright\$ differs by up to a factor of 4 from existing models. We illustrate the effects of our new MT model on a \$30\textbackslash, M\_\textbackslash odot\$ low-metallicity star undergoing intensive thermal time-scale MT and find that it is more likely to become unstable to L2 overflow and common-envelope evolution than expected according to MT prescriptions. Our model provides a framework to include additional physics such as radiation or magnetic fields.},
  keywords = {Astrophysics - High Energy Astrophysical Phenomena,Astrophysics - Solar and Stellar Astrophysics,binaries: close,hydrodynamics,methods: analytical,stars: mass-loss},
  annotation = {ADS Bibcode: 2023MNRAS.524..471C},
  file = {/Users/daniel/Zotero/storage/Z59CMCGX/Cehula and Pejcha - 2023 - A theory of mass transfer in binary stars.pdf}
}
