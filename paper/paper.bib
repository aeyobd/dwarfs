@article{riemer-sorensen+2017,
  title = {A Precise Deuterium Abundance: Remeasurement of the z = 3.572 Absorption System towards the Quasar {{PKS1937-101}}},
  shorttitle = {A Precise Deuterium Abundance},
  author = {{Riemer-S{\o}rensen}, S. and Kotu{\v s}, S. and Webb, J. K. and Ali, K. and Dumont, V. and Murphy, M. T. and Carswell, R. F.},
  year = 2017,
  month = jul,
  journal = {MNRAS},
  volume = {468},
  pages = {3239--3250},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stx681},
  url = {https://ui.adsabs.harvard.edu/abs/2017MNRAS.468.3239R},
  urldate = {2025-01-12},
  abstract = {The primordial deuterium abundance probes fundamental physics during the big bang nucleosynthesis and can be used to infer cosmological parameters. Observationally, the abundance can be measured using absorbing clouds along the lines of sight to distant quasars. Observations of the quasar PKS1937-101 contain two absorbers for which the deuterium abundance has previously been determined. Here, we focus on the higher redshift one at zabs = 3.572. We present new observations with significantly increased signal-to-noise ratio that enable a far more precise and robust measurement of the deuterium to hydrogen column density ratio, resulting in D I/H I = 2.62 \textpm{} 0.05 \texttimes{} 10-5. This particular measurement is of interest because it is amongst the most precise assessments to date and it has been derived from the second lowest column-density absorber [N(H I) = 17.9 cm-2] that has so-far been utilized for deuterium abundance measurements. The majority of existing high-precision measurements were obtained from considerably higher column density systems [I.e. N(H I) {$>$} 19.4 cm-2]. This bodes well for future observations as low column density systems are more common.},
  langid = {english},
  keywords = {abundances,Astrophysics - Cosmology and Nongalactic Astrophysics,cosmological parameters,nuclear reactions,nucleosynthesis,primordial nucleosynthesis,quasars: absorption lines},
  annotation = {ADS Bibcode: 2017MNRAS.468.3239R},
  file = {/Users/daniel/Zotero/storage/CKLURE4U/Riemer-Sørensen et al. - 2017 - A precise deuterium abundance remeasurement of the z = 3.572 absorption system towards the quasar P.pdf}
}
