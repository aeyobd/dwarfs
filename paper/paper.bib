@misc{cai+2025,
  title = {A {{Metal-Free Galaxy}} at \$z = 3.19\$? {{Evidence}} of {{Late Population III Star Formation}} at {{Cosmic Noon}}},
  shorttitle = {A {{Metal-Free Galaxy}} at \$z = 3.19\$?},
  author = {Cai, Sijia and Li, Mingyu and Cai, Zheng and Wu, Yunjing and Yu, Fujiang and Dickinson, Mark and Sun, Fengwu and Fan, Xiaohui and Wang, Ben and Cullen, Fergus and Bian, Fuyan and Lin, Xiaojing and Zou, Jiaqi},
