@article{grichener2019,
  title = {The {{Common Envelope Jet Supernova}} ({{CEJSN}}) r-Process {{Scenario}}},
  author = {Grichener, Aldana and Soker, Noam},
  year = 2019,
  month = jun,
  journal = {The Astrophysical Journal},
  volume = {878},
  pages = {24},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/ab1d5d},
  url = {https://ui.adsabs.harvard.edu/abs/2019ApJ...878...24G},
  urldate = {2023-11-07},
  abstract = {We study r-process feasibility inside jets launched by a cold neutron star (NS) spiraling in inside the core of a giant star and find that such common envelope jet supernova events might be a significant source of heavy r-process elements in the early universe. We run the stellar evolution code MESA to follow the evolution of low-metallicity giant stars that swallow NSs during their late expansion phases and find that in some of the cases the NSs penetrate the core. The Bondi-Hoyle-Lyttleton (BHL) mass accretion rate onto an NS as it spirals in inside the core is sufficiently high to obtain a neutron-rich ejecta as required for the heavy r-process where the second and third r-process elements are synthesized. Due to the small radius of the NS, the accretion is through an accretion disk and the outflow is in jets (or bipolar disk winds). The r-process nucleosynthesis takes place inside the jets. To account for the r-process abundances in the Galaxy, we require that 1 in 10 cases of an NS entering the envelope of a giant star ends as a CEJSN r-process event.},
  keywords = {abundances,Astrophysics - High Energy Astrophysical Phenomena,Astrophysics - Solar and Stellar Astrophysics,binaries: close,nuclear reactions,nucleosynthesis,stars: jets,supernovae: general},
  annotation = {ADS Bibcode: 2019ApJ...878...24G},
  file = {/Users/daniel/Zotero/storage/P6ERUQDC/Grichener and Soker - 2019 - The Common Envelope Jet Supernova (CEJSN) r-proces.pdf}
}
