@article{tolstoy+2004,
  title = {Two Distinct Ancient Components in the Sculptor Dwarf Spheroidal Galaxy: First Results from the Dwarf Abundances and Radial Velocities Team},
  shorttitle = {Two Distinct Ancient Components in the Sculptor Dwarf Spheroidal Galaxy},
  author = {Tolstoy, Eline and Irwin, M. J. and Helmi, A. and Battaglia, G. and Jablonka, P. and Hill, V. and Venn, K. A. and Shetrone, M. D. and Letarte, B. and Cole, A. A. and Primas, F. and Francois, P. and Arimoto, N. and Sadakane, K. and Kaufer, A. and Szeifert, T. and Abel, T.},
  year = 2004,
  month = dec,
  journal = {\apj},
  volume = {617},
  pages = {L119-L122},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/427388},
  url = {https://ui.adsabs.harvard.edu/abs/2004ApJ...617L.119T},
  urldate = {2025-04-28},
  abstract = {We have found evidence for the presence of two distinct ancient stellar components (both {$>$}=10 Gyr old) in the Sculptor dwarf spheroidal galaxy. We used the ESO Wide Field Imager in conjunction with the Very Large Telescope/FLAMES spectrograph to study the properties of the resolved stellar population of Sculptor out to and beyond the tidal radius. We find that two components are discernible in the spatial distribution of horizontal branch stars in our imaging and in the [Fe/H] and vhel distributions for our large sample of spectroscopic measurements. They can be generally described as a ``metal-poor'' component ([Fe/H]{$<$}-1.7) and a ``metal-rich'' component ([Fe/H]{$>$}-1.7). The metal-poor stars are more spatially extended than the metal-rich stars, and they also appear to be kinematically distinct. These results provide insight into the formation processes of small systems in the early universe and the conditions found there. Even this simplest of galaxies appears to have had a surprisingly complex early evolution. Based on FLAMES observations collected at the ESO, proposals 71.B-0641 and 171.B-0588.},
  langid = {english},
  keywords = {Astrophysics,Galaxies: Abundances,Galaxies: Evolution,Galaxies: Individual: Name: Sculptor,Galaxies: Kinematics and Dynamics,Sculptor,to read},
  annotation = {ADS Bibcode: 2004ApJ...617L.119T},
  file = {/Users/daniel/Zotero/storage/DDVI2CGG/Tolstoy et al. - 2004 - Two Distinct Ancient Components in the Sculptor Dwarf Spheroidal Galaxy First Results from the Dwar.pdf}
}
