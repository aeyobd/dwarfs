  doi = {10.1051/0004-6361/202453063},
  url = {https://www.aanda.org/articles/aa/abs/2025/11/aa53063-24/aa53063-24.html},
  urldate = {2026-01-30},
  abstract = {\emph{Context{$<$}i/{$>$}. Observational studies are identifying stars thought to be remnants from the earliest stages of the Milky Way's hierarchical mass assembly, referred to as the proto-Galaxy.\emph{Aims{$<$}i/{$>$}. We used red giant stars with kinematics from \emph{Gaia{$<$}i/{$>$} DR3 RVS data and [\emph{{$\alpha<$}i/{$>$}/M] and [M/H] estimates from low-resolution \emph{Gaia{$<$}i/{$>$} XP spectra to investigate the relationship between azimuthal velocity and metallicity. Our aim is to understand the transition from a chaotic proto-Galaxy to a well-ordered rotating (high-\emph{{$\alpha<$}i/{$>$}) disc-like population.\emph{Methods{$<$}i/{$>$}. To analyze the structure of the data in [M/H]-v\textsubscript{\emph{{$\phi<$}i/{$><$}sub/{$>$} space for both high- and low-\emph{{$\alpha<$}i/{$>$} samples with carefully defined \emph{{$\alpha<$}i/{$>$}-separation, we developed a model with two Gaussian components in v\textsubscript{\emph{{$\phi<$}i/{$><$}sub/{$>$}, one representing a disc-like population and the other a halo-like population. This model is designed to capture the conditional distribution P(v\textsubscript{\emph{{$\phi<$}i/{$><$}sub/{$>$} \textbar [M/H]) with a two-component Gaussian mixture model with fixed means and standard deviations in the azimuthal velocities. To quantify the spin-up of the high-\emph{{$\alpha<$}i/{$>$} disc population, we extended this two-component model by allowing the mean velocity and velocity dispersion to vary between the spline knots across the metallicity range used. We also compared our findings with existing literature using traditional Gaussian mixture modelling in bins of [M/H] and investigated using orbital circularity instead of azimuthal velocity.\emph{Results{$<$}i/{$>$}. Our findings show that the metal-poor high-\emph{{$\alpha<$}i/{$>$} disc gradually spins up across [M/H] {$\sim-$}1.7 to -1, while the low-\emph{{$\alpha<$}i/{$>$} sample exhibits a sharp transition at [M/H] {$\asymp-$}1. This latter result is due to the accreted (mostly \emph{Gaia{$<$}i/{$>$}-Enceladus-Sausage) debris dominating the metal-poor end, underscoring the critical role of [\emph{{$\alpha<$}i/{$>$}/M] selection in studying the Milky Way's (old, high-\emph{{$\alpha<$}i/{$>$}) disc evolution.\emph{Conclusions{$<$}i/{$>$}. These results indicate that the proto-Galaxy underwent a slow, monotonic spin-up phase over increasing metallicities rather than a rapid, dramatic spin-up at [M/H] {$\sim-$}1, as previously inferred in the literature.}}}}}}}}}}}}}}}}}}}}}}}},
  copyright = {\copyright{} The Authors 2025},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/7YHU6Q2M/Viswanathan et al. - 2025 - A slow spin to win the gradual kinematic evolution across metallicities of the proto-galaxy to the.pdf}
}
