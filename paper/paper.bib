@article{lelli+fraternali+verheijen2014,
  title = {Evolution of Dwarf Galaxies: A Dynamical Perspective},
  shorttitle = {Evolution of Dwarf Galaxies},
  author = {Lelli, Federico and Fraternali, Filippo and Verheijen, Marc},
  year = 2014,
  month = mar,
  journal = {\aap},
  volume = {563},
  pages = {A27},
  publisher = {EDP Sciences},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/201322658},
  url = {https://www.aanda.org/articles/aa/abs/2014/03/aa22658-13/aa22658-13.html},
  urldate = {2025-07-08},
  abstract = {For a rotating galaxy, the inner circular-velocity gradient d\textsubscript{\emph{R{$<$}i/{$><$}sub/{$>$}\emph{V{$<$}i/{$>$}(0) provides a direct estimate of the central dynamical mass density, including gas, stars, and dark matter. We consider 60 low-mass galaxies with high-quality H I and/or stellar rotation curves (including starbursting dwarfs, irregulars, and spheroidals), and estimate d\textsubscript{\emph{R{$<$}i/{$><$}sub/{$>$}\emph{V{$<$}i/{$>$}(0) as \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$}, where \emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} is the galaxy scale length. For gas-rich dwarfs, we find that \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} correlates with the central surface brightness \emph{{$\mu<$}i/{$>$}\textsubscript{0{$<$}sub/{$>$}, the mean atomic gas surface density {$\Sigma$}\textsubscript{gas{$<$}sub/{$>$}, and the star formation rate surface density {$\Sigma$}\textsubscript{SFR{$<$}sub/{$>$}. Starbursting galaxies, such as blue compact dwarfs (BCDs), generally have higher values of \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} than dwarf irregulars, suggesting that the starburst is closely related to the inner shape of the potential well. There are, however, some ``compact'' irregulars with values of \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} similar to BCDs. Unless a redistribution of mass takes place, BCDs must evolve into compact irregulars. Rotating spheroidals in the Virgo cluster follow the same correlation between \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} and \emph{{$\mu<$}i/{$>$}\textsubscript{0{$<$}sub/{$>$} as gas-rich dwarfs. They have values of \emph{V{$<$}i/{$>$}\textsubscript{\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$><$}sub/{$>$}/\emph{R{$<$}i/{$>$}\textsubscript{d{$<$}sub/{$>$} comparable to those of BCDs and compact irregulars, pointing to evolutionary links between these types of dwarfs. Finally, we find that, as for spiral galaxies and massive starbursts, the star-formation activity in dwarfs can be parametrized as {$\Sigma$}\textsubscript{SFR{$<$}sub/{$>$} = \emph{{$\epsilon<$}i/{$>$} {$\Sigma$}\textsubscript{gas{$<$}sub/{$>$}/\emph{{$\tau<$}i/{$>$}\textsubscript{orb{$<$}sub/{$>$}, where \emph{{$\tau<$}i/{$>$}\textsubscript{orb{$<$}sub/{$>$} is the orbital time and \emph{{$\epsilon<$}i/{$>$} {$\simeq$} 0.02.}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}},
  copyright = {\copyright{} ESO, 2014},
  langid = {english},
  keywords = {to read},
  file = {/Users/daniel/Zotero/storage/IZG55TXT/Lelli et al. - 2014 - Evolution of dwarf galaxies a dynamical perspective.pdf}
}
