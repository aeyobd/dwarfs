@article{MOF2009,
  title = {A {{Physiologically-based Model}} for {{Simulation}} of {{Color Vision Deficiency}}},
  author = {Machado, Gustavo M. and Oliveira, Manuel M. and Fernandes, Leandro A. F.},
  year = 2009,
