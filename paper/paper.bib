@article{calura+lanfranchi+matteucci2008,
  title = {The Evolution of the Photometric Properties of Local Group Dwarf Spheroidal Galaxies},
  author = {Calura, F. and Lanfranchi, G. A. and Matteucci, F.},
  year = 2008,
  month = jun,
