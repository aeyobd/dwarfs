@article{
  title = {Hubble Space Telescope Proper Motions of Large Magellanic Cloud Star Clusters: {{II}}. {{Kinematic}} Structure of Young and Intermediate-Age Clusters},
  shorttitle = {Hubble Space Telescope Proper Motions of Large Magellanic Cloud Star Clusters},
  author = {Niederhofer, F. and Cullinane, L. and Massari, D. and Bastian, N. and Bellini, A. and {Aguado-Agelet}, F. and Cassisi, S. and Erkal, D. and Libralato, M. and Kacharov, N. and {Cabrera-Ziri}, I. and Ceccarelli, E. and Cioni, M.-R. L. and Dresbach, F. and H{\"a}berle, M. and Martocchia, S. and Saracino, S.},
  year = 2026,
  month = jan,
  journal = {Astron. Astrophys.},
  volume = {705},
  pages = {A94},
  publisher = {EDP},
  issn = {0004-6361},
  doi = {10.1051/0004-6361/202557397},
  url = {https://ui.adsabs.harvard.edu/abs/2026A&A...705A..94N},
  urldate = {2026-02-26},
  abstract = {In this paper, we explore the kinematic properties of a sample of 19 young ({$<$}1 Gyr) and intermediate-age (1-2.5 Gyr) massive star clusters within the Large Magellanic Cloud (LMC). We analysed the proper motions of the clusters, which have been measured based on multi-epoch Hubble Space Telescope (HST) observations. Additionally, from the HST data we inferred homogeneous and robust estimates for the distances, ages, and metallicities of the clusters. This collection of information, in combination with literature line-of-sight velocities, allowed us to investigate the full 3D dynamics of our sample of clusters within the frame of the LMC in a self-consistent way. While most young clusters orbit the LMC close to the stellar disc plane, NGC 1850 ({$\sim$}100 Myr old) depicts a peculiar case. Depending on the exact distance from the disc, it follows either a highly inclined retrograde orbit or an eccentric orbit along the bar structure. The orbits of young clusters that formed north of the LMC centre show signs that might be connected to the resettling motion of the LMC bar structure. Based on the dynamic properties in combination with the positions of the clusters in the age-metallicity space, we find no clear-cut evidence of clusters in our sample that could have been stripped from the Small Magellanic Cloud (SMC) onto the LMC. Finally, we compared the kinematics of the intermediate-age clusters with a suite of simple numerical simulations of the Magellanic system to interpret the cluster motions. A possible interaction history of the LMC with the SMC, where the SMC had two past crossings of the LMC disc plane (about 300 and 900 Myr ago), in combination with the recent SMC pericentre passage, can qualitatively explain the observed kinematic structure of the clusters analysed in this work.},
  langid = {english},
  keywords = {Astrophysics of Galaxies,galaxies: interactions,galaxies: star clusters: general,Magellanic Clouds,proper motions,stars: kinematics and dynamics,techniques: photometric},
  annotation = {ADS Bibcode: 2026A\&A...705A..94N},
  file = {/Users/daniel/Zotero/storage/3TWJWSS5/Niederhofer et al. - 2026 - Hubble space telescope proper motions of large magellanic cloud star clusters II. Kinematic structu.pdf}
}
