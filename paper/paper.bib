@article{kleyna+2003,
  title = {A Dynamical Fossil in the Ursa Minor Dwarf Spheroidal Galaxy},
  author = {Kleyna, Jan T. and Wilkinson, Mark I. and Gilmore, Gerard and Evans, N. Wyn},
  year = 2003,
  month = may,
  journal = {\apj},
  volume = {588},
  pages = {L21-L24},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/375522},
  url = {https://ui.adsabs.harvard.edu/abs/2003ApJ...588L..21K},
  urldate = {2024-11-27},
  abstract = {The nearby Ursa Minor dwarf spheroidal (UMi dSph) is one of the most dark matter-dominated galaxies known, with a central mass-to-light ratio M/L\textasciitilde 70. Somewhat anomalously, it appears to contain morphological substructure in the form of a second peak in the stellar number density. It is often argued that this substructure must be transient, because it could not survive for the \textasciitilde 12 Gyr age of the system, given the crossing time implied by UMi's 8.8 km s-1 internal velocity dispersion. In this Letter, however, we present evidence that the substructure has a cold kinematical signature and argue that UMi's clumpiness could indeed be a primordial artefact. Using numerical simulations, we demonstrate that substructure is incompatible with the cusped dark matter halos predicted by the prevailing cold dark matter (CDM) paradigm but is consistent with an unbound stellar cluster sloshing back and forth within the nearly harmonic potential of a cored dark matter halo. Thus, CDM appears to disagree with observation at the least massive, most dark matter-dominated end of the galaxy mass spectrum.},
  langid = {english},
  keywords = {Astrophysics,Celestial Mechanics,Cosmology: Dark Matter,Galaxies: Individual: Name: Ursa Minor dwarf spheroidal,Galaxies: Kinematics and Dynamics,Galaxies: Local Group,Stellar Dynamics,Ursa Minor},
  annotation = {ADS Bibcode: 2003ApJ...588L..21K},
  file = {/Users/daniel/Zotero/storage/YHQ8JK5G/Kleyna et al. - 2003 - A Dynamical Fossil in the Ursa Minor Dwarf Spheroidal Galaxy.pdf}
}
