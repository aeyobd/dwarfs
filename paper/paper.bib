@misc{wang+2025,
  title = {Collisional {{Baryon-Dominated Dwarf Galaxies}}: {{A New Probe}} of {{Bursty Feedback}} and {{Dark Matter Physics}}},
  shorttitle = {Collisional {{Baryon-Dominated Dwarf Galaxies}}},
  author = {Wang, Yi-Ying and Yang, Daneng and Lu, Keyu and Tsai, Yue-Lin Sming and Fan, Yi-Zhong},
  year = 2025,
  month = sep,
  number = {arXiv:2509.24270},
  eprint = {2509.24270},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2509.24270},
  url = {http://arxiv.org/abs/2509.24270},
  urldate = {2025-11-05},
  abstract = {High-velocity collisions between gas-rich ultra-diffuse galaxies present a promising formation channel for baryon-dominated dwarf galaxies (BDDGs). Using hydrodynamical simulations, we show that the progenitors' baryonic binding energy, \$\textbar E\_\textbraceleft\textbackslash rm bind\textbraceright\textbar\$, critically controls the outcome. Repeated potential fluctuations, e.g., from bursty feedback, inject energy and reduce \$\textbar E\_\textbraceleft\textbackslash rm bind\textbraceright\textbar\$ by \$\textbackslash approx 15\textbackslash\%\$, yielding fewer but substantially more massive BDDGs. By contrast, elastic self-interacting dark matter produces comparable cores without lowering \$\textbar E\_\textbraceleft\textbackslash rm bind\textbraceright\textbar\$, resulting in negligible effect. This provides a novel way to distinguish between two leading galactic core formation channels, i.e., the baryon feedback and elastic dark matter self-interaction. Among 15 paired simulation runs, 13 show higher BDDG masses in the weakened-binding case, and about two thirds exhibit \${$>$}100\textbackslash\%\$ mass enhancements. The simulations also predict systematically lower gas fractions due to sustained post-collision star formation, yielding a clean observational signature. Upcoming wide-field imaging (CSST, LSST), HI surveys (FAST), and kinematic follow-up will be crucial to test this scenario.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,to read},
  file = {/Users/daniel/Zotero/storage/Z243SKPP/Wang et al. - 2025 - Collisional Baryon-Dominated Dwarf Galaxies A New Probe of Bursty Feedback and Dark Matter Physics.pdf}
}
