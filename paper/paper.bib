  author = {Han, Zhan-Wen and Ge, Hong-Wei and Chen, Xue-Fei and Chen, Hai-Liang},
  year = 2020,
  month = oct,
  journal = {Res. Astron. Astrophys.},
  volume = {20},
  number = {10},
  pages = {161},
