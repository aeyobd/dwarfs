@article{garcia-rojas+2007,
  title = {The Chemical Composition of the Galactic {{H II}} Regions {{M8}} and {{M17}}. {{A}} Revision Based on Deep {{VLT}} Echelle Spectrophotometry},
  author = {{Garc{\'i}a-Rojas}, J. and Esteban, C. and Peimbert, A. and Rodr{\'i}guez, M. and Peimbert, M. and Ruiz, M. T.},
  year = 2007,
