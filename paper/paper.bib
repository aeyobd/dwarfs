@article{bugueno+2026,
  title = {On the Origin of Counterrotating Stellar Disks in {{TNG50}}. {{I}}},
  author = {Bugue{\~n}o, M. C. and G{\'o}mez, Facundo A. and Dolfi, Arianna and Tissera, Patricia B.},
  year = 2026,
  month = mar,
  journal = {A\&A},
  volume = {707},
  eprint = {2510.03106},
  primaryclass = {astro-ph},
  pages = {A51},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/202557544},
  url = {http://arxiv.org/abs/2510.03106},
  urldate = {2026-03-20},
  abstract = {Understanding galaxy evolution is key to explaining the structures we observe in the present-day Universe. Counterrotating stellar disks (CRDs), i.e. co-spatial stellar disks rotating with opposite angular momentum, have been proposed as signatures of past accretion events. Therefore, they constitute potentially valuable tracers of galactic assembly. We aim to investigate the properties, formation, and significance of CRDs in a sample of Milky Way mass galaxies using the IllustrisTNG cosmological simulations. We select 260 central late-type galaxies (i.e. \$M\_\textbraceleft\textbackslash rm tot\textbraceright{} \textbackslash approx 10\textasciicircum\textbraceleft 12\textbraceright\$, \$D/T{$>$}0.5\$, \$N\_\textbraceleft\textbackslash rm star\textbraceright{$>$}10\textasciicircum 5\$). For each galaxy, we measure the circularity of its stellar particles and define the CRD by considering all particles with circularity \${$\varepsilon<$} -0.7\$, which are located within the spatial extension of the main disk. We then characterize the mass fraction, spatial extent, and star formation history of the CRDs. Out of the 260 galaxies, we find that 26 host significant CRDs (i.e. contributing at least 1\textbackslash\% of the total stellar mass of the disk). This means that CRDs are rare, consistent with the results from observations. We also find that the most of the CRDs are compact (i.e. 88\textbackslash\%), in-situ dominated (i.e.73\textbackslash\%), and exhibit bursty SFHs whose peaks often coincide with external perturbations. This means that external perturbations are able to catalyze star formation, even when a majority of the CRD's star population is in-situ. Finally, we find that a variety of formation pathways can lead to CRDs, including interaction-induced in-situ bursts and smooth accretion of misaligned gas. Overall, our results suggest that CRDs are rare but diverse in origin. In most cases, their formation is linked to the accretion of retrograde gas, either through mergers or environmental inflow, suggesting that these structures are sensitive tracers of the galaxy's past accretion history.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/WGURTKNJ/Bugueño et al. - 2026 - On the origin of counterrotating stellar disks in TNG50. I.pdf}
}
