  author = {Yang, Yong and Zhao, Jing-Kun and Ishigaki, Miho N. and Zhou, Jian-Zhao and Yang, Cheng-Qun and Xue, Xiang-Xiang and Ye, Xian-Hao and Zhao, Gang},
