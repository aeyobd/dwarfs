@article{carlin+sand2018,
  title = {Bo\"otes {{III}} Is a Disrupting Dwarf Galaxy Associated with the Styx Stellar Stream},
  author = {Carlin, Jeffrey L. and Sand, D. J.},
  year = 2018,
  month = sep,
  journal = {\apj},
  volume = {865},
  pages = {7},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/aad8c1},
  url = {https://ui.adsabs.harvard.edu/abs/2018ApJ...865....7C},
  urldate = {2025-05-16},
  abstract = {We present proper motion (PM) measurements of Bo\"otes III, an enigmatic stellar satellite of the Milky Way (MW), utilizing data from the second data release of the Gaia mission. By selecting 15 radial velocity confirmed members of Bo\"otes III, along with a likely RR Lyrae member in the vicinity, we measure an error-weighted mean PM of ({$\mu$} {$\alpha$} \textbackslash cos {$\delta$} , {$\mu$} {$\delta$} ) = (-1.14, -0.98) \textpm{} (0.18, 0.20) mas yr-1. We select and present further stars that may be Bo\"otes III members based on their combined PM and position in the color-magnitude diagram. We caution against assigning membership to stars that are not confirmed spectroscopically, as we demonstrate that there are contaminating stars from the disrupting globular cluster NGC 5466 in the vicinity of the main body of Bo\"otes III, but we note that our results are consistent with previous Bo\"otes III PM estimates that did not include spectroscopic members. Based on the measured PM and other known properties of Bo\"otes III, we derive its Galactocentric velocity and compute its orbit given canonical MW potentials with halo masses of both 0.8 \texttimes{} 1012 M {$\odot$} and 1.6 \texttimes{} 1012 M {$\odot$}. These orbits robustly show that Bo\"otes III passed within {$\sim$}12 kpc of the Galactic center on an eccentric orbit roughly {$\sim$}140 Myr ago. Additionally, the PM of Bo\"otes III is in excellent agreement with predictions for the retrograde motion of the coincident Styx stellar stream. Given this, along with the small pericenter and metallicity spread of Bo\"otes III itself, we suggest that it is a disrupting dwarf galaxy giving rise to the Styx stellar stream.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Bootes III,galaxies: individual: Bootes III,galaxies: interactions,galaxies: kinematics and dynamics,proper motions},
  annotation = {ADS Bibcode: 2018ApJ...865....7C},
  file = {/Users/daniel/Zotero/storage/IWYKAHLN/Carlin and Sand - 2018 - Boötes III is a Disrupting Dwarf Galaxy Associated with the Styx Stellar Stream.pdf}
}
