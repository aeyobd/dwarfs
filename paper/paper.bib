@misc{sit+weinberg+griffith2025,
  title = {On the {{Origin}} of {{Abundance Variations}} in the {{Milky Way}}'s {{High-}}\${$\alpha\$$} {{Plateau}}},
  author = {Sit, Tawny and Weinberg, David H. and Griffith, Emily J.},
  year = 2025,
  month = mar,
  number = {arXiv:2503.07738},
  eprint = {2503.07738},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2503.07738},
  url = {http://arxiv.org/abs/2503.07738},
  urldate = {2025-07-15},
  abstract = {Using multi-element abundances from the SDSS APOGEE survey, we investigate the origin of abundance variations in Milky Way (MW) disk stars on the "high-\$\textbackslash alpha\$ plateau," with \$-0.8\textbackslash leq\textbackslash rm\textbraceleft [Fe/H]\textbraceright\textbackslash leq-0.4\$ and \$0.25\textbackslash leq\textbackslash rm\textbraceleft [Mg/Fe]\textbraceright\textbackslash leq0.35\$. The elevated [\$\textbackslash alpha\$/Fe] ratios of these stars imply low enrichment contributions from Type Ia supernovae (SNIa), but it is unclear whether their abundance patterns reflect pure core-collapse supernova (CCSN) enrichment. We find that plateau stars with higher [Fe/Mg] ratios also have higher [X/Mg] ratios for other iron-peak elements, suggesting that the [Fe/Mg] variations in the plateau population do reflect variations in the SNIa/CCSN ratio. To quantify this finding, we fit the observed abundance patterns with a two-process model, calibrated on the full MW disk, which represents each star's abundances as the sum of a prompt CCSN process with amplitude \$A\_\textbraceleft\textbackslash text\textbraceleft cc\textbraceright\textbraceright\$ and a delayed SNIa process with amplitude \$A\_\textbraceleft\textbackslash text\textbraceleft Ia\textbraceright\textbraceright\$. This model is generally successful at explaining the observed trends of [X/Mg] with \$A\_\textbraceleft\textbackslash text\textbraceleft Ia\textbraceright\textbraceright/A\_\textbraceleft\textbackslash text\textbraceleft cc\textbraceright\textbraceright\$, which are steeper for elements with a large SNIa contribution (e.g., Cr, Ni, Mn) and flatter for elements with low SNIa contribution (e.g., O, Si, Ca). Our analysis does not determine the value of [Mg/Fe] corresponding to pure CCSN enrichment, but it should be at least as high as the upper edge of the plateau at \$\textbackslash rm\textbraceleft [Mg/Fe]\textbraceright\textbackslash approx0.35\$, and could be significantly higher. Compared to the two-process predictions, the observed trends of [X/Mg] with \$A\_\textbraceleft\textbackslash text\textbraceleft Ia\textbraceright\textbraceright/A\_\textbraceleft\textbackslash text\textbraceleft cc\textbraceright\textbraceright\$ are steeper for (C+N) but shallower for Ce, providing intriguing but contradictory clues about AGB enrichment in the early disk.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  file = {/Users/daniel/Zotero/storage/GJI6ZLXQ/Sit et al. - 2025 - On the Origin of Abundance Variations in the Milky Way's High-$α$ Plateau.pdf}
}
