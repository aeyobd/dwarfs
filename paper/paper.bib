@article{vanzella+2016,
  title = {High-Resolution Spectroscopy of a Young, Low-Metallicity Optically Thin {{L}} = 0.{{02L}}* Star-Forming Galaxy at z = 3.12},
  author = {Vanzella, E. and De Barros, S. and Cupani, G. and Karman, W. and Gronke, M. and Balestra, I. and Coe, D. and Mignoli, M. and Brusa, M. and Calura, F. and Caminha, G. -B. and Caputi, K. and Castellano, M. and Christensen, L. and Comastri, A. and Cristiani, S. and Dijkstra, M. and Fontana, A. and Giallongo, E. and Giavalisco, M. and Gilli, R. and Grazian, A. and Grillo, C. and Koekemoer, A. and Meneghetti, M. and Nonino, M. and Pentericci, L. and Rosati, P. and Schaerer, D. and Verhamme, A. and Vignali, C. and Zamorani, G.},
  year = 2016,
  month = apr,
  journal = {ApJ},
  volume = {821},
  pages = {L27},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/2041-8205/821/2/L27},
  url = {https://ui.adsabs.harvard.edu/abs/2016ApJ...821L..27V},
  urldate = {2024-10-16},
  abstract = {We present VLT/X-Shooter and MUSE spectroscopy of a faint F814W = 28.60 \textpm{} 0.33 (\textbraceleft M\textbraceright\textbraceleft UV\textbraceright =-17.0), low-mass ({$\lessequivlnt$}\textbraceleft 10\textbraceright 7\textbraceleft M\textbraceright{$\odot$} ), and compact (R eff = 62 pc) freshly star-forming galaxy at z = 3.1169 magnified (16\texttimes ) by the Hubble Frontier Fields galaxy cluster Abell S1063. Gravitational lensing allows for a significant jump toward low-luminosity regimes, in moderately high-resolution spectroscopy (R={$\lambda$} /d{$\lambda$} {$\sim$} 3000\textbraceleft --\textbraceright 7400). We measured C IV {$\lambda$} 1548,1550, He II {$\lambda$} 1640, O III]{$\lambda$} 1661,1666, C III]{$\lambda$} {$\lambda$} 1907,1909, H{$\beta$}, [O III]{$\lambda$} {$\lambda$} 4959,5007 emission lines with \textbraceleft FWHM\textbraceright{$\lessequivlnt$} 50 km s-1 and (de-lensed) fluxes spanning the interval 1.0\texttimes{} \textbraceleft 10\textbraceright -19\textbraceleft --\textbraceright 2\texttimes{} \textbraceleft 10\textbraceright -18 erg s-1 cm-2 at signal-to-noise ratio (S/N) = 4-30. The double-peaked Ly{$\alpha$} emission with \textbraceleft\textbraceleft{$\Delta$} \textbraceright\textbraceright v(\textbraceleft red\textbraceright -\textbraceleft blue\textbraceright )=280(\textpm 7) km s-1 and de-lensed fluxes \textbraceleft 2.4\textbraceright (\textbraceleft blue)\textbraceright\textbar{} \textbraceleft 8.5\textbraceright (\textbraceleft red)\textbraceright\texttimes{} \textbraceleft 10\textbraceright -18 erg s-1 cm-2 (S/N = \textbraceleft 38\textbraceright (\textbraceleft blue)\textbraceright\textbar{} \textbraceleft 110\textbraceright (\textbraceleft red)\textbraceright ) indicate a low column density of neutral hydrogen gas consistent with a highly ionized interstellar medium as also inferred from the large [O III]{$\lambda$} 5007/ [O II]{$\lambda$} 3727 \textbackslash quad 10 ratio. We detect C IV {$\lambda$} 1548,1550 resonant doublet in emission, each component with \textbraceleft FWHM\textbraceright{$\lessequivlnt$} 45 km s-1 and redshifted by +51(\textpm 10) km s-1 relative to the systemic redshift. We interpret this as nebular emission tracing an expanding optically thin interstellar medium. Both C IV {$\lambda$} 1548,1550 and He II {$\lambda$} 1640 suggest the presence of hot and massive stars (with a possible faint active galactic nucleus). The ultraviolet slope is remarkably blue, {$\beta$} =-2.95+/- 0.20 (\textbraceleft F\textbraceright{$\lambda$} =\textbraceleft{$\lambda$} \textbraceright{$\beta$} ), consistent with a dust-free and young {$\lessequivlnt$}20 Myr galaxy. Line ratios suggest an oxygen abundance 12 + log(O/H)\textbackslash quad \textbackslash quad 7.8. We are witnessing an early episode of star formation in which a relatively low N H I and negligible dust attenuation might favor a leakage of ionizing radiation. This galaxy currently represents a unique low-luminosity reference object for future studies of the reionization epoch with the James Webb Space Telescope. Based on observations collected at the European Southern Observatory for Astronomical research in the Southern Hemisphere under ESO programs P095.A-0840, P095.A-0653, P186.A-0798.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,cosmology: observations,galaxies: formation},
  annotation = {ADS Bibcode: 2016ApJ...821L..27V},
  file = {/Users/daniel/Zotero/storage/ERG4GLN7/Vanzella et al. - 2016 - High-resolution Spectroscopy of a Young, Low-metallicity Optically Thin L = 0.02L Star-forming Gala.pdf}
}
