@phdthesis{palma2001,
  title = {Evidence for Tidal Disruption Induced Substructure in the Outer Halo of the Milky Way Galaxy},
  author = {Palma, Christopher},
  year = 2001,
  month = jan,
  pages = {3233},
  url = {https://ui.adsabs.harvard.edu/abs/2001PhDT.........1P},
  urldate = {2025-04-28},
  abstract = {This thesis provides evidence that the outer halo of the Milky Way Galaxy has in the past, and continues presently, to accumulate stars and stellar systems from satellite galaxies. The results of three experiments support this conclusion: We search the distribution of possible orbital poles of all Milky Way satellite galaxies and globular clusters for co-orbiting objects, an expected signature for the products of tidal disruption. The principal results are: (1)It is statistically more likely that outer halo (Rgc {$>$} 8 kpc) ``red horizontal branch'' globular clusters share orbits similar to the dwarf satellite galaxies than do outer halo ``blue horizontal branch/metal-poor'' globular clusters. (2)The most distant, outer halo globular clusters (Rgc {$>$} 25 kpc) Pal 4, NGC 6229, NGC 7006, and Pyxis are most likely to share an orbit with the Galactic satellite galaxies. A more complete, dynamical analysis of those globular clusters and satellite galaxies with known space motions finds little evidence for common orbits among the 41 clusters and any of the 6 satellite galaxies. This is to be expected, however, since the majority of the 41 globular clusters are inner halo (Rgc {$<$} 8 kpc), blue horizontal branch/metal-poor or disk clusters. Motivated by the study above, a first measurement of the radial velocity of the Pyxis globular cluster is presented, and reveals that it can only share the orbital pole of the Magellanic Clouds (an association predicted by the orbital pole analysis) if it is on an eccentric orbit ({$\varepsilon$} {$>$} 0.7). However, the few outer halo clusters with known orbits are found on very eccentric orbits. An analysis of the Ursa Minor dwarf galaxy reveals a large population of stars outside its nominal tidal radius. These stars, if unbound to Ursa Minor, suggest that the galaxy is losing up to a third of its mass per Gyr to the Milky Way, a conclusion that supports the overall premise of this thesis, that the Galaxy is growing from the accretion of satellite galaxies. The morphology of this satellite galaxy is peculiar even within its tidal radius, which further suggests an ongoing interaction with the Milky Way.},
  langid = {english},
  keywords = {GALACTIC HALO,GLOBULAR CLUSTERS: GENERAL,GLOBULAR CLUSTERS: PYXIS,Physics: Astronomy and Astrophysics,to read,URSA MINOR DWARF SPHEROIDAL},
  annotation = {ADS Bibcode: 2001PhDT.........1P}
}
