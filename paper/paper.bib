@article{diteodoro+2019,
  title = {On the Dynamics of the Small Magellanic Cloud through High-Resolution {{ASKAP H I}} Observations},
  author = {Di Teodoro, E. M. and {McClure-Griffiths}, N. M. and Jameson, K. E. and D{\'e}nes, H. and Dickey, John M. and Stanimirovi{\'c}, S. and {Staveley-Smith}, L. and Anderson, C. and Bunton, J. D. and Chippendale, A. and {Lee-Waddell}, K. and MacLeod, A. and Voronkov, M. A.},
  year = 2019,
  month = feb,
  journal = {\mnras},
  volume = {483},
  pages = {392--406},
  issn = {0035-8711},
  doi = {10.1093/mnras/sty3095},
  url = {https://ui.adsabs.harvard.edu/abs/2019MNRAS.483..392D},
  urldate = {2025-09-17},
  abstract = {We use new high-resolution H I data from the Australian Square Kilometre Array Pathfinder to investigate the dynamics of the Small Magellanic Cloud (SMC). We model the H I gas component as a rotating disc of non-negligible angular size, moving into the plane of the sky, and undergoing nutation/precession motions. We derive a high-resolution ({$\sim$}10 pc) rotation curve of the SMC out to R{$\sim$} 4 kpc. After correcting for asymmetric drift, the circular velocity slowly rises to a maximum value of V\_c{$\sim$}eq 55 \textbraceleft km s\textbraceright\textasciicircum\textbraceleft -1\textbraceright{} at R{$\sim$}eq 2.8 kpc and possibly flattens outwards. In spite of the SMC undergoing strong gravitational interactions with its neighbours, its H I rotation curve is akin to that of many isolated gas-rich dwarf galaxies. We decompose the rotation curve and explore different dynamical models to deal with the unknown 3D shape of the mass components (gas, stars, and dark matter). We find that, for reasonable mass-to-light ratios, a dominant dark matter halo with mass M\_DM(R{$<$}4 kpc) {$\sim$}eq 1-1.5 \texttimes{} 10\textasciicircum 9 M\_{$\odot$} is always required to successfully reproduce the observed rotation curve, implying a large baryon fraction of 30 per cent-40 per cent. We discuss the impact of our assumptions and the limitations of deriving the SMC kinematics and dynamics from H I observations.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: dwarf,galaxies: kinematics and dynamics,Magellanic Clouds},
  annotation = {ADS Bibcode: 2019MNRAS.483..392D},
  file = {/Users/daniel/Zotero/storage/UFBYF7TR/Di Teodoro et al. - 2019 - On the dynamics of the small magellanic cloud through high-resolution ASKAP H I observations.pdf}
}
