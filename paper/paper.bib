@article{jimenez+1998,
  title = {Galaxy Formation and Evolution: Low-Surface-Brightness Galaxies},
  shorttitle = {Galaxy Formation and Evolution},
  author = {Jimenez, Raul and Padoan, Paolo and Matteucci, Francesca and Heavens, Alan F.},
  year = 1998,
