@article{white+rees1978,
  title = {Core Condensation in Heavy Halos: A Two-Stage Theory for Galaxy Formation and Clustering},
  shorttitle = {Core Condensation in Heavy Halos},
  author = {White, S. D. M. and Rees, M. J.},
  year = 1978,
