@article{hunter+2024,
  title = {Testing Kinematic Distances under a Realistic Galactic Potential: Investigating Systematic Errors in the Kinematic Distance Method Arising from a Non-Axisymmetric Potential},
  shorttitle = {Testing Kinematic Distances under a Realistic Galactic Potential},
  author = {Hunter, Glen H. and Sormani, Mattia C. and Beckmann, Jan P. and Vasiliev, Eugene and Glover, Simon C. O. and Klessen, Ralf S. and Soler, Juan D. and Brucy, No{\'e} and Girichidis, Philipp and G{\"o}ller, Junia and Ohlin, Loke and Tress, Robin and Molinari, Sergio and Gerhard, Ortwin and Benedettini, Milena and Smith, Rowan and Hennebelle, Patrick and Testi, Leonardo},
  year = 2024,
  month = dec,
  journal = {\aap},
  volume = {692},
