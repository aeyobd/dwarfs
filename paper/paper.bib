@article{NCN2020,
  title = {First Gaia Dynamical Model of the Milky Way Disc with Six Phase Space Coordinates: A Test for Galaxy Dynamics},
  shorttitle = {First Gaia Dynamical Model of the Milky Way Disc with Six Phase Space Coordinates},
  author = {Nitschai, Maria Selina and Cappellari, Michele and Neumayer, Nadine},
  year = 2020,
  month = jun,
  journal = {\mnras},
  volume = {494},
  pages = {6001--6011},
  issn = {0035-8711},
  doi = {10.1093/mnras/staa1128},
  url = {https://ui.adsabs.harvard.edu/abs/2020MNRAS.494.6001N},
  urldate = {2024-04-14},
  abstract = {We construct the first comprehensive dynamical model for the high-quality subset of stellar kinematics of the Milky Way disc, with full 6D phase-space coordinates, provided by the Gaia Data Release 2. We adopt an axisymmetric approximation and use an updated Jeans Anisotropic Modelling (JAM) method, which allows for a generic shape and radial orientation of the velocity ellipsoid, as indicated by the Gaia data, to fit the mean velocities and all three components of the intrinsic velocity dispersion tensor. The Milky Way is the first galaxy for which all intrinsic phase space coordinates are available, and the kinematics are superior to the best integral-field kinematics of external galaxies. This situation removes the long-standing dynamical degeneracies and makes this the first dynamical model highly overconstrained by the kinematics. For these reasons, our ability to fit the data provides a fundamental test for both galaxy dynamics and the mass distribution in the Milky Way disc. We tightly constrain the volume average total density logarithmic slope, in the radial range 3.6-12 kpc, to be {$\alpha$}tot = -2.149 \textpm{} 0.055 and find that the dark halo slope must be significantly steeper than {$\alpha$}DM = -1 (NFW). The dark halo shape is close to spherical and its density is {$\rho$}DM(R{$\odot$}) = 0.0115 \textpm{} 0.0020 M{$\odot$} pc-3 (0.437 \textpm{} 0.076 GeV cm-3), in agreement with previous estimates. The circular velocity at the solar position Vcirc(R{$\odot$}) = 236.5 \textpm{} 3.1 km s-1 (including systematics) and its gently declining radial trends are also consistent with recent determinations.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Galaxy: disc,Galaxy: kinematics and dynamics,Milky Way,solar neighbourhood},
  annotation = {ADS Bibcode: 2020MNRAS.494.6001N},
  file = {/Users/daniel/Zotero/storage/RPPTPN7I/Nitschai et al. - 2020 - First Gaia dynamical model of the Milky Way disc with six phase space coordinates a test for galaxy.pdf;/Users/daniel/Zotero/storage/TW7ANFM9/Nitschai et al. - 2020 - First Gaia dynamical model of the Milky Way disc w.pdf}
}
