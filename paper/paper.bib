@article{sun+2023,
  title = {Classifying Globular Clusters and Applying Them to Estimate the Mass of the Milky Way},
  author = {Sun, GuangChen and Wang, Yougang and Liu, Chao and Long, Richard J. and Chen, Xuelei and Gao, Qi},
  year = 2023,
  month = jan,
  journal = {Res. Astron. Astrophys.},
