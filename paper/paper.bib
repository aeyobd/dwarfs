@article{herwig+austin2004,
  title = {Nuclear Reaction Rates and Carbon Star Formation},
  author = {Herwig, Falk and Austin, Sam M.},
  year = 2004,
  month = sep,
  journal = {ApJ},
  volume = {613},
  pages = {L73-L76},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/424872},
  url = {https://ui.adsabs.harvard.edu/abs/2004ApJ...613L..73H},
  urldate = {2024-05-10},
  abstract = {We have studied how the third dredge-up and the carbon star formation in low-mass asymptotic giant branch stars depend on certain key nuclear reaction rates. From a set of complete stellar evolution calculations of a 2 Msolar model with Z=0.01 including mass loss, we find that varying either the 14N(p, {$\gamma$})15O or the triple-{$\alpha$} reaction rate within their uncertainties as given in the NACRE compilation results in dredge-up and yields that differ by a factor of 2. Model tracks with a higher rate for the triple-{$\alpha$} rate and a lower rate for the 14N(p, {$\gamma$})15O reaction both show more efficient third dredge-up. New experimental results for the 14N(p, {$\gamma$})15O reaction rates are surveyed, yielding a rate that is about 40\% lower than the tabulated NACRE rate and smaller than NACRE's lower limit. We discuss the possible implications of the revised nuclear reaction rate for stellar evolution calculations that aim to reproduce the observed carbon star formation at low mass, which requires efficient third dredge-up.},
  langid = {english},
  keywords = {Abundances,Astrophysics,Nuclear Reactions,Nucleosynthesis,Stars: Abundances,Stars: AGB and Post-AGB,Stars: Carbon},
  annotation = {ADS Bibcode: 2004ApJ...613L..73H},
  file = {/Users/daniel/Zotero/storage/8PJR3CXC/Herwig and Austin - 2004 - Nuclear Reaction Rates and Carbon Star Formation.pdf}
}
