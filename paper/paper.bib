@article{tau+vivas+martinez-vazquez2024,
  title = {Extended Stellar Populations in Ultrafaint Dwarf Galaxies},
  author = {Tau, Elisa A. and Vivas, A. Katherina and {Mart{\'i}nez-V{\'a}zquez}, Clara E.},
  year = 2024,
