@article{webbink1979,
  title = {The {{Formation}} of {{White Dwarfs}} in {{Close Binary Systems}}},
  author = {Webbink, Ronald F.},
  year = 1979,
  month = aug,
  journal = {International Astronomical Union Colloquium},
  volume = {53},
  pages = {426--447},
  publisher = {Cambridge University Press},
  issn = {0252-9211},
  doi = {10.1017/S0252921100076338},
  url = {https://www.cambridge.org/core/journals/international-astronomical-union-colloquium/article/formation-of-white-dwarfs-in-close-binary-systems/00B2A53C0E9E601D9893C776CC9FFA57},
  urldate = {2023-11-18},
  abstract = {Three major modes of interaction in binary systems are identified, corresponding to (I) physical contact, (II) tidal mass loss from a star with a radiative envelope, and (III) tidal mass loss from a star with a convectlve envelope. The qualitative evolution of binary systems in each of these cases is outlined, leading to the formation of single white dwarfs, long-period remnants of quasi-conservative mass transfer, or short-period cataclysmic binaries. The origin of short-period double white dwarfs in a second phase of mass transfer is outlined. Implications for the frequency of different systems of these types, and of planetary nebulae with close binary nuclei, are discussed.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/5ELZ762Q/Webbink - 1979 - The Formation of White Dwarfs in Close Binary Syst.pdf;/Users/daniel/Zotero/storage/KQWB4C7H/Webbink - 1979 - The Formation of White Dwarfs in Close Binary Syst.pdf}
}
