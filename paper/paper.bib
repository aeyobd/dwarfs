@article{escorza+rosa2020,
  title = {Learning about {{AGB}} Stars by Studying the Stars Polluted by Their Outflows},
  author = {Escorza, Ana and Rosa, Robert J. De},
  year = 2020,
  month = nov,
  journal = {Proceedings of the International Astronomical Union},
  volume = {16},
  number = {S366},
  pages = {253--258},
  publisher = {Cambridge University Press},
  issn = {1743-9213, 1743-9221},
