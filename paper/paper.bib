@article{martinez-delgado+2001,
  title = {A Tidal Extension in the Ursa Minor Dwarf Spheroidal Galaxy},
  author = {{Mart{\'i}nez-Delgado}, D. and {Alonso-Garc{\'i}a}, J. and Aparicio, A. and {G{\'o}mez-Flechoso}, M. A.},
  year = 2001,
