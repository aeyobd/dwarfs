@article{vandenbosch+2018,
  title = {Disruption of Dark Matter Substructure: Fact or Fiction?},
  shorttitle = {Disruption of Dark Matter Substructure},
  author = {{van den Bosch}, Frank C. and Ogiya, Go and Hahn, Oliver and Burkert, Andreas},
  year = 2018,
  month = mar,
  journal = {\mnras},
  volume = {474},
  pages = {3043--3066},
  issn = {0035-8711},
  doi = {10.1093/mnras/stx2956},
  url = {https://ui.adsabs.harvard.edu/abs/2018MNRAS.474.3043V},
  urldate = {2025-09-01},
  abstract = {Accurately predicting the demographics of dark matter (DM) substructure is of paramount importance for many fields of astrophysics, including gravitational lensing, galaxy evolution, halo occupation modelling, and constraining the nature of DM. Because of its strongly non-linear nature, DM substructure is typically modelled using N-body simulations, which reveal that large fractions of DM subhaloes undergo complete disruption. In this paper, we use both analytical estimates and idealized numerical simulations to investigate whether this disruption is mainly physical, due to tidal heating and stripping, or numerical (i.e. artificial). We show that, contrary to naive expectation, subhaloes that experience a tidal shock {$\Delta$}E that exceeds the subhalo's binding energy, \textbar Eb\textbar, do not undergo disruption, even when {$\Delta$}E/\textbar Eb\textbar{} is as large as 100. Along the same line, and contrary to existing claims in the literature, instantaneously stripping matter from the outskirts of a DM subhalo also does not result in its complete disruption, even when the instantaneous remnant has positive binding energy. In addition, we show that tidal heating due to high-speed (impulsive) encounters with other subhaloes (`harassment') is negligible compared to the tidal effects due to the host halo. Hence, we conclude that, in the absence of baryonic processes, the complete physical disruption of CDM substructure is extremely rare and that most disruption in numerical simulations therefore must be artificial. We discuss various processes that have been associated with numerical overmerging and conclude that inadequate force softening is the most likely culprit.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,dark matter,dynamics theory,galaxies: haloes,gravitation,idealized simulations,methods: analytical,methods: numerical,to read},
  annotation = {ADS Bibcode: 2018MNRAS.474.3043V},
  file = {/Users/daniel/Zotero/storage/H5H2MXPM/van den Bosch et al. - 2018 - Disruption of dark matter substructure fact or fiction.pdf}
}
