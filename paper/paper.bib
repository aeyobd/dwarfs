@article{zhao+2016,
  title = {Systematic Non-{{LTE}} Study of the -.6 {$\leq$} [{{Fe}}/{{H}}] {$\leq$} 0.2 {{F}} and {{G}} Dwarfs in the Solar Neighborhood. {{II}}. {{Abundance}} Patterns from {{Li}} to {{Eu}}},
