@article{tran+2022,
  title = {Distances to Local Group Galaxies via Population {{II}}, Stellar Distance Indicators. {{I}}. {{The}} Sculptor Dwarf Spheroidal},
  author = {Tran, Quang H. and Hoyt, Taylor J. and Freedman, Wendy L. and Madore, Barry F. and Oakes, Elias K. and Cerny, William and Hatt, Dylan and Beaton, Rachael L.},
