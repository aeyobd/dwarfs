@article{baumgardt+2003,
  title = {On the {{Central Structure}} of {{M15}}},
  author = {Baumgardt, Holger and Hut, Piet and Makino, Junichiro and McMillan, Steve and Portegies Zwart, Simon},
  year = 2003,
  month = jan,
  journal = {The Astrophysical Journal},
  volume = {582},
