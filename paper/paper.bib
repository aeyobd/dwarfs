@article{dutton+maccio2014,
  title = {Cold Dark Matter Haloes in the Planck Era: Evolution of Structural Parameters for Einasto and {{NFW}} Profiles},
  shorttitle = {Cold Dark Matter Haloes in the Planck Era},
  author = {Dutton, Aaron A. and Macci{\`o}, Andrea V.},
