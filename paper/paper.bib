@article{aaronson+olszewski+hodge1983,
  title = {Carbon Stars and the Seven Dwarfs},
  author = {Aaronson, M. and Olszewski, E. W. and Hodge, P. W.},
  year = 1983,
  month = apr,
  journal = {\apj},
  volume = {267},
  pages = {271--279},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/160865},
  url = {https://ui.adsabs.harvard.edu/abs/1983ApJ...267..271A},
  urldate = {2025-04-28},
  abstract = {The discovery of carbon stars in the Leo I, Leo II, and Ursa Minor dwarf spheroidal galaxies is reported. The C2 and CN band strengths are found to be well correlated with each other, although there is a wide range in band strength at fixed color. The number of carbon stars is shown not to be a simple function of parent galaxy luminosity nor of metallicity. Only one carbon star is detected in Leo I. The newly discovered Ursa Minor C star lies well below the giant branch tip in the color-magnitude diagram, and it is suggested that the location of this star may support the argument that more than one process is required to make dwarf spheroidal carbon stars. It is concluded that mechanisms for producing carbon stars are favored in dwarf spheroidal galaxies, as opposed to globular clusters in our Galaxy, although the nature and number of the physical mechanisms required to account for the large range observed in C star luminosity and spectral appearance are still unresolved.},
  langid = {english},
  keywords = {Astrophysics,Carbon Stars,Color-Magnitude Diagram,Dwarf Galaxies,Giant Stars,Milky Way Galaxy,Radial Velocity,Stellar Color,Stellar Evolution,Stellar Luminosity,Stellar Magnitude,Stellar Spectra,Stellar Spectrophotometry},
  annotation = {ADS Bibcode: 1983ApJ...267..271A},
  file = {/Users/daniel/Zotero/storage/5EQIDGUQ/Aaronson et al. - 1983 - Carbon stars and the seven dwarfs..pdf}
}
