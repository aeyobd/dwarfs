@article{pace+2014,
  title = {Evidence for Substructure in Ursa Minor Dwarf Spheroidal Galaxy Using a Bayesian Object Detection Method},
  author = {Pace, Andrew B. and Martinez, Gregory D. and Kaplinghat, Manoj and Mu{\~n}oz, Ricardo R.},
  year = 2014,
  month = aug,
  journal = {\mnras},
  volume = {442},
  pages = {1718--1730},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stu938},
  url = {https://ui.adsabs.harvard.edu/abs/2014MNRAS.442.1718P},
  urldate = {2024-11-27},
  abstract = {We present a method for identifying localized secondary populations in stellar velocity data using Bayesian statistical techniques. We apply this method to the dwarf spheroidal galaxy Ursa Minor and find two secondary objects in this satellite of the Milky Way. One object is kinematically cold with a velocity dispersion of 4.25 \textpm{} 0.75 km s-1 and centred at (9.1 arcmin \textpm{} 1.5, 7.2 arcmin \textpm{} 1.2) in relative RA and Dec. with respect to the centre of Ursa Minor. The second object has a large velocity offset of -12.8\textasciicircum\textbraceleft +1.75\textbraceright\_\textbraceleft -1.5\textbraceright{} \textbraceleft km s\textasciicircum\textbraceleft -1\textbraceright\textbraceright{} compared to Ursa Minor and centred at (-14.0 arcmin\textasciicircum\textbraceleft +2.4\textbraceright\_\textbraceleft -5.8\textbraceright, -2.5 arcmin\textasciicircum\textbraceleft +0.4\textbraceright\_\textbraceleft -1.0\textbraceright ). The kinematically cold object has been found before using a smaller data set, but the prediction that this cold object has a velocity dispersion larger than 2.0 km s-1 at 95 per cent confidence level differs from previous work. We use two- and three-component models along with the information criteria and Bayesian evidence model selection methods to argue that Ursa Minor has additional localized secondary populations. The significant probability for a large velocity dispersion in each secondary object raises the intriguing possibility that each has its own dark matter halo, that is, it is a satellite of a satellite of the Milky Way.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,galaxies: kinematics and dynamics,Local Group,methods: statistical,Ursa Minor},
  annotation = {ADS Bibcode: 2014MNRAS.442.1718P},
  file = {/Users/daniel/Zotero/storage/BA82J7RG/Pace et al. - 2014 - Evidence for substructure in Ursa Minor dwarf spheroidal galaxy using a Bayesian object detection me.pdf}
}
