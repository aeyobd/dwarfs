@article{bruenn+2023,
  title = {Comparison of the Core-Collapse Evolution of Two Nearly Equal-Mass Progenitors},
  author = {Bruenn, Stephen W. and Sieverding, Andre and Lentz, Eric J. and Sukhbold, Tuguldur and Hix, W. Raphael and Huk, Leah N. and Harris, J. Austin and Messer, O. E. Bronson and Mezzacappa, Anthony},
  year = 2023,
  month = apr,
  journal = {ApJ},
  volume = {947},
  pages = {35},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/acbb65},
  url = {https://ui.adsabs.harvard.edu/abs/2023ApJ...947...35B},
  urldate = {2024-04-22},
  abstract = {We compare the core-collapse evolution of a pair of 15.8 M {$\Sun$} stars with significantly different internal structures, a consequence of the bimodal variability exhibited by massive stars during their late evolutionary stages. The 15.78 and 15.79 M {$\Sun$} progenitors have core masses (masses interior to an entropy of 4 k B baryon-1) of 1.47 and 1.78 M {$\Sun$} and compactness parameters {$\xi$} 1.75 of 0.302 and 0.604, respectively. The core-collapse simulations are carried out in 2D to nearly 3 s postbounce and show substantial differences in the times of shock revival and explosion energies. The 15.78 M {$\Sun$} model begins exploding promptly at 120 ms postbounce when a strong density decrement at the Si-Si/O shell interface, not present in the 15.79 M {$\Sun$} progenitor, encounters the stalled shock. The 15.79 M {$\Sun$} model takes 100 ms longer to explode but ultimately produces a more powerful explosion. Both the larger mass accretion rate and the more massive core of the 15.79 M {$\Sun$} model during the first 0.8 s postbounce time result in larger {$\nu$} e / \$\textbraceleft\textbackslash bar\textbraceleft\textbackslash nu \textbraceright\textbraceright\_\textbraceleft e\textbraceright\$ luminosities and RMS energies along with a flatter and higher-density heating region. The more-energetic explosion of the 15.79 M {$\Sun$} model resulted in the ejection of twice as much 56Ni. Most of the ejecta in both models are moderately proton rich, though counterintuitively the highest electron fraction (Y e = 0.61) ejecta in either model are in the less-energetic 15.78 M {$\Sun$} model, while the lowest electron fraction (Y e = 0.45) ejecta in either model are in the 15.79 M {$\Sun$} model.},
  langid = {english},
  keywords = {304,503,767,Astrophysics - Solar and Stellar Astrophysics,Core-collapse supernovae,Explosive nucleosynthesis,Hydrodynamical simulations},
  annotation = {ADS Bibcode: 2023ApJ...947...35B},
  file = {/Users/daniel/Zotero/storage/WWS76QBE/Bruenn et al. - 2023 - Comparison of the Core-collapse Evolution of Two N.pdf}
}
