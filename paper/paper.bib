  author = {Esteban, C{\'e}sar and {Garc{\'i}a-Rojas}, Jorge and Peimbert, Manuel and Peimbert, Antonio and Ruiz, Mar{\'i}a Teresa and Rodr{\'i}guez, M{\'o}nica and Carigi, Leticia},
  year = 2005,
