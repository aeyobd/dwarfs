  author = {Wilson, Robert F. and Ca{\~n}as, Caleb I. and Majewski, Steven R. and Cunha, Katia and Smith, Verne V. and Bender, Chad F. and Mahadevan, Suvrath and Fleming, Scott W. and Teske, Johanna and Ghezzi, Luan and J{\"o}nsson, Henrik and Beaton, Rachael L. and Hasselquist, Sten and Stassun, Keivan and Nitschelm, Christian and {Garc{\'i}a-Hern{\'a}ndez}, D. A. and Hayes, Christian R. and Tayar, Jamie},
