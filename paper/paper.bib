@article{choi+weinberg+katz2009,
  title = {The Dynamics of Satellite Disruption in Cold Dark Matter Haloes},
  author = {Choi, Jun-Hwan and Weinberg, Martin D. and Katz, Neal},
  year = 2009,
  month = dec,
  journal = {\mnras},
  volume = {400},
  pages = {1247--1263},
  issn = {0035-8711},
  doi = {10.1111/j.1365-2966.2009.15556.x},
  url = {https://ui.adsabs.harvard.edu/abs/2009MNRAS.400.1247C},
  urldate = {2025-09-01},
  abstract = {We investigate the physical mechanisms of tidal heating and satellite disruption in cold dark matter host haloes using N-body simulations based on cosmological initial conditions. We show the importance of resonant shocks and resonant torques with the host halo to satellite heating. A resonant shock (torque) couples the radial (tangential) motion of a satellite in its orbit to its phase space. For a satellite on a circular orbit, an inner Lindblad resonance (ILR)-like resonance dominates the heating and this heating results in continuous satellite mass loss. We estimate the requirements for simulations to achieve these dynamics using perturbation theory. Both resonant shocks and resonant torques affect satellites on eccentric orbits. We demonstrate that satellite mass loss is an outside-in process in energy space; a satellite's stars and gas are thus protected by their own halo against tidal stripping. We simulate the evolution of a halo similar to the Large Magellanic Cloud (LMC) in our Galactic dark matter halo and conclude that the LMC stars have not yet been stripped. Finally, we present a simple algorithm for estimating the evolution of satellite mass that includes both shock heating and resonant torques.},
  langid = {english},
  keywords = {Astrophysics,dynamics theory,galaxies: evolution,galaxies: haloes,galaxies: interaction,galaxies: kinematics and dynamics,idealized simulations,methods: N-body simulation,methods: numerical},
  annotation = {ADS Bibcode: 2009MNRAS.400.1247C},
  file = {/Users/daniel/Zotero/storage/XHUNXRHV/Choi et al. - 2009 - The dynamics of satellite disruption in cold dark matter haloes.pdf}
}
