@article{duttachowdhury+2023,
  title = {On the Dynamical Heating of Dwarf Galaxies in a Fuzzy Dark Matter Halo},
  author = {Dutta Chowdhury, Dhruba and {van den Bosch}, Frank C. and {van Dokkum}, Pieter and Robles, Victor H. and Schive, Hsi-Yu and Chiueh, Tzihong},
  year = 2023,
  month = jun,
  journal = {\apj},
  volume = {949},
