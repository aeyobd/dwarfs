@article{deng+2025,
  title = {{{RIGEL}}: {{Feedback-regulated}} Cloud-Scale Star Formation Efficiency in a Simulated Dwarf Galaxy Merger},
  shorttitle = {{{RIGEL}}},
  author = {Deng, Yunwei and Li, Hui and Marinacci, Federico and Ni, Yang and Liu, Boyuan and Smith, Aaron and Kannan, Rahul and Bryan, Greg L.},
  year = 2025,
  month = dec,
  journal = {A\&A},
  volume = {704},
  eprint = {2510.07368},
  primaryclass = {astro-ph},
  pages = {A240},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/202556854},
  url = {http://arxiv.org/abs/2510.07368},
  urldate = {2026-03-20},
  abstract = {Major mergers of galaxies are likely to trigger bursty star formation activities. The accumulation of dense gas and the boost of star formation efficiency (SFE) are considered to be the two main drivers of starbursts. However, it remains unclear how each process operates on the scale of individual star-forming clouds. Here, we present a high-resolution (2 Msun) RHD simulation of a gas-rich dwarf galaxy merger using the RIGEL model to investigate how mergers affect the properties of the structure of dense star-forming gas and the cloud-scale SFE. We tracked the evolution of sub-virial dense clouds in the simulation by mapping them across successive snapshots taken at intervals of 0.2 Myr. We find that the merger triggers a 130 fold increase in the SFR and shortens the galaxy-wide gas-depletion time by two orders of magnitude compared to those in two isolated galaxies. However, the depletion time of individual clouds and their lifetime distribution remained unchanged over the simulation period. The cloud life cycles and cloud-scale SFE are determined by the local stellar feedback rather than such environmental factors as tidal fields regardless of the merger process, and the integrated SFE (\${$\varepsilon\_$}\textbraceleft\textbackslash rm int\textbraceright\$) of clouds in complex environments remains well-described by an \${$\varepsilon\_$}\textbraceleft\textbackslash rm int\textbraceright -{$\Sigma\_$}\textbraceleft\textbackslash rm tot\textbraceright\$ relation found in idealized isolated-cloud experiments. During the peak of the starburst, the media SFE was lower by only 0.17-0.33 dex compared to the value when the galaxies were not interacting. The merger boosts the SFR through the accumulation and compression of dense gas fueling star formation. Strong tidal torques assemble \${$>$}10\textasciicircum 5\$ Msun clouds, which seed massive star clusters. The average separation between star-forming clouds decreases during the merger, which in turn decreases the cloud--cluster spatial de-correlation from {$>$}1 kpc to 0.1 kpc depicted in tuning fork diagrams.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/NC5CA5JC/Deng et al. - 2025 - RIGEL Feedback-regulated cloud-scale star formation efficiency in a simulated dwarf galaxy merger.pdf}
}
