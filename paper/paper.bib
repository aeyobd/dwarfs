@misc{brooks+2025a,
  title = {The {{Milky Way}} - {{Large Magellanic Cloud Interaction}} with {{Simulation Based Inference}}},
  author = {Brooks, Richard A. N. and Sanders, Jason L. and Chandra, Vedant and {Garavito-Camargo}, Nicol{\'a}s and Dillamore, Adam M. and {Price-Whelan}, Adrian M. and Ting, Yuan-Sen},
  year = 2025,
  month = oct,
  number = {arXiv:2510.04735},
  eprint = {2510.04735},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2510.04735},
  url = {http://arxiv.org/abs/2510.04735},
  urldate = {2026-03-20},
  abstract = {The infall of the Large Magellanic Cloud (LMC) into the Milky Way (MW) has displaced the MW's centre of mass, manifesting as an observed reflex motion in the velocities of outer halo stars. We use a Simulation Based Inference framework to constrain properties of the MW, LMC and the induced reflex motion using the dynamics of outer MW halo stars. Specifically, we use the mean radial and tangential velocities of outer halo stars calculated in a set of distance and on-sky bins. We train neural networks to estimate parameter posterior distributions using a set of \$128,000\$ rigid MW--LMC simulations conditioned upon velocity data from the Dark Energy Spectroscopic Instrument (DESI) and the combined H3+SEGUE+MagE outer halo surveys. We constrain the reflex motion velocity and the enclosed MW and LMC masses within \$50 \textbackslash, \textbackslash rm kpc\$ using the DESI or H3+SEGUE+MagE dataset while varying the survey sky coverage and depth. We find the most precise constraints by using the radial and tangential velocity data from the H3+SEGUE+MagE survey and on-sky quadrant sky coverages. We report a reflex motion velocity, the speed at which the MW lurches towards the LMC, of \$v\_\textbraceleft\textbackslash rm\textbraceleft travel\textbraceright\textbraceright{} = 26.4\textasciicircum\textbraceleft +5.5\textbraceright\_\textbraceleft -4.4\textbraceright{} \textbackslash, \textbackslash rm km \textbackslash, \textbackslash rm s\textasciicircum\textbraceleft -1\textbraceright\$, while simultaneously finding an enclosed LMC mass of \$M\_\textbraceleft\textbackslash rm LMC\textbraceright ({$<$} 50 \textbackslash, \textbackslash rm kpc) = 9.2\textasciicircum\textbraceleft +1.9\textbraceright\_\textbraceleft -2.3\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 10\textbraceright\textbackslash, \textbackslash rm M\_\textbraceleft\textbackslash odot\textbraceright\$ and enclosed MW mass of \$M\_\textbraceleft\textbackslash rm MW\textbraceright ({$<$} 50 \textbackslash, \textbackslash rm kpc) = 4.4\textasciicircum\textbraceleft +0.7\textbraceright\_\textbraceleft -0.7\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 11\textbraceright\textbackslash, \textbackslash rm M\_\textbraceleft\textbackslash odot\textbraceright\$. Our results suggest that the LMC's total mass is at least \$\textbackslash approx 10-15 \textbackslash\%\$ of that of the MW. This inference framework is flexible such that it can provide rapid and reliable constraints when applied to any future survey measuring the velocities of outer halo stars.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/EQUGGX7L/Brooks et al. - 2025 - The Milky Way - Large Magellanic Cloud Interaction with Simulation Based Inference.pdf}
}
