@article{lee+2018,
  title = {Difference in Dwarf Galaxy Surface Brightness Profiles as a Function of Environment},
  author = {Lee, Youngdae and Park, Hong Soo and Kim, Sang Chul and Moon, Dae-Sik and Lee, Jae-Joon and Kim, Dong-Jin and Cha, Sang-Mok},
  year = 2018,
  month = may,
  journal = {\apj},
