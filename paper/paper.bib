@article{walker+2009a,
  title = {A Universal Mass Profile for Dwarf Spheroidal Galaxies?},
  author = {Walker, Matthew G. and Mateo, Mario and Olszewski, Edward W. and Pe{\~n}arrubia, Jorge and Evans, N. Wyn and Gilmore, Gerard},
  year = 2009,
  month = oct,
  journal = {\apj},
  volume = {704},
  pages = {1274--1287},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/704/2/1274},
  url = {https://ui.adsabs.harvard.edu/abs/2009ApJ...704.1274W},
  urldate = {2025-07-09},
  abstract = {We apply the Jeans equation to estimate masses for eight of the brightest dwarf spheroidal (dSph) galaxies. For Fornax, the dSph with the largest kinematic data set, we obtain a model-independent constraint on the maximum circular velocity, V max = 20+4 -3 km s-1. Although we obtain only lower limits of V max {$>$}\textasciitilde{} 10 km s-1 for the remaining dSphs, we find that in all cases the enclosed mass at the projected half-light radius is well constrained and robust to a wide range of halo models and velocity anisotropies. We derive a simple analytic formula that estimates M(r half) accurately with respect to results from the full Jeans analysis. Applying this formula to the entire population of Local Group dSphs with published kinematic data, we demonstrate a correlation such that M(r half) vprop r 1.4\textpm 0.4 half, or in terms of the mean density interior to the half-light radius, lang{$\rho$}rang vprop r -1.6\textpm 0.4 half. This relation is driven by the fact that the dSph data exhibit a correlation between global velocity dispersion and half-light radius. We argue that tidal forces are unlikely to have introduced this relation, but tides may have increased the scatter and/or altered the slope. While the data are well described by mass profiles ranging over a factor of lsim2 in normalization (V max \textasciitilde{} 10-20 km s-1), we consider the hypothesis that all dSphs are embedded within a "universal" dark matter halo. We show that in addition to the power law M vprop r 1.4, viable candidates include a cuspy "Navarro-Frenk-White" halo with V max \textasciitilde{} 15 km s-1 and scale radius r 0 \textasciitilde{} 800 pc, as well as a cored halo with V max \textasciitilde{} 13 km s-1 and r 0 \textasciitilde{} 150 pc. Finally, assuming that their measured velocity dispersions accurately reflect their masses, the smallest dSphs now allow us to resolve dSph densities at radii as small as a few tens of pc. At these small scales, we find mean densities as large as lang{$\rho$}rang {$<$}\textasciitilde{} 5 M sun pc-3 (lsim200 GeV cm-3). This paper presents data gathered with the Magellan Telescopes at Las Campanas Observatory, Chile, and the MMT Observatory at Mt. Hopkins, AZ, USA.},
  langid = {english},
  keywords = {Astrophysics - Cosmology and Extragalactic Astrophysics,Astrophysics - Galaxy Astrophysics,dynamics theory,galaxies: dwarf,galaxies: kinematics and dynamics,Local Group,to read},
  annotation = {ADS Bibcode: 2009ApJ...704.1274W},
  file = {/Users/daniel/Zotero/storage/MC2CJA7R/Walker et al. - 2009 - A Universal Mass Profile for Dwarf Spheroidal Galaxies.pdf}
}
