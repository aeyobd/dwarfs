@article{mcdonald2015,
  title = {Mass-Loss on the Red Giant Branch: The Value and Metallicity Dependence of {{Reimers}}' {$\eta$} in Globular Clusters},
  shorttitle = {Mass-Loss on the Red Giant Branch},
  author = {McDonald, I. and Zijlstra, A. A.},
  year = 2015,
  month = mar,
  journal = {Monthly Notices of the Royal Astronomical Society},
  volume = {448},
  number = {1},
  pages = {502--521},
  issn = {0035-8711},
  doi = {10.1093/mnras/stv007},
  url = {https://doi.org/10.1093/mnras/stv007},
  urldate = {2023-11-22},
  abstract = {The impact of metallicity on the mass-loss rate from red giant branch (RGB) stars is studied through its effect on the parameters of horizontal branch (HB) stars. The scaling factors from Reimers and Schr\"oder and Cuntz are used to measure the efficiency of RGB mass-loss for typical stars in 56 well-studied Galactic globular clusters (GCs). The median values among clusters are, respectively, \$\textbackslash eta \_\textbraceleft\textbackslash rm R\textbraceright{} = 0.477 \textbackslash pm 0.070 \textasciicircum\textbraceleft +0.050\textbraceright\_\textbraceleft -0.062\textbraceright\$ and \$\textbackslash eta \_\textbraceleft\textbackslash rm SC\textbraceright{} = 0.172 \textbackslash pm 0.024 \textasciicircum\textbraceleft +0.018\textbraceright\_\textbraceleft -0.023\textbraceright\$ (standard deviation and systematic uncertainties, respectively). Over a factor of 200 in iron abundance, {$\eta$} varies by {$\lessequivlnt$}30~per cent, thus mass-loss mechanisms on the RGB have very little metallicity dependence. Any remaining dependence is within the current systematic uncertainties on cluster ages and evolution models. The low standard deviation of {$\eta$} among clusters ({$\approx$}14~per cent) contrasts with the variety of HB morphologies. Since {$\eta$} incorporates cluster age, this suggests that age accounts for the majority of the `second parameter problem', and that a Reimers-like law provides a good mass-loss model. The remaining spread in {$\eta$} correlates with cluster mass and density, suggesting helium enrichment provides the third parameter explaining HB morphology of GCs. We close by discussing asymptotic giant branch (AGB) mass-loss, finding that the AGB tip luminosity is better reproduced and {$\eta$} has less metallicity dependence if GCs are more co-eval than generally thought.},
  file = {/Users/daniel/Zotero/storage/SLZH2BME/McDonald and Zijlstra - 2015 - Mass-loss on the red giant branch the value and m.pdf;/Users/daniel/Zotero/storage/DE85ZX9Q/1751090.html}
}
