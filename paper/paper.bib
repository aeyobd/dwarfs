@article{karczmarek+2015,
  title = {The Araucaria Project: The Distance to the Carina Dwarf Galaxy from Infrared Photometry of {{RR}} Lyrae Stars},
  shorttitle = {The Araucaria Project},
  author = {Karczmarek, Paulina and Pietrzy{\'n}ski, Grzegorz and Gieren, Wolfgang and Suchomska, Ksenia and Konorski, Piotr and G{\'o}rski, Marek and Pilecki, Bogumi{\l} and Graczyk, Dariusz and Wielg{\'o}rski, Piotr},
  year = 2015,
  month = sep,
  journal = {\aj},
  volume = {150},
  pages = {90},
  publisher = {IOP},
  issn = {0004-6256},
  doi = {10.1088/0004-6256/150/3/90},
  url = {https://ui.adsabs.harvard.edu/abs/2015AJ....150...90K},
  urldate = {2026-03-24},
  abstract = {We obtained single-phase near-infrared (NIR) magnitudes in the J- and K-band for a sample of 33 RR Lyrae (RRL) stars in the Carina dSph galaxy. Applying different theoretical and empirical calibrations of the NIR period-luminosity-metallicity relation for RRL stars, we find consistent results and obtain a true, reddening-corrected distance modulus of 20.118 \textpm{} 0.017 (statistical) \textpm{} 0.11 (systematic) mag. This value is in excellent agreement with the results obtained in the context of the Araucaria Project from NIR photometry of red clump stars (20.165 \textpm{} 0.015) and the tip of red giant branch (20.09 \textpm{} 0.03 \textpm{} 0.12 mag in the J band, 20.14 \textpm{} 0.04 \textpm{} 0.14 mag in the K band), as well as with most independent distance determinations to this galaxy. The NIR RRL method proved to be a reliable tool for accurate distance determination at the 5\% level or better, particularly for galaxies and globular clusters that lack young standard candles, like Cepheids. Based on data collected with the VLT/HAWK-I instrument at ESO Paranal Observatory, Chile, as a part of a program 082.D-0123(B).},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,Astrophysics - Solar and Stellar Astrophysics,distance scale,galaxies: distances and redshifts,galaxies: individual: Carina,infrared: stars,stars: individual: RR Lyrae},
  annotation = {ADS Bibcode: 2015AJ....150...90K},
  file = {/Users/daniel/Zotero/storage/TNQNQV6J/Karczmarek et al. - 2015 - The araucaria project the distance to the carina dwarf galaxy from infrared photometry of RR lyrae.pdf}
}
