@article{jenkins+2001,
  title = {The Mass Function of Dark Matter Haloes},
  author = {Jenkins, A. and Frenk, C. S. and White, S. D. M. and Colberg, J. M. and Cole, S. and Evrard, A. E. and Couchman, H. M. P. and Yoshida, N.},
  year = 2001,
