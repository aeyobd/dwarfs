@article{cooke+2014,
  title = {Precision Measures of the Primordial Abundance of Deuterium},
  author = {Cooke, Ryan J. and Pettini, Max and Jorgenson, Regina A. and Murphy, Michael T. and Steidel, Charles C.},
  year = 2014,
  month = jan,
