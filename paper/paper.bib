@article{breddels+2013,
  title = {Orbit-Based Dynamical Models of the Sculptor {{dSph}} Galaxy},
  author = {Breddels, Maarten A. and Helmi, A. and {van den Bosch}, R. C. E. and {van de Ven}, G. and Battaglia, G.},
  year = 2013,
  month = aug,
  journal = {\mnras},
  volume = {433},
  pages = {3173--3189},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stt956},
  url = {https://ui.adsabs.harvard.edu/abs/2013MNRAS.433.3173B},
  urldate = {2025-04-01},
  abstract = {We have developed spherically symmetric dynamical models of dwarf spheroidal (dSph) galaxies using Schwarzschild's orbit superposition method. This type of modelling yields constraints both on the total mass distribution (e.g. enclosed mass and scale radius) and on the orbital structure of the system (e.g. velocity anisotropy). This method is thus less prone to biases introduced by assumptions in comparison to the more commonly used Jeans modelling, and it allows us to put reliable constraints on their dark matter content. Here we present our results for the Sculptor dSph galaxy, after testing our methods on mock data sets. We fit both the second and fourth velocity moment profiles to break the mass-anisotropy degeneracy. For an Navarro, Frenk \& White (NFW) dark matter halo profile, we find that the mass of Sculptor within 1 kpc is M1 kpc = (1.03 \textpm{} 0.07) \texttimes{} 108 M{$\odot$}, and that its velocity anisotropy profile is tangentially biased and nearly constant for radii beyond {$\sim$}100 pc. The preferred concentration (c {$\sim$} 15) is low for its dark matter mass but consistent within the scatter found in N-body cosmological simulations. When we let the value of the central logarithmic slope {$\alpha$} vary, we find that the best-fitting model has {$\alpha$} = 0, although an NFW cusp or shallower is consistent at the 1{$\sigma$} confidence level. On the other hand, very cuspy density profiles with logarithmic central slopes {$\alpha$} {$<$} -1.5 are strongly disfavoured for Sculptor.},
  langid = {english},
  keywords = {Astrophysics - Cosmology and Nongalactic Astrophysics,galaxies: dwarf,galaxies: kinematics and dynamics,Sculptor},
  annotation = {ADS Bibcode: 2013MNRAS.433.3173B},
  file = {/Users/daniel/Zotero/storage/ZNPZXMWC/Breddels et al. - 2013 - Orbit-based dynamical models of the Sculptor dSph galaxy.pdf}
}
