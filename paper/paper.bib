@article{drakos+taylor+benson2020,
  title = {Mass-Loss in Tidally Stripped Systems: The Energy-Based Truncation Method},
  shorttitle = {Mass-Loss in Tidally Stripped Systems},
  author = {Drakos, Nicole E. and Taylor, James E. and Benson, Andrew J.},
  year = 2020,
  month = may,
  journal = {\mnras},
  volume = {494},
  pages = {378--395},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/staa760},
  url = {https://ui.adsabs.harvard.edu/abs/2020MNRAS.494..378D},
  urldate = {2025-08-02},
  abstract = {The ability to accurately predict the evolution of tidally stripped haloes is important for understanding galaxy formation and testing the properties of dark matter. Most studies of substructure evolution make predictions based on empirical models of tidal mass-loss that are calibrated using numerical simulations. This approach can be accurate in the cases considered, but lacks generality and does not provide a physical understanding of the processes involved. Recently, we demonstrated that truncating NFW distribution functions sharply in energy results in density profiles that resemble those of tidally stripped systems, offering a path to constructing physically motivated models of tidal mass-loss. In this work, we review calculations of mass-loss based on energy truncation alone, and then consider what secondary effects may modulate mass-loss beyond this. We find that a combination of dependence on additional orbital parameters and variations in individual particle energies over an orbit results in a less abrupt truncation in energy space as a subhalo loses mass. Combining the energy truncation approach with a simple prediction for the mass-loss rate, we construct a full model of mass-loss that can accurately predict the evolution of a subhalo in terms of a single parameter {$\eta$}eff. This parameter can be fully determined from the initial orbital and halo properties, and does not require calibration with numerical simulations.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,dark matter,dynamics theory,galaxies: haloes,idealized simulations,methods: numerical},
  annotation = {ADS Bibcode: 2020MNRAS.494..378D},
  file = {/Users/daniel/Zotero/storage/ZX5LPKJJ/Drakos et al. - 2020 - Mass-loss in tidally stripped systems the energy-based truncation method.pdf}
}
