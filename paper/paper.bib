@article{PKS2024,
  title = {Radiocarbon Variations in Annual Tree Rings with 11-Year Solar Cycles during 1800--1950},
  author = {Povinec, Pavel P. and Kontu{\v l}, Ivan and Svetlik, Ivo},
  year = 2024,
  month = oct,
  journal = {Radiocarbon},
  volume = {66},
  number = {5},
  pages = {973--988},
  issn = {0033-8222, 1945-5755},
  doi = {10.1017/RDC.2024.37},
  url = {https://www.cambridge.org/core/journals/radiocarbon/article/radiocarbon-variations-in-annual-tree-rings-with-11year-solar-cycles-during-18001950/2C5647DF4048AAA544C7583F13DF44FF},
  urldate = {2025-02-03},
  abstract = {The results of radiocarbon variation studies observed in annual tree rings from the NW Pacific (USA Northwest) (Stuiver and Braziunas 1993) and Europe (England, Brehm et al. 2021; Slovakia, Povinec 1977, 1987) are reviewed with the aim of better understanding the 11-year radiocarbon cycle and possible impacts of solar proton events on 14C levels in the atmosphere and biosphere. The average {$\Delta$}14C amplitude in tree rings for the period of 1798--1944 was 1.3 \textpm{} 0.3‰, the average periodicity was 11 \textpm{} 1 years, and the average time shift between the sunspot numbers and {$\Delta$}14C records was 3 \textpm{} 1 years. A new solar activity minimum (Gleissberg minimum, 1878--1933) has been identified in the {$\Delta$}14C data sets from the NW Pacific and England, showing {$\Delta$}14C excess of 7‰, comparable to the Dalton minimum (1797--1823). No significant changes in {$\Delta$}14C levels were identified that could be associated with solar proton events during 1800--1950.},
  langid = {english},
  keywords = {radiocarbon,solar activity,solar proton events,tree rings,wines},
  file = {/Users/daniel/Zotero/storage/ID7M5MU5/Povinec et al. - 2024 - RADIOCARBON VARIATIONS IN ANNUAL TREE RINGS WITH 11-YEAR SOLAR CYCLES DURING 1800–1950.pdf}
}
