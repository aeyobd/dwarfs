  urldate = {2024-10-28},
  abstract = {With the increasing number of large stellar survey projects, the quality and quantity of excellent tracers for studying the Milky Way are rapidly growing, one of which is the classical Cepheids. Classical Cepheids are high-precision standard candles with very low typical uncertainties ({$<$}3\%) available via the mid-infrared period-luminosity relation. About 3500 classical Cepheids identified from the Optical Gravitational Lensing Experiment, All-Sky Automated Survey for Supernova, Gaia, Wide-field Infrared Survey Explorer, and Zwicky Transient Facility survey data have been analyzed in this work, and their spatial distributions show a clear signature of Galactic warp. Two kinematical methods are adopted to measure the Galactic rotation curve (RC) in the Galactocentric distance range of \$4\textbackslash lesssim \textbraceleft R\textbraceright\_\textbraceleft\textbackslash mathrm\textbraceleft GC\textbraceright\textbraceright\textbackslash lesssim 19\textbackslash,\textbackslash mathrm\textbraceleft kpc\textbraceright\$ . Gently declining RCs are derived by both the proper motion (PM) method and three-dimensional velocity vector (3DV) method. The largest sample of classical Cepheids with the most accurate 6D phase-space coordinates available to date are modeled in the 3DV method, and the resulting RC is found to decline at the relatively smaller gradient of (-1.33 \textpm{} 0.1) \$\textbackslash mathrm\textbraceleft km\textbraceright\textbackslash,\textbraceleft\textbraceleft\textbackslash rm\textbraceleft s\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft -1\textbraceright\textbackslash,\textbraceleft\textbackslash mathrm\textbraceleft kpc\textbraceright\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ . Comparing to results from the PM method, a higher rotation velocity ((232.5 \textpm{} 0.83) \$\textbackslash mathrm\textbraceleft km\textbraceright\textbackslash,\textbraceleft\textbraceleft\textbackslash rm\textbraceleft s\textbraceright\textbraceright\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ ) is derived at the position of the Sun in the 3DV method. The virial mass and local dark matter density are estimated from the 3DV method, which is the more reliable method, \$\textbraceleft M\textbraceright\_\textbraceleft\textbackslash mathrm\textbraceleft vir\textbraceright\textbraceright =(0.822\textbackslash pm 0.052)\textbackslash times \textbraceleft 10\textbraceright\textasciicircum\textbraceleft 12\textbraceright\textbackslash,\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ and \$\textbraceleft\textbackslash rho \textbraceright\_\textbraceleft\textbackslash mathrm\textbraceleft DM\textbraceright,\textbackslash odot \textbraceright =0.33\textbackslash pm 0.03\$ GeV, respectively.},
  langid = {english},
  keywords = {1049,1051,218,353,354,606,619,Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,Astrophysics - High Energy Astrophysical Phenomena,Cepheid variable stars,Dark matter,Dark matter density,Galaxy mass distribution,Galaxy rotation curves,Milky Way dark matter halo,Milky Way dynamics},
  annotation = {ADS Bibcode: 2020ApJ...895L..12A},
