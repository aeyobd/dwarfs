@article{putman+1998,
  title = {Tidal Disruption of the Magellanic Clouds by the Milky Way},
  author = {Putman, M. E. and Gibson, B. K. and {Staveley-Smith}, L. and Banks, G. and Barnes, D. G. and Bhatal, R. and Disney, M. J. and Ekers, R. D. and Freeman, K. C. and Haynes, R. F. and Henning, P. and Jerjen, H. and Kilborn, V. and Koribalski, B. and Knezek, P. and Malin, D. F. and Mould, J. R. and Oosterloo, T. and Price, R. M. and Ryder, S. D. and Sadler, E. M. and Stewart, I. and Stootman, F. and Vaile, R. A. and Webster, R. L. and Wright, A. E.},
