@article{zhu+2025,
  title = {{{SQuIGGE}}: {{Observational Evidence}} of {{Low Ongoing Star Formation Rates}} in {{Gas-rich Post-starburst Galaxies}}},
  shorttitle = {{{SQuIGGE}}},
  author = {Zhu, Pengpei and Suess, Katherine A. and Kriek, Mariska and Setton, David J. and Bezanson, Rachel and Donofrio, Vincenzo and Feldmann, Robert and Goulding, Andy D. and Greene, Jenny E. and Narayanan, Desika and Spilker, Justin},
  year = 2025,
  month = mar,
  journal = {Astrophys. J.},
  volume = {981},
  pages = {60},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/adaf1c},
  url = {https://ui.adsabs.harvard.edu/abs/2025ApJ...981...60Z},
  urldate = {2026-02-03},
  abstract = {Atacama Large Millimeter/submillimeter Array observations have shown that candidate "post-starburst" galaxies (PSBs) at z {$\sim$} 0.6 can retain significant molecular gas reservoirs. These results would imply that---unlike many model predictions---galaxies can shut down their star formation before their cold gas reservoirs are depleted. However, these studies inferred star formation rates (SFRs) either from [O II] line fluxes or from spectral energy distribution (SED) modeling and could have missed large dust-obscured contributions to the SFRs. In this study, we present Keck/NIRES observations of 13 massive (M* {$\greaterequivlnt$} 1011 M{$\odot$}) PSBs, which allow us to estimate H{$\alpha$} SFRs in these gas-rich PSBs. We confirm the previously inferred low SFRs for the majority of the sample: 11/13 targets show clear H{$\alpha$} absorption, with minimal infilling indicating dust-corrected SFRs of {$<$}4.1 M{$\odot$} yr-1. These SFRs are notably low given the large H2 reservoirs ({$\sim$}(1--5) \texttimes{} 1010 M{$\odot$}) present in 5/13 of these galaxies, placing them significantly offset from star-forming galaxies on the Kennicutt--Schmidt relation for star-forming galaxies. The [N II]/H{$\alpha$} ratios of all 13 PSBs imply contributions from non-star-forming ionization mechanisms (e.g., active galactic nuclei, shocks, or hot evolved stars) to their H{$\alpha$} emission, suggesting that even these low ongoing SFRs may be overestimated. These low H{$\alpha$} SFRs, dust corrected using Av estimates from SED fitting, confirm that these galaxies are very likely quiescent and, thus, that galaxies can quench before their cold gas reservoirs are fully depleted.},
  keywords = {2016,2040,2176,573,594,Astrophysics - Astrophysics of Galaxies,Galaxies,Galaxy evolution,Galaxy quenching,Post-starburst galaxies,Quenched galaxies},
  annotation = {ADS Bibcode: 2025ApJ...981...60Z},
  file = {/Users/daniel/Zotero/storage/9VXUPUT4/Zhu et al. - 2025 - SQuIGGE observational evidence of low ongoing star formation rates in gas-rich post-starburst galax.pdf}
}
