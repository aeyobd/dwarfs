@misc{chakrabarti+2025,
  title = {Constraints on a Dark Matter Sub-Halo near the {{Sun}} from Pulsar Timing},
  author = {Chakrabarti, Sukanya and Chang, Philip and Profumo, Stefano and Craig, Peter},
  year = 2025,
  month = sep,
  number = {arXiv:2507.16932},
  eprint = {2507.16932},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2507.16932},
  url = {http://arxiv.org/abs/2507.16932},
  urldate = {2025-11-05},
  abstract = {Using pulsar accelerations, we identify and constrain the properties of a dark matter sub-halo in the Galaxy for the first time from analyzing the acceleration field of binary and solitary pulsars. The sub-halo is characterized by analyzing a local deviation from a smooth potential. Our MCMC calculations show that this sub-halo has a mass of \$2.45\textasciicircum\textbraceleft +1.07\textbraceright\_\textbraceleft -0.96\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 7\textbraceright\textasciitilde M\_\textbraceleft\textbackslash odot\textbraceright\$ and is located at Galactocentric coordinates \$X = 7.43\textasciicircum\textbraceleft +0.2\textbraceright\_\textbraceleft -0.12\textbraceright\textasciitilde\textbackslash rm\$ kpc, \$Y = 0.38\textasciicircum\textbraceleft +0.11\textbraceright\_\textbraceleft -0.16\textbraceright{} \textasciitilde\textbackslash rm kpc\$, \$Z = 0.21\textasciicircum\textbraceleft +0.06\textbraceright\_\textbraceleft -0.11\textbraceright{} \textasciitilde\textbackslash rm kpc\$, using flat, uninformative priors, where we have modeled the sub-halo as a compact object. The Bayes factors for the models are in the range of \$\textbackslash sim\$ 20-40, which indicate strong evidence (though not yet decisive) for the sub-halo. Modeling the sub-halo with a NFW profile gives a sub-halo mass of \$6.19\textasciicircum\textbraceleft +1.92\textbraceright\_\textbraceleft -2.03\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 7\textbraceright\$, located at \$X = 7.47\textasciicircum\textbraceleft +0.21\textbraceright\_\textbraceleft -0.14\textbraceright\$, \$Y=0.38\textasciicircum\textbraceleft +0.11\textbraceright\_\textbraceleft -0.16\textbraceright\$, \$Z=0.21\textasciicircum\textbraceleft +0.06\textbraceright\_\textbraceleft -0.11\textbraceright\$. We examine \textbackslash textit\textbraceleft Gaia\textbraceright{} data and the atomic and molecular hydrogen data of our Galaxy and show that the measured deviation from a smooth potential cannot arise from the gas or the stars in our Galaxy. Additionally, by analyzing the full sample of binary pulsars with available acceleration measurements that span 3.4 kpc in Galactocentric radius from the Sun and 3.6 kpc in vertical height, we find that massive (with mass \${$>$}10\textasciicircum\textbraceleft 8\textbraceright\textasciitilde M\_\textbraceleft\textbackslash odot\textbraceright\textasciitilde\$) sub-halos are disfavored for the Milky Way within several kiloparsec of the Sun. As the number and precision of direct acceleration measurements continues to grow, we will obtain tighter constraints on dark matter sub-structure in our Galaxy. These measurements now open a new avenue for studying dark matter and have implications across many fields of astrophysics - from understanding the nature of dark matter to galaxy formation.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/UJ4C86H5/Chakrabarti et al. - 2025 - Constraints on a dark matter sub-halo near the Sun from pulsar timing.pdf}
}

