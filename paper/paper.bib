  author = {Iani, E. and Zanella, A. and Vernet, J. and Richard, J. and Gronke, M. and {Arrigoni-Battaia}, F. and Bolamperti, A. and Caputi, K. I. and Humphrey, A. and Rodighiero, G. and Rinaldi, P. and Vanzella, E.},
