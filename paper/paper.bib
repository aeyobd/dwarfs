@article{lee+jeon+bromm2024,
  title = {Hypernova Signatures of the First Stars in Dwarf Galaxies in the Local Group},
  author = {Lee, Teayong and Jeon, Myoungwon and Bromm, Volker},
  year = 2024,
  month = jan,
  journal = {\mnras},
  volume = {527},
  pages = {1257--1274},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stad3198},
  url = {https://ui.adsabs.harvard.edu/abs/2024MNRAS.527.1257L},
  urldate = {2025-04-28},
  abstract = {Observing the first generation of stars, Population III (Pop III), is still a challenge even with the JWST due to their faintness. Instead, searching for fossil records of Pop III stars in nearby dwarf galaxies provides an alternative method for studying their physical properties. It is intriguing that a star recently discovered in the Sculptor dwarf galaxy, named AS0039, is considered to show the unique signature of a Pop III star. The detailed abundance patterns of AS0039 are well matched with those predicted by nucleosynthesis models for Pop III exploding as an energetic hypernova (HN), confirming its potential to provide insight into the properties of the first stars. This study aims to explore the environmental conditions required for the formation of such a unique star using cosmological hydrodynamic zoom-in simulations on dwarf galaxies with a mass of \$M\_\textbraceleft\textbackslash rm vir\textbraceright\textbackslash approx 10\textasciicircum 8\textbraceleft\textbackslash{} \textbackslash mathrm\textbraceleft{} M\textbraceright\_\textbackslash odot \textbraceright\$ at z = 0 while varying the fraction of Pop III stars that undergo HNe. Our simulations identify rapid gas inflow (\$\textbackslash dot\textbraceleft M\textbraceright\_\textbraceleft\textbackslash rm gas\textbraceright\textbackslash sim 0.08\textbraceleft\textbackslash{} \textbackslash mathrm\textbraceleft{} M\textbraceright\_\textbackslash odot \textbraceright\$ \$\textbackslash rm yr\textasciicircum\textbraceleft -1\textbraceright\$) as a possible factor in facilitating the formation of stars similar to AS0039. Alternatively, the delayed formation of subsequent Population II (Pop II) stars in the gas-enriched environment may lead to low-metallicity stars like AS0039. Additionally, using the A-SLOTH code, we investigate the probability of finding remnants of Pop II stars with HN signatures in nearby dwarf satellite galaxies. We suggest that the most likely dwarf galaxies to contain HN signatures are massive satellites with a probability of 40 per cent in the range of \$M\_\textbraceleft\textbackslash rm peak\textbraceright\textbackslash approx 10\textasciicircum\textbraceleft 10\textbraceright\textbackslash{} \textbackslash mathrm\textbraceleft{} to\textbraceright{} \textbackslash{} 10\textasciicircum\textbraceleft 11\textbraceright\textbraceleft\textbackslash{} \textbackslash mathrm\textbraceleft{} M\textbraceright\_\textbackslash odot \textbraceright\$ and \$M\_\textbraceleft\textbackslash ast \textbraceright\textbackslash approx 10\textasciicircum 7 \textbackslash{} \textbackslash mathrm\textbraceleft{} to\textbraceright{} \textbackslash{} 10\textasciicircum 8\textbraceleft\textbackslash{} \textbackslash mathrm\textbraceleft{} M\textbraceright\_\textbackslash odot \textbraceright\$, considering observational limitations.},
