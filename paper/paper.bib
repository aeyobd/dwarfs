@article{jackson+2024,
  title = {The Formation of Cores in Galaxies across Cosmic Time - the Existence of Cores Is Not in Tension with the {{$\Lambda$CDM}} Paradigm},
  author = {Jackson, R. A. and Kaviraj, S. and Yi, S. K. and Peirani, S. and Dubois, Y. and Martin, G. and Devriendt, J. E. G. and Slyz, A. and Pichon, C. and Volonteri, M. and Kimm, T. and Kraljic, K.},
  year = 2024,
  month = feb,
  journal = {\mnras},
  volume = {528},
  pages = {1655--1667},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stae056},
  url = {https://ui.adsabs.harvard.edu/abs/2024MNRAS.528.1655J},
  urldate = {2025-07-24},
  abstract = {The 'core-cusp' problem is considered a key challenge to the {$\Lambda$}CDM paradigm. Haloes in dark matter only simulations exhibit 'cuspy' profiles, where density continuously increases towards the centre. However, the dark matter profiles of many observed galaxies (particularly in the dwarf regime) deviate strongly from this prediction, with much flatter central regions ('cores'). We use NewHorizon (NH), a hydrodynamical cosmological simulation, to investigate core formation, using a statistically significant number of galaxies in a cosmological volume. Haloes containing galaxies in the upper (M{$\star$} {$\geq$} 1010.2 M{$\odot$}) and lower (M{$\star$} {$\leq$} 108 M{$\odot$}) ends of the stellar mass distribution contain cusps. However, Haloes containing galaxies with intermediate (108 M{$\odot$} {$\leq$} M{$\star$} {$\leq$} 1010.2 M{$\odot$}) stellar masses are generally cored, with typical halo masses between 1010.2 M{$\odot$} and 1011.5 M{$\odot$}. Cores form through supernova-driven gas removal from halo centres, which alters the central gravitational potential, inducing dark matter to migrate to larger radii. While all massive (M{$\star$} {$\geq$} 109.5 M{$\odot$}) galaxies undergo a cored-phase, in some cases cores can be removed and cusps reformed. This happens if a galaxy undergoes sustained star formation at high redshift, which results in stars (which, unlike the gas, cannot be removed by baryonic feedback) dominating the central gravitational potential. After cosmic star formation peaks, the number of cores, and the mass of the Haloes they are formed in, remain constant, indicating that cores are being routinely formed over cosmic time after a threshold halo mass is reached. The existence of cores is, therefore, not in tension with the standard paradigm.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: dwarf,galaxies: evolution,galaxies: formation,galaxies: haloes,methods: numerical,to read},
  annotation = {ADS Bibcode: 2024MNRAS.528.1655J},
  file = {/Users/daniel/Zotero/storage/PGI36QX8/Jackson et al. - 2024 - The formation of cores in galaxies across cosmic time - the existence of cores is not in tension wit.pdf}
}
