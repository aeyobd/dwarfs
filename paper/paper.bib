@article{navarro1989,
  title = {Merging Encounters between Equal-Mass Non-Rotating Galaxies},
  author = {Navarro, Julio F.},
  year = 1989,
  month = jul,
  journal = {\mnras},
  volume = {239},
  pages = {257--272},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/239.1.257},
  url = {https://ui.adsabs.harvard.edu/abs/1989MNRAS.239..257N},
  urldate = {2026-02-24},
  abstract = {N-body simulations are used to investigate merging encounters between equal-mass isotropic non-rotating de Vaucouleurs-type galaxies in order to obtain empirical correlations that relate the structural parameters of merger remnants to the initial orbit and structure of the progenitors. We found that these parameters correlate well with the orbital energy of the pair. The angular momentum of the orbit was found to have a noticeable influence only on the internal spin of the remnant. An analysis of the location of the remnants in the R\_eff\_ - {$\mu\_$}eff\_ plane (R\_eff\_ and {$\mu\_$}eff\_ stand for the effective radius and the logarithm of the surface density measured at R\_eff\_) with regards to that of the progenitor suggests that galaxies which have experienced several mergers in the past would deviate systematically from the R\_effmu\_eff\_ relation holding for normal elliptical galaxies. Such deviation is consistent with data on the properties of brightest cluster members recently published by Schombert. The density structure of the remnants of merging collisions between de Vaucouleurs galaxy models progressively approaches an r\textasciicircum 1/4\textasciicircum -law profile. Transitory 'light' excesses in the outer parts are also produced, as found by Aguilar \& White for non-merging encounters. This suggests that some 'tidally distended' galaxies (Kormendy) may be actually interpreted as the remnants of mergers between galaxies of comparable mass and size on its later stages. Nevertheless, this interpretation should be confirmed by additional merger evidence in 'tidally distended' galaxies.},
  langid = {english},
  keywords = {Angular Momentum,Astronomical Models,Astrophysics,Computerized Simulation,Galactic Mass,Galactic Rotation,Galactic Structure,Gravitational Effects,Interacting Galaxies,Many Body Problem},
  annotation = {ADS Bibcode: 1989MNRAS.239..257N},
