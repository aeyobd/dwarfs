@article{carlin+2009,
  title = {Kinematics and Metallicities in the Bo\"otes {{III}} Stellar Overdensity: A Disrupted Dwarf Galaxy?},
  shorttitle = {Kinematics and Metallicities in the Bo\"otes {{III}} Stellar Overdensity},
  author = {Carlin, Jeffrey L. and Grillmair, Carl J. and Mu{\~n}oz, Ricardo R. and Nidever, David L. and Majewski, Steven R.},
  year = 2009,
  month = sep,
  journal = {\apj},
  volume = {702},
