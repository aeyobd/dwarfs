@article{drakos+taylor+benson2017,
  title = {The Phase-Space Structure of Tidally Stripped Haloes},
  author = {Drakos, Nicole E. and Taylor, James E. and Benson, Andrew J.},
  year = 2017,
  month = jun,
  journal = {\mnras},
  volume = {468},
  pages = {2345--2358},
