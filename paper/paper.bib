@article{tsujimoto+shigeyama2002,
  title = {History of Milky Way Dwarf Spheroidal Galaxies Imprinted on Abundance Patterns of Neutron-Capture Elements},
  author = {Tsujimoto, Takuji and Shigeyama, Toshikazu},
  year = 2002,
  month = jun,
