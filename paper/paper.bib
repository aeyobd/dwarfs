@article{diaz+bekki2012,
  title = {The Tidal Origin of the Magellanic Stream and the Possibility of a Stellar Counterpart},
  author = {Diaz, Jonathan D. and Bekki, Kenji},
  year = 2012,
  month = may,
  journal = {\apj},
  volume = {750},
  pages = {36},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/750/1/36},
  url = {https://ui.adsabs.harvard.edu/abs/2012ApJ...750...36D},
  urldate = {2025-09-26},
  abstract = {We present an N-body model that reproduces the morphology and kinematics of the Magellanic Stream (MS), a vast neutral hydrogen (H I) structure that trails behind the Large and Small Magellanic Clouds (LMC and SMC, respectively) in their orbit about the Milky Way (MW). After investigating 8 \texttimes{} 106 possible orbits consistent with the latest proper motions, we adopt an orbital history in which the LMC and SMC have only recently become a strongly interacting binary pair. We find that their first close encounter \textasciitilde 2 Gyr ago provides the necessary tidal forces to disrupt the disk of the SMC and thereby create the MS. The model also reproduces the on-sky bifurcation of the two filaments of the MS, and we suggest that a bound association with the MW is required to reproduce the bifurcation. Additional H I structures are created during the tidal evolution of the SMC disk, including the Magellanic Bridge, the "Counter-Bridge," and two branches of leading material. Insights into the chemical evolution of the LMC are also provided, as a substantial fraction of the material stripped away from the SMC is engulfed by the LMC. Lastly, we compare three different N-body realizations of the stellar component of the SMC, which we model as a pressure-supported spheroid motivated by recent kinematical observations. We find that an extended spheroid is better able to explain the stellar periphery of the SMC, and the tidal evolution of the spheroid may imply the existence of a stellar stream akin to the gaseous MS.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: evolution,galaxies: kinematics and dynamics,Galaxy: halo,Magellanic Clouds},
  annotation = {ADS Bibcode: 2012ApJ...750...36D},
  file = {/Users/daniel/Zotero/storage/QAQGHUHM/Diaz and Bekki - 2012 - The tidal origin of the magellanic stream and the possibility of a stellar counterpart.pdf}
}
