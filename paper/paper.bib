@article{smercina+2022,
  title = {Relating the Diverse Merger Histories and Satellite Populations of Nearby Galaxies},
  author = {Smercina, Adam and Bell, Eric F. and Samuel, Jenna and D'Souza, Richard},
  year = 2022,
  month = may,
  journal = {\apj},
  volume = {930},
  pages = {69},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.3847/1538-4357/ac5d56},
  url = {https://ui.adsabs.harvard.edu/abs/2022ApJ...930...69S},
  urldate = {2025-05-27},
  abstract = {We investigate whether the considerable diversity in the satellite populations of nearby Milky Way (MW)-mass galaxies is connected with the diversity in their host's merger histories. Analyzing eight nearby galaxies with extensive observations of their satellite populations and stellar halos, we characterize each galaxy's merger history using the metric of its most dominant merger, M {$\star$},Dom, defined as the greater of either its total accreted stellar mass or most massive current satellite. We find an unexpectedly tight relationship between these galaxies' number of M V {$<$} - 9 satellites within 150 kpc (N Sat) and M {$\star$},Dom. This relationship remains even after accounting for differences in galaxy mass. Using the star formation and orbital histories of satellites around the MW and M81, we demonstrate that both likely evolved along the M {$\star$},Dom-N Sat relation during their current dominant mergers with the Large Magellanic Cloud and M82, respectively. We investigate the presence of this relation in galaxy formation models, including using the Feedback In Realistic Environments (FIRE) simulations to directly compare to the observations. We find no relation between M {$\star$},Dom and N Sat in FIRE, and a universally large scatter in N Sat with M {$\star$},Dom across simulations-in direct contrast with the tightness of the empirical relation. This acute difference in the observed and predicted scaling relation between two fundamental galaxy properties signals that current simulations do not sufficiently reproduce diverse merger histories and their effects on satellite populations. Explaining the emergence of this relation is therefore essential for obtaining a complete understanding of galaxy formation.},
  langid = {english},
  keywords = {2031,416,594,595,598,608,Astrophysics - Astrophysics of Galaxies,Dwarf galaxies,Galaxy evolution,Galaxy formation,Galaxy mergers,Galaxy stellar halos,Scaling relations},
  annotation = {ADS Bibcode: 2022ApJ...930...69S},
  file = {/Users/daniel/Zotero/storage/SFVFXYYS/Smercina et al. - 2022 - Relating the Diverse Merger Histories and Satellite Populations of Nearby Galaxies.pdf}
}
