@article{ji+2021,
  title = {Kinematics of Antlia 2 and Crater 2 from the Southern Stellar Stream Spectroscopic Survey ({{S5}})},
  author = {Ji, Alexander P. and Koposov, Sergey E. and Li, Ting S. and Erkal, Denis and Pace, Andrew B. and Simon, Joshua D. and Belokurov, Vasily and Cullinane, Lara R. and Da Costa, Gary S. and Kuehn, Kyler and Lewis, Geraint F. and Mackey, Dougal and Shipp, Nora and Simpson, Jeffrey D. and Zucker, Daniel B. and Hansen, Terese T. and {Bland-Hawthorn}, Joss and {S5 Collaboration}},
