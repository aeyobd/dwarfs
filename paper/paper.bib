  title = {The Ursa Minor Dwarf Galaxy : Still an Old Stellar System},
  shorttitle = {The Ursa Minor Dwarf Galaxy},
  author = {Olszewski, E. W. and Aaronson, M.},
  year = 1985,
  month = nov,
  journal = {\aj},
  volume = {90},
