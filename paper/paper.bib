@article{maccarone+fender+tzioumis2005,
  title = {Upper Limits on Central Black Hole Masses of Globular Clusters from Radio Emission and a Possible Black Hole Detection in the Ursa Minor Dwarf Galaxy},
  author = {Maccarone, Thomas J. and Fender, Robert P. and Tzioumis, Anastasios K.},
  year = 2005,
  month = jan,
  journal = {\mnras},
  volume = {356},
  pages = {L17-L22},
  issn = {0035-8711},
  doi = {10.1111/j.1745-3933.2005.08584.x},
  url = {https://ui.adsabs.harvard.edu/abs/2005MNRAS.356L..17M},
  urldate = {2025-09-23},
  abstract = {Intermediate-mass black holes (IMBHs) have been alternatively predicted to be quite common in the centres of globular clusters or nearly impossible to form and retain in the centres of globular clusters. As it has been recently shown that radio observations are currently the most sensitive observational technique for detecting such objects, we have obtained new deep radio observations of Omega Cen, and have reanalyzed older observations of M 15 in the hope of constraining the masses of possible black holes in their centres. In both cases, upper limits of about 100 {$\mu$}Jy are found atGHz frequencies. We find that if the Bondi-Hoyle accretion rate truly represents the spherical accretion rate onto a black hole, then the masses of the black holes in the centres of these two galaxies are severely constrained - with mass limits of less than about 100 solar masses in both cases. If more realistic assumptions are made based on recent work showing the Bondi rate to be a severe overestimate, then the data for Omega Cen are marginally consistent with a black hole of about 1/1000 of the mass of the cluster (i.e. about 1000Msolar). The data for M 15 are then only marginally consistent with previous reports of a \textasciitilde 2000 solar mass black hole, and we note that there is considerable hope for either detecting the black hole or improving this upper limit with current instrumentation. Finally, we discuss the possibility that the radio source near the core of the Ursa Minor dwarf spheroidal galaxy is a \textasciitilde 104-Msolar black hole.},
  langid = {english},
  keywords = {accretion,accretion discs,Astrophysics,black hole physics,globular clusters: general,globular clusters: individual: Omega Cen,radio continuum: general,to read,Ursa Minor},
  annotation = {ADS Bibcode: 2005MNRAS.356L..17M},
  file = {/Users/daniel/Zotero/storage/R52X7UWV/Maccarone et al. - 2005 - Upper limits on central black hole masses of globular clusters from radio emission and a possible bl.pdf}
}
