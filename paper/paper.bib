@article{garnett1997,
  title = {Constraints on the 12{{{\emph{C}}}}({\emph{{$\alpha$}}}, {\emph{{$\gamma$}}})16{{{\emph{O}}}} Nuclear Reaction Rate from Hubble Space Telescope Observations of {{CO}}{$<$}math{$><$}mtext{$>$}{{C}}{$<$}/mtext{$><$}mtext{$>$}{{O}}{$<$}/Mtext{$><$}/Math{$>$} in Low-Abundance Galaxies},
  author = {Garnett, D. R.},
  year = 1997,
  month = aug,
  journal = {NuPhA},
  series = {Nuclei in the {{Cosmos}}},
  volume = {621},
  number = {1},
  pages = {27--30},
  issn = {0375-9474},
  doi = {10.1016/S0375-9474(97)00206-6},
  url = {https://www.sciencedirect.com/science/article/pii/S0375947497002066},
  urldate = {2024-12-10},
  abstract = {The CO abundance ratio in the ionized interstellar gas of galaxies with very low heavy element abundances is used to constrain the 12C({$\alpha$}, {$\gamma$})16O nuclear reaction rate, based on spectroscopic measurements using the Hubble Space Telescope (Garnett et al. 1995, ApJ, 443, 64). We observe that CO is only about one-third the solar system value in galaxies with the lowest abundances (OH less than one-tenth of the solar system value), implying significant evolution of the abundance ratio. If intermediate mass stars have not contributed significant amounts of carbon to the interstellar gas in these galaxies, then the CO ratio reflects nucleosynthetic yields of C and O in massive stars, which are sensitive to the 12C({$\alpha$}, {$\gamma$})16O rate. Based on stellar nucleosynthesis calculations of Weaver \& Woosley (1993, Phys. Rep. 227, 65), the average observed CO ratio in the four galaxies with the lowest abundances implies a reaction rate of 1.7 times the Caughlan \& Fowler 1988 (CF88) ``baseline'' rate for 12C({$\alpha$}, {$\gamma$})16O, with a lower limit of 1.2 times the CF88 rate (95\% confidence level). This compares well with Weaver \& Woosley's best estimate of 1.7\textpm 0.5 times the CF88 rate.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/A42I5PWV/Garnett - 1997 - Constraints on the 12C(α, γ)16O nuclear reaction rate from Hubble Space.pdf;/Users/daniel/Zotero/storage/MRMKP2GL/S0375947497002066.html}
}
