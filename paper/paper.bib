  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,binaries: close,binaries: eclipsing,binaries: spectroscopic,stars: abundances,stars: formation,stars: solar-type},
  annotation = {ADS Bibcode: 2019ApJ...875...61M},
