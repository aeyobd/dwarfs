@article{delpino+aparicio+hidalgo2015,
  title = {Merger Traces in the Spatial Distribution of Stellar Populations in the Fornax {{dSph}} Galaxy},
  author = {{del Pino}, Andr{\'e}s and Aparicio, Antonio and Hidalgo, Sebastian L.},
  year = 2015,
  month = dec,
  journal = {\mnras},
  volume = {454},
  pages = {3996--4012},
  issn = {0035-8711},
  doi = {10.1093/mnras/stv2174},
  url = {https://ui.adsabs.harvard.edu/abs/2015MNRAS.454.3996D},
  urldate = {2025-09-18},
  abstract = {We present a comprehensive and detailed study of the stellar populations of the Fornax dwarf spheroidal galaxy. We analyse their spatial distributions along the main body of the galaxy, obtaining their surface density maps, together with their radial density profiles. Results are based on the largest and most complete catalogue of stars in Fornax, with more than 3.5 \texttimes{} 105 stars covering the main body of the galaxy up to V {$\sim$} 24. We find a differentiated structure in Fornax depending on the stellar ages. Old stars ({$\greaterequivlnt$}10 Gyr) follow an elliptical distribution well fitted by King profiles with relatively large core radius (rc = 760 \textpm{} 60 pc). On another hand, young populations ({$\lessequivlnt$}3 Gyr) concentrate in the central region of the galaxy (rc = 210 \textpm{} 10 pc), and are better fitted by S\'ersic profiles with 0.8 {$<$} n {$<$} 1.2, indicating some discy shape. These stars show strong asymmetries and substructures not aligned with the main optical axes of Fornax. This together with the observed differences between metallicity and age distribution maps strongly suggests accretion of material with different angular momentum. These results lead us to propose a scenario in which Fornax has suffered a major merger at z {$\sim$} 1.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,early Universe,galaxies: dwarf,galaxies: evolution,Local Group,stellar halos},
  annotation = {ADS Bibcode: 2015MNRAS.454.3996D},
  file = {/Users/daniel/Zotero/storage/VZJZ3YR5/del Pino et al. - 2015 - Merger traces in the spatial distribution of stellar populations in the fornax dSph galaxy.pdf}
}
