@article{ragagnin+2021,
  title = {Cosmology Dependence of Halo Masses and Concentrations in Hydrodynamic Simulations},
  author = {Ragagnin, Antonio and Saro, Alexandro and Singh, Priyanka and Dolag, Klaus},
  year = 2021,
  month = jan,
  journal = {\mnras},
  volume = {500},
  pages = {5056--5071},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/staa3523},
  url = {https://ui.adsabs.harvard.edu/abs/2021MNRAS.500.5056R},
  urldate = {2025-07-18},
  abstract = {We employ a set of Magneticum cosmological hydrodynamic simulations that span over 15 different cosmologies, and extract masses and concentrations of all well-resolved haloes between z = 0 and 1 for critical overdensities \$\textbackslash Delta \_\textbackslash textrm \textbraceleft vir\textbraceright, \textbackslash Delta \_\textbraceleft 200c\textbraceright, \textbackslash Delta \_\textbraceleft 500c\textbraceright, \textbackslash Delta \_\textbraceleft 2500c\textbraceright\$ and mean overdensity {$\Delta$}200m. We provide the first mass-concentration (Mc) relation and sparsity relation (i.e. M{$\Delta$}1 - M{$\Delta$}2 mass conversion) of hydrodynamic simulations that is modelled by mass, redshift, and cosmological parameters \textohm m, \textohm b, {$\sigma$}8, h0 as a tool for observational studies. We also quantify the impact that the Mc relation scatter and the assumption of Navarro-Frank-White (NFW) density profiles have on the uncertainty of the sparsity relation. We find that converting masses with the aid of an Mc relation carries an additional fractional scatter ( \$\textbackslash approx 4\textbraceleft\textbraceleft\textbackslash{} \textbackslash rm per\textbackslash{} cent\textbraceright\textbraceright\$ ) originated from deviations from the assumed NFW density profile. For this reason, we provide a direct mass-mass conversion relation fit that depends on redshift and cosmological parameters. We release the package HYDRO\_MC, a PYTHON tool that perform all kind of conversions presented in this paper.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,cosmological parameters,Cosmology,Galaxy: halo,large-scale structure of Universe,to read},
  annotation = {ADS Bibcode: 2021MNRAS.500.5056R},
  file = {/Users/daniel/Zotero/storage/RUDC9H6S/Ragagnin et al. - 2021 - Cosmology dependence of halo masses and concentrations in hydrodynamic simulations.pdf}
}
