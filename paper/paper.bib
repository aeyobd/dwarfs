@article{longeard+2023,
  title = {The Pristine Dwarf Galaxy Survey-{{V}}. {{The}} Edges of the Dwarf Galaxy Hercules},
  author = {Longeard, Nicolas and Jablonka, Pascale and Battaglia, Giuseppina and Malhan, Khyati and Martin, Nicolas and {S{\'a}nchez-Janssen}, Rub{\'e}n and Sestito, Federico and Starkenburg, Else and Venn, Kim A.},
