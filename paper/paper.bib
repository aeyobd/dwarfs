  author = {Jones, David and Boffin, Henri M. J.},
  year = 2017,
  month = may,
  journal = {Nature Astronomy},
  volume = {1},
  pages = {0117},
  issn = {2397-3366},
  doi = {10.1038/s41550-017-0117},
  url = {https://ui.adsabs.harvard.edu/abs/2017NatAs...1E.117J},
  urldate = {2023-11-07},
  abstract = {Planetary nebulae are traditionally considered to represent the final evolutionary stage of all intermediate-mass stars ({$\sim$}0.7-8 M{$\odot$}). Recent evidence seems to contradict this picture. In particular, since the launch of the Hubble Space Telescope, it has been clear that planetary nebulae display a wide range of striking morphologies that cannot be understood in a single-star scenario, instead pointing towards binary evolution in a majority of systems. Here, we summarize our current understanding of the importance of binarity in the formation and shaping of planetary nebulae, as well as the surprises that recent observational studies have revealed with respect to our understanding of binary evolution in general. These advances have critical implications for the understanding of mass transfer processes in binary stars---particularly the all-important but ever-so-poorly understood 'common envelope phase'---as well as the formation of cosmologically important type Ia supernovae.},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  annotation = {ADS Bibcode: 2017NatAs...1E.117J},
  file = {/Users/daniel/Zotero/storage/I7Z5BQS2/Jones and Boffin - 2017 - Binary stars as the key to understanding planetary.pdf}
}
