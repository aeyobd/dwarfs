@article{kleyna+1998,
  title = {A {{V}} and {{I CCD}} Mosaic Survey of the Ursa Minor Dwarf Spheroidal Galaxy},
  author = {Kleyna, J. T. and Geller, M. J. and Kenyon, S. J. and Kurtz, M. J. and Thorstensen, J. R.},
