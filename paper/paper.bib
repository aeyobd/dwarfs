@article{gallagher+2003,
  title = {A Search for Ionized Gas in the Draco and Ursa Minor Dwarf Spheroidal Galaxies},
  author = {Gallagher, J. S. and Madsen, G. J. and Reynolds, R. J. and Grebel, E. K. and {Smecker-Hane}, T. A.},
  year = 2003,
  month = may,
  journal = {\apj},
  volume = {588},
  pages = {326--330},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1086/373951},
  url = {https://ui.adsabs.harvard.edu/abs/2003ApJ...588..326G},
  urldate = {2025-04-28},
  abstract = {The Wisconsin H{$\alpha$} Mapper has been used to set the first deep upper limits on the intensity of diffuse H{$\alpha$} emission from warm ionized gas in the Draco and Ursa Minor dwarf spheroidal galaxies (dSphs). Assuming a velocity dispersion of 15 km s-1 for the ionized gas, we set limits of IH{$\alpha<$}=0.024 R and IH{$\alpha<$}=0.021 R for the Draco and Ursa Minor dSphs, respectively, averaged over our 1{$^\circ$} circular beam. Adopting a simple model for the ionized interstellar medium, these limits translate to upper bounds on the mass of ionized gas of {$<$}\textasciitilde 10\% of the stellar mass, or \textasciitilde 10 times the upper limits for the mass of neutral hydrogen. Note that the Draco and Ursa Minor dSphs could contain substantial amounts of interstellar gas, equivalent to all of the gas injected by dying stars since the end of their main star-forming episodes {$>$}\textasciitilde 8 Gyr in the past, without violating these limits on the mass of ionized gas.},
  langid = {english},
  keywords = {Astrophysics,Galaxies: Dwarf,Galaxies: Individual: Name: Draco,Galaxies: Individual: Name: Ursa Minor,Galaxies: ISM},
  annotation = {ADS Bibcode: 2003ApJ...588..326G},
  file = {/Users/daniel/Zotero/storage/CRJII2Q2/Gallagher et al. - 2003 - A Search for Ionized Gas in the Draco and Ursa Minor Dwarf Spheroidal Galaxies.pdf}
}
