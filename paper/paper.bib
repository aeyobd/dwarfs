@misc{mutlu-pakdil+2025,
  title = {Hubble {{Space Telescope Imaging}} of {{Three Isolated Faint Dwarf Galaxies Beyond}} the {{Local Group}}: {{Pavo}}, {{Corvus A}}, and {{Kamino}}},
  shorttitle = {Hubble {{Space Telescope Imaging}} of {{Three Isolated Faint Dwarf Galaxies Beyond}} the {{Local Group}}},
  author = {{Mutlu-Pakdil}, Bur{\c c}in and Jones, Michael G. and Sand, David J. and Crnojevi{\'c}, Denija and Herron, Kai and Strader, Jay and Zaritsky, Dennis and Bennet, Paul and {Drlica-Wagner}, Alex and Casey, Quinn O. and {Doliva-Dolinsky}, Amandine and Donnerstein, Richard and Fielder, Catherine E. and Hunter, Laura C. and Peter, Annika H. G. and Prabhu, Deepthi S. and Spekkens, Kristine},
  year = 2025,
  month = sep,
  number = {arXiv:2509.16307},
  eprint = {2509.16307},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2509.16307},
  url = {http://arxiv.org/abs/2509.16307},
  urldate = {2025-11-05},
  abstract = {We present new Hubble Space Telescope (HST) imaging of three recently discovered star-forming dwarf galaxies beyond the Local Group: Pavo, Corvus A, and Kamino. The discovery of Kamino is reported here for the first time. They rank among the most isolated faint dwarf galaxies known, hence they provide unique opportunities to study galaxy evolution at the smallest scales, free from environmental effects of more massive galaxies. Our HST data reach \$\textbackslash sim\$2-4 magnitudes below the tip of the red giant branch for each dwarf, allowing us to measure their distances, structural properties, and recent star formation histories (SFHs). All three galaxies contain a complex stellar population of young and old stars, and are typical of field galaxies in this mass regime (\$M\_V=-10.62\textbackslash pm0.08\$ and \$D=2.16\textasciicircum\textbraceleft +0.08\textbraceright\_\textbraceleft -0.07\textbraceright\$ Mpc for Pavo, \$M\_V=-10.91\textbackslash pm0.10\$ and \$D=3.34\textbackslash pm0.11\$ Mpc for Corvus A, and \$M\_V=-12.02\textbackslash pm0.12\$ and \$D=6.50\textasciicircum\textbraceleft +0.15\textbraceright\_\textbraceleft -0.11\textbraceright\$ Mpc for Kamino). Our HST-derived SFHs reveal differences among the three dwarfs: Pavo and Kamino show relatively steady, continuous star formation, while Corvus A formed \$\textbackslash sim\$\$60\$\% of its stellar mass by 10 Gyr ago. These results align with theoretical predictions of diverse evolutionary pathways for isolated low-mass galaxies.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/6KS22LMK/Mutlu-Pakdil et al. - 2025 - Hubble Space Telescope Imaging of Three Isolated Faint Dwarf Galaxies Beyond the Local Group Pavo, .pdf}
}
