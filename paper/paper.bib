@article{mao+2021,
  title = {The {{SAGA}} Survey. {{II}}. {{Building}} a Statistical Sample of Satellite Systems around Milky Way-like Galaxies},
  author = {Mao, Yao-Yuan and Geha, Marla and Wechsler, Risa H. and Weiner, Benjamin and Tollerud, Erik J. and Nadler, Ethan O. and Kallivayalil, Nitya},
