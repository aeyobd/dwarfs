@article{lotz+miller+ferguson2004,
  title = {The Colors of Dwarf Elliptical Galaxy Globular Cluster Systems, Nuclei, and Stellar Halos},
  author = {Lotz, Jennifer M. and Miller, Bryan W. and Ferguson, Henry C.},
