@article{reino+2021,
  title = {Galactic Potential Constraints from Clustering in Action Space of Combined Stellar Stream Data},
  author = {Reino, Stella and Rossi, Elena M and Sanderson, Robyn E and Sellentin, Elena and Helmi, Amina and Koppelman, Helmer H and Sharma, Sanjib},
  year = 2021,
  month = apr,
  journal = {Mon. Not. R. Astron. Soc.},
  volume = {502},
  number = {3},
  pages = {4170--4193},
  issn = {0035-8711},
  doi = {10.1093/mnras/stab304},
  url = {https://doi.org/10.1093/mnras/stab304},
  urldate = {2026-02-03},
  abstract = {Stream stars removed by tides from their progenitor satellite galaxy or globular cluster act as a group of test particles on neighbouring orbits, probing the gravitational field of the Milky Way. While constraints from individual streams have been shown to be susceptible to biases, combining several streams from orbits with various distances reduces these biases. We fit a common gravitational potential to multiple stellar streams simultaneously by maximizing the clustering of the stream stars in action space. We apply this technique to members of the GD-1, Palomar~5 (Pal~5), Orphan, and Helmi streams, exploiting both the individual and combined data sets. We describe the Galactic potential with a St\"ackel model, and vary up to five parameters simultaneously. We find that we can only constrain the enclosed mass, and that the strongest constraints come from the GD-1, Pal~5, and Orphan streams whose combined data set yields \$M(\textbackslash lt 20\textbackslash, \textbackslash mathrm\textbraceleft kpc\textbraceright ) = 2.96\textasciicircum\textbraceleft +0.25\textbraceright\_\textbraceleft -0.26\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 11\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft{} M\textbraceright\_\textbraceleft\textbackslash odot\textbraceright\$. When including the Helmi stream in the data set, the mass uncertainty increases to \$M(\textbackslash lt 20\textbackslash, \textbackslash mathrm\textbraceleft kpc\textbraceright ) = 3.12\textasciicircum\textbraceleft +3.21\textbraceright\_\textbraceleft -0.46\textbraceright{} \textbackslash times 10\textasciicircum\textbraceleft 11\textbraceright{} \textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbraceleft\textbackslash odot\textbraceright\$.},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/E2RCRS46/Reino et al. - 2021 - Galactic potential constraints from clustering in action space of combined stellar stream data.pdf;/Users/daniel/Zotero/storage/Y5QIA77R/stab304.html}
}
