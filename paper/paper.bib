  shorttitle = {Breaking {{Down}} the \$\textbackslash textsf\textbraceleft{{CosmoGEMS}}\textbraceright\$},
  author = {Panithanpaisal, Nondh and Sanderson, Robyn E. and Rodriguez, Carl L. and Starkenburg, Tjitske and Pearson, Sarah and Bonaca, Ana and Hopkins, Philip F. and Cook, Brian T. and Arora, Arpit and Weatherford, Newlin C.},
  year = 2025,
