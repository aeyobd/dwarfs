@article{kupper+2015,
  title = {Globular {{Cluster Streams}} as {{Galactic High-Precision Scales}}---the {{Poster Child Palomar}} 5},
  author = {K{\"u}pper, Andreas H. W. and Balbinot, Eduardo and Bonaca, Ana and Johnston, Kathryn V. and Hogg, David W. and Kroupa, Pavel and Santiago, Basilio X.},
  year = 2015,
  month = apr,
  journal = {The Astrophysical Journal},
  volume = {803},
  pages = {80},
  publisher = {IOP},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/803/2/80},
  url = {https://ui.adsabs.harvard.edu/abs/2015ApJ...803...80K},
  urldate = {2024-04-15},
  abstract = {Using the example of the tidal stream of the Milky Way globular cluster Palomar 5 (Pal 5), we demonstrate how observational data on tidal streams can be efficiently reduced in dimensionality and modeled in a Bayesian framework. Our approach combines detection of stream overdensities by a Difference-of-Gaussians process with fast streakline models of globular cluster streams and a continuous likelihood function built from these models. Inference is performed with Markov chain Monte Carlo. By generating {$\approx$} \textbraceleft\textbraceleft 10\textbraceright 7\textbraceright{} model streams, we show that the unique geometry of the Pal 5 debris yields powerful constraints on the solar position and motion, the Milky Way and Pal 5 itself. All 10 model parameters were allowed to vary over large ranges without additional prior information. Using only readily available SDSS data and a few radial velocities from the literature, we find that the distance of the Sun from the Galactic Center is 8.30 \textpm{} 0.25 kpc, and the transverse velocity is 253 \textpm{} 16 km s-1. Both estimates are in excellent agreement with independent measurements of these two quantities. Assuming a standard disk and bulge model, we determine the Galactic mass within Pal 5's apogalactic radius of 19 kpc to be (2.1+/- 0.4)\texttimes{} \textbraceleft\textbraceleft 10\textbraceright 11\textbraceright{} \textbraceleft\textbraceleft M\textbraceright{$\odot$} \textbraceright. Moreover, we find the potential of the dark halo with a flattening of \textbraceleft\textbraceleft q\textbraceright z\textbraceright =0.95-0.12+0.16 to be essentially spherical---at least within the radial range that is effectively probed by Pal 5. We also determine Pal 5's mass, distance, and proper motion independently from other methods, which enables us to perform vital cross-checks. Our inferred heliocentric distance of Pal 5 is 23.6-0.7+0.8 kpc, in perfect agreement with, and more precise than, estimates from isochrone fitting of deep Hubble Space Telescope (HST) imaging data. We conclude that finding and modeling more globular cluster streams is an efficient way to map out the structure of our Galaxy to high precision. With more observational data and by using additional prior information, the precision of this mapping can be significantly increased.},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics,dark matter,Galaxy: fundamental parameters,Galaxy: halo,Galaxy: kinematics and dynamics,Galaxy: structure,globular clusters: individual: Palomar 5},
  annotation = {ADS Bibcode: 2015ApJ...803...80K},
  file = {/Users/daniel/Zotero/storage/292MC4UJ/Küpper et al. - 2015 - Globular Cluster Streams as Galactic High-Precisio.pdf}
}
