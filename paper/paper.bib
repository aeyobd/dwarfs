  doi = {10.48550/arXiv.2512.14146},
  url = {http://arxiv.org/abs/2512.14146},
  urldate = {2026-01-15},
  abstract = {We construct mass models of Milky Way dwarf spheroidal galaxies to place constraints on the central black hole (BH) masses they can host. We model the galaxies as a three-component system consisting of the stars, dark matter halo, and a central black hole, using the Osipkov--Merritt--Cuddeford class of anisotropic distribution function. The posterior distribution of black hole mass remains flat toward the low-mass end, indicating that the kinematic data places an upper limit on the black hole mass. Our analysis yields a 95\% credible upper limit of \$\textbackslash log(M\_\textbraceleft\textbackslash bullet\textbraceright/M\_\textbraceleft\textbackslash odot\textbraceright ) {$<$} 6\$. We combine our results with black hole mass measurements and upper limits from the literature to construct a unified \$M\_\textbraceleft\textbackslash bullet\textbraceright\$--\${$\sigma\_$}\textbraceleft\textbraceright\$ relation spanning \${$\sigma\_$}\textbraceleft\textbraceright{} \textbackslash sim 10\$--\$300,\textbackslash mathrm\textbraceleft km,s\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$, described by \$\textbackslash log(M\_\textbraceleft\textbackslash bullet\textbraceright ) = 8.32 + 4.08,\textbackslash log\textbackslash left({$\sigma\_$}\textbraceleft\textbraceright/200,\textbackslash mathrm\textbraceleft km,s\textasciicircum\textbraceleft -1\textbraceright\textbraceright\textbackslash right)\$, with an intrinsic scatter of \${$\sigma\_$}\textbraceleft\textbackslash rm int\textbraceright{} = 0.55\$. We compare the inferred limits to models of black hole growth via momentum-driven accretion and stellar capture, which predict black hole masses in the range \$10\textasciicircum\textbraceleft 3\textbraceright\$--\$10\textasciicircum\textbraceleft 4\textbraceright,M\_\textbraceleft\textbackslash odot\textbraceright\$ for the range \${$\sigma\_$}\textbraceleft\textbraceright{} \textbackslash sim 6\$--\$12,\textbackslash mathrm\textbraceleft km,s\textasciicircum\textbraceleft -1\textbraceright\textbraceright\$, in close agreement with the \$M\_\textbraceleft\textbackslash bullet\textbraceright\$--\${$\sigma\_$}\textbraceleft *\textbraceright\$ relation within the 95\% credible upper limits on the black hole masses derived in this work.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/MIGI8TMK/Aditya and Mangalam - 2025 - Can dwarf spheroidal galaxies host a central black hole .pdf}
}

