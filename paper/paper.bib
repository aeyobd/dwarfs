  author = {Bongiovanni, {\'A}ngel and {Ram{\'o}n-P{\'e}rez}, Marina and P{\'e}rez Garc{\'i}a, Ana Mar{\'i}a and Cepa, Jordi and Cervi{\~n}o, Miguel and Nadolny, Jakub and P{\'e}rez Mart{\'i}nez, Ricardo and Alfaro, Emilio and Casta{\~n}eda, H{\'e}ctor O. and De Diego, Jos{\'e} A. and Ederoclite, Alessandro and {Fern{\'a}ndez-Lorenzo}, Mirian and Gallego, Jes{\'u}s and Gonz{\'a}lez, Jos{\'e} Jes{\'u}s and {Gonz{\'a}lez-Serrano}, Jos{\'e} Ignacio and {Lara-L{\'o}pez}, Maritza A. and Oteo G{\'o}mez, Iv{\'a}n and Padilla Torres, Carmen P. and {Pintos-Castro}, Irene and Povi{\'c}, Mirjana and {S{\'a}nchez-Portal}, Miguel and Jones, Heath and {Bland-Hawthorn}, Joss and {Cabrera-Lavers}, Antonio},
