@article{errani+2023a,
  title = {Dark Matter Halo Cores and the Tidal Survival of Milky Way Satellites},
  author = {Errani, Rapha{\"e}l and Navarro, Julio F and Pe{\~n}arrubia, Jorge and Famaey, Benoit and Ibata, Rodrigo},
  year = 2023,
  month = feb,
  journal = {\mnras},
  volume = {519},
  number = {1},
  pages = {384--396},
  issn = {0035-8711},
  doi = {10.1093/mnras/stac3499},
  url = {https://doi.org/10.1093/mnras/stac3499},
  urldate = {2025-01-24},
  abstract = {The cuspy central density profiles of cold dark matter (CDM) haloes make them highly resilient to disruption by tides. Self-interactions between dark matter particles, or the cycling of baryons, may result in the formation of a constant-density core that would make haloes more susceptible to tidal disruption. We use N-body simulations to study the evolution of Navarro--Frenk--White (NFW)-like `cored' subhaloes in the tidal field of a massive host, and identify the criteria and time-scales for full disruption. Our results imply that the survival of Milky Way satellites places constraints on the sizes of dark matter cores. We find that no subhaloes with cores larger than 1~per\,cent of their initial NFW scale radius can survive for a Hubble time on orbits with pericentres \$\textbraceleft\textbackslash lesssim\textbraceright{} 10\textbackslash, \textbackslash mathrm\textbraceleft kpc\textbraceright\$. A satellite like Tucana~3, with pericentre \$\textbraceleft\textbackslash sim\textbraceright{} 3.5\textbackslash, \textbackslash mathrm\textbraceleft kpc\textbraceright\$, must have a core size smaller than \$\textbraceleft\textbackslash sim\textbraceright{} 2\textbackslash, \textbackslash mathrm\textbraceleft pc\textbraceright\$ to survive just three orbital periods on its current orbit. The core sizes expected in self-interacting dark matter models with a velocity-independent cross-section~of \$1\textbackslash, \textbackslash mathrm\textbraceleft cm\textasciicircum 2\textbraceright\textbackslash,\textbackslash mathrm\textbraceleft g\textbraceright\textasciicircum\textbraceleft -1\textbraceright\$ seem incompatible with ultrafaint satellites with small pericentric radii, such as Tuc~3, Seg~1, Seg~2, Ret~2, Tri~2, and Wil~1, as these should have fully disrupted if accreted on to the Milky Way \$\textbraceleft\textbackslash gtrsim\textbraceright{} 10\textbackslash, \textbackslash mathrm\textbraceleft Gyr\textbraceright\$ ago. These results suggest that many satellites have vanishingly small core sizes, consistent with CDM cusps. The discovery of further Milky Way satellites on orbits with small pericentric radii would strengthen these conclusions and allow for stricter upper limits on the core sizes.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,dark matter,galaxies: dwarf,galaxies: evolution,Galaxy: kinematics and dynamics,to read},
  file = {/Users/daniel/Zotero/storage/GRENC4EG/Errani et al. - 2022 - Dark matter halo cores and the tidal survival of milky way satellites.pdf;/Users/daniel/Zotero/storage/WZKTXB4F/Errani et al. - 2023 - Dark matter halo cores and the tidal survival of Milky Way satellites.pdf}
}
