  url = {https://ui.adsabs.harvard.edu/abs/1987IAUS..117..153A},
  urldate = {2025-07-24},
  abstract = {Cumulative results are reported from an on-going effort to measure the stellar velocity dispersion in two nearby dwarf spheroidal galaxies. Radial velocities having an accuracy within 2 km/sec have now been secured for 10 stars in Ursa Minor and 11 stars in Draco (including 16 K giants and 5 C types). Most objects have been observed at two or more epochs. Stars having nonvariable velocities yield in both dwarfs a large (about 10 km/sec) dispersion. These results cannot be explained by atmospheric motions, and circumstantial evidence suggests that the effects of undetected binaries are also not likely to be important. Instead, it seems that both spheroidals contain a substantial dark matter component, which therefore must be 'cold' in form.},
  langid = {english},
  keywords = {Astrophysics,Dark Matter,Dwarf Galaxies,Giant Stars,K Stars,Mass Distribution,Radial Velocity,Star Distribution,Stellar Rotation,Ursa Minor,Velocity Distribution},
  annotation = {ADS Bibcode: 1987IAUS..117..153A},
