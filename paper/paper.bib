@article{martin+2016,
  title = {The {{PAndAS}} View of the Andromeda Satellite System. {{II}}. {{Detailed}} Properties of 23 {{M31}} Dwarf Spheroidal Galaxies},
  author = {Martin, Nicolas F. and Ibata, Rodrigo A. and Lewis, Geraint F. and McConnachie, Alan and Babul, Arif and Bate, Nicholas F. and Bernard, Edouard and Chapman, Scott C. and Collins, Michelle M. L. and Conn, Anthony R. and Crnojevi{\'c}, Denija and Fardal, Mark A. and Ferguson, Annette M. N. and Irwin, Michael and Mackey, A. Dougal and McMonigal, Brendan and Navarro, Julio F. and Rich, R. Michael},
