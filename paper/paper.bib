@article{smith+2024,
  title = {The Discovery of the Faintest Known Milky Way Satellite Using {{UNIONS}}},
  author = {Smith, Simon E. T. and Cerny, William and Hayes, Christian R. and Sestito, Federico and Jensen, Jaclyn and McConnachie, Alan W. and Geha, Marla and Navarro, Julio F. and Li, Ting S. and Cuillandre, Jean-Charles and Errani, Rapha{\"e}l and Chambers, Ken and Gwyn, Stephen and Hammer, Francois and Hudson, Michael J. and Magnier, Eugene and Martin, Nicolas},
