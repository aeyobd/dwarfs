@article{spencer+2017a,
  title = {A Multi-Epoch Kinematic Study of the Remote Dwarf Spheroidal Galaxy Leo {{II}}},
  author = {Spencer, Meghin E. and Mateo, Mario and Walker, Matthew G. and Olszewski, Edward W.},
  year = 2017,
  month = feb,
  journal = {\apj},
  volume = {836},
  pages = {202},
  publisher = {IOP},
  issn = {0004-637X},
