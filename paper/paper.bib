@article{welsh+2022,
  title = {Oxygen-Enhanced Extremely Metal-Poor Damped Ly{$\alpha$} Systems: A Signpost of the First Stars?},
  shorttitle = {Oxygen-Enhanced Extremely Metal-Poor Damped Ly{$\alpha$} Systems},
  author = {Welsh, Louise and Cooke, Ryan and Fumagalli, Michele and Pettini, Max},
  year = 2022,
  month = apr,
  journal = {ApJ},
  volume = {929},
  pages = {158},
  publisher = {IOP},
  issn = {0004-637X},
