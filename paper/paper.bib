@article{read+walker+steger2019,
  title = {Dark Matter Heats up in Dwarf Galaxies},
  author = {Read, J I and Walker, M G and Steger, P},
  year = 2019,
  month = mar,
  journal = {\mnras},
  volume = {484},
  number = {1},
  pages = {1401--1420},
  issn = {0035-8711},
  doi = {10.1093/mnras/sty3404},
  url = {https://doi.org/10.1093/mnras/sty3404},
  urldate = {2025-07-24},
  abstract = {Gravitational potential fluctuations driven by bursty star formation can kinematically `heat up' dark matter at the centres of dwarf galaxies. A key prediction of such models is that, at a fixed dark matter halo mass, dwarfs with a higher stellar mass will have a lower central dark matter density. We use stellar kinematics and HI gas rotation curves to infer the inner dark matter densities of eight dwarf spheroidal and eight dwarf irregular galaxies with a wide range of star formation histories. For all galaxies, we estimate the dark matter density at a common radius of 150\,pc, \$\textbackslash rho \_\textbraceleft\textbackslash rm DM\textbraceright (150\textbackslash, \textbackslash mathrm\textbraceleft pc\textbraceright )\$. We find that our sample of dwarfs falls into two distinct classes. Those that stopped forming stars over 6\,Gyr ago favour central densities \$\textbackslash rho \_\textbraceleft\textbackslash rm DM\textbraceright (150\textbackslash, \textbackslash mathrm\textbraceleft pc\textbraceright )\textbackslash gt 10\textasciicircum 8\$\,M{$\odot$}\,kpc-3, consistent with cold dark matter cusps, while those with more extended star formation favour \$\textbackslash rho \_\textbraceleft\textbackslash rm DM\textbraceright (150\textbackslash, \textbackslash mathrm\textbraceleft pc\textbraceright )\textbackslash lt 10\textasciicircum 8\$\,M{$\odot$}\,kpc-3, consistent with shallower dark matter cores. Using abundance matching to infer pre-infall halo masses, M200, we show that this dichotomy is in excellent agreement with models in which dark matter is heated up by bursty star formation. In particular, we find that \$\textbackslash rho \_\textbraceleft\textbackslash rm DM\textbraceright (150\textbackslash, \textbackslash mathrm\textbraceleft pc\textbraceright )\$ steadily decreases with increasing stellar mass-to-halo mass ratio, M*/M200. Our results suggest that, to leading order, dark matter is a cold, collisionless, fluid that can be kinematically `heated up' and moved around.},
  langid = {english},
  keywords = {dynamics theory,to read},
  file = {/Users/daniel/Zotero/storage/CWD5L8XJ/Read et al. - 2019 - Dark matter heats up in dwarf galaxies.pdf;/Users/daniel/Zotero/storage/8Q944Y6B/5265085.html}
}
