@misc{williams+hjorth+skillman2025,
  title = {Addressing the Core-Cusp and Diversity Problem of Dwarf and Disk Galaxies Using Cold Collisionless {{DARKexp}} Theory},
  author = {Williams, Liliya L. R. and Hjorth, Jens and Skillman, Evan D.},
  year = 2025,
  month = feb,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2502.15879},
  url = {https://ui.adsabs.harvard.edu/abs/2025arXiv250215879W},
  urldate = {2025-07-29},
  abstract = {Dwarf galaxies are observed to have linearly rising rotation curves, which indicate constant density cores in their centers. These do not arise naturally from dark matter only simulations, giving rise to the ``core-cusp'' problem. Hydrodynamic simulations incorporating baryonic feedback can create cored profiles, but this solution requires some fine tuning. Additionally, there is a related ``diversity'' problem in which simulations cannot reproduce the large range in rotation curve shapes for galaxies of similar mass. Here we investigate, for the first time, whether a theoretical model based on statistical mechanics (DARKexp) can produce flat density cores with its single shape parameter. We find that these theoretical profiles are able to fit the observed rotation curves of galaxies with last measured velocities in the range \textasciitilde{} 20-200 km/s by producing fits to 96 SPARC catalog galaxies covering this range. We additionally show that the projected stellar density distributions of ultrafaint dwarfs that show cores are also well fit, and that wave, or fuzzy dark matter is unable to fit the full range of SPARC galaxies. Thus, DARKexp appears to be able to address the core-cusp problem and the diversity of rotation curves in these dark matter dominated galaxies with cold collisionless dark matter alone, i.e., without introducing baryonic feedback, or alternative nature of dark matter.},
  langid = {english},
  keywords = {Astrophysics of Galaxies,Cosmology and Nongalactic Astrophysics},
  annotation = {ADS Bibcode: 2025arXiv250215879W},
  file = {/Users/daniel/Zotero/storage/STP5VCWX/Williams et al. - 2025 - Addressing the core-cusp and diversity problem of dwarf and disk galaxies using cold collisionless D.pdf}
}
