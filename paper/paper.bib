@article{stark+2014,
  title = {Ultraviolet Emission Lines in Young Low-Mass Galaxies at z {$\simeq$} 2: Physical Properties and Implications for Studies at z {$>$} 7},
  shorttitle = {Ultraviolet Emission Lines in Young Low-Mass Galaxies at z {$\simeq$} 2},
  author = {Stark, Daniel P. and Richard, Johan and Siana, Brian and Charlot, St{\'e}phane and Freeman, William R. and Gutkin, Julia and Wofford, Aida and Robertson, Brant and Amanullah, Rahman and Watson, Darach and {Milvang-Jensen}, Bo},
  year = 2014,
  month = dec,
  journal = {MNRAS},
  volume = {445},
  pages = {3200--3220},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stu1618},
  url = {https://ui.adsabs.harvard.edu/abs/2014MNRAS.445.3200S},
  urldate = {2024-10-15},
  abstract = {We present deep spectroscopy of 17 very low mass (M{$\star$} {$\simeq$} 2.0 \texttimes{} 106-1.4 \texttimes{} 109 M{$\odot$}) and low luminosity (MUV {$\simeq$} -13.7 to -19.9) gravitationally lensed galaxies in the redshift range z {$\simeq$} 1.5-3.0. Deep rest-frame ultraviolet spectra reveal large equivalent width emission from numerous emission lines (N IV], O III], C IV, Si III], C III]) which are rarely seen in individual spectra of more massive star-forming galaxies. C III] is detected in 16 of 17 low-mass star-forming systems with rest-frame equivalent widths as large as 13.5 \AA. Nebular C IV emission is present in the most extreme C III] emitters, requiring an ionizing source capable of producing a substantial component of photons with energies in excess of 47.9 eV. Photoionization models support a picture whereby the large equivalent widths are driven by the increased electron temperature and enhanced ionizing output arising from metal-poor gas and stars (0.04-0.13 Z{$\odot$}), young stellar populations (6-50 Myr), and large ionization parameters (log U = -2.16 to -1.84). The young ages implied by the emission lines and continuum spectral energy distributions (SEDs) indicate that the extreme line emitters in our sample are in the midst of a significant upturn in their star formation activity. The low stellar masses, blue UV colours, and large specific star formation rates of our sample are similar to those of typical z {$\greaterequivlnt$} 6 galaxies. Given the strong attenuation of Ly{$\alpha$} in z {$\greaterequivlnt$} 6 galaxies, we suggest that C III] is likely to provide our best probe of early star-forming galaxies with ground-based spectrographs and one off the most efficient means of confirming z {$\greaterequivlnt$} 10 galaxies with the James Webb Space Telescope.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,cosmology: observations,galaxies: evolution,galaxies: formation,galaxies: high-redshift},
  annotation = {ADS Bibcode: 2014MNRAS.445.3200S},
  file = {/Users/daniel/Zotero/storage/KRK6LWG7/Stark et al. - 2014 - Ultraviolet emission lines in young low-mass galaxies at z ≃ 2 physical properties and implications.pdf}
}
