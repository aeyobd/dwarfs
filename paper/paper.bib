  url = {https://ui.adsabs.harvard.edu/abs/2023AJ....165...55C},
  urldate = {2025-01-22},
  abstract = {We present chemical abundances and velocities of five stars between 0.3 and 1.1 kpc from the center of the Tucana II ultrafaint dwarf galaxy (UFD) from high-resolution Magellan/MIKE spectroscopy. We find that every star is deficient in metals (-3.6 {$<$} [Fe/H] {$<$} -1.9) and in neutron-capture elements as is characteristic of UFD stars, unambiguously confirming their association with Tucana II. Other chemical abundances (e.g., C, iron peak) largely follow UFD trends and suggest that faint core-collapse supernovae (SNe) dominated the early evolution of Tucana II. We see a downturn in [{$\alpha$}/Fe] at [Fe/H] {$\approx$} -2.8, indicating the onset of Type Ia SN enrichment and somewhat extended chemical evolution. The most metal-rich star has strikingly low [Sc/Fe] = -1.29 \textpm{} 0.48 and [Mn/Fe] = -1.33 \textpm{} 0.33, implying significant enrichment by a sub-Chandrasekhar mass Type Ia SN. We do not detect a radial velocity gradient in Tucana II ( \$\textbraceleft\textbraceleft dv\textbraceright\textbraceright\_\textbraceleft\textbackslash mathrm\textbraceleft helio\textbraceright\textbraceright/d\textbraceleft\textbackslash theta \textbraceright\_\textbraceleft 1\textbraceright =-\textbraceleft 2.6\textbraceright\_\textbraceleft -2.9\textbraceright\textasciicircum\textbraceleft +3.0\textbraceright\$ km s-1 kpc-1), reflecting a lack of evidence for tidal disruption, and derive a dynamical mass of \$\textbraceleft M\textbraceright\_\textbraceleft 1/2\textbraceright\textbackslash,(\textbraceleft r\textbraceright\_\textbraceleft h\textbraceright )=\textbraceleft 1.6\textbraceright\_\textbraceleft -0.7\textbraceright\textasciicircum\textbraceleft +1.1\textbraceright\textbackslash times \textbraceleft 10\textbraceright\textasciicircum\textbraceleft 6\textbraceright\$ M {$\odot$}. We revisit formation scenarios of the extended component of Tucana II in light of its stellar chemical abundances. We find no evidence that Tucana II had abnormally energetic SNe, suggesting that if SNe drove in situ stellar halo formation, then other UFDs should show similar such features. Although not a unique explanation, the decline in [{$\alpha$}/Fe] is consistent with an early galactic merger triggering later star formation. Future observations may disentangle such formation channels of UFD outskirts. * This paper includes data gathered with the 6.5 m Magellan Telescopes located at Las Campanas Observatory, Chile.},
  langid = {english},
  keywords = {1284,416,929,Astrophysics - Astrophysics of Galaxies,Dwarf galaxies,Local Group,Population II stars,stellar halos},
  annotation = {ADS Bibcode: 2023AJ....165...55C},
  file = {/Users/daniel/Zotero/storage/PE9U5ALM/Chiti et al. - 2023 - Detailed Chemical Abundances of Stars in the Outskirts of the Tucana II Ultrafaint Dwarf Galaxy.pdf}
}
