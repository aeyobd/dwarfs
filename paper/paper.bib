@article{dodd+2025,
  title = {Chemical Characterisation of Small Substructures in the Local Stellar Halo},
  author = {Dodd, Emma and Matsuno, Tadafumi and Helmi, Amina and Balbinot, Eduardo and Callingham, Thomas M. and Starkenburg, Else and Woudenberg, Hanneke C. and {Ruiz-Lara}, Tom{\'a}s},
  year = 2025,
  month = aug,
  journal = {Astron. Astrophys.},
  volume = {700},
  pages = {A154},
  publisher = {EDP Sciences},
  issn = {0004-6361, 1432-0746},
  doi = {10.1051/0004-6361/202554252},
  url = {https://www.aanda.org/articles/aa/abs/2025/08/aa54252-25/aa54252-25.html},
  urldate = {2026-01-30},
  abstract = {\emph{Context{$<$}i/{$>$}. The local stellar halo of the Milky Way is known to contain the debris from accreted dwarf galaxies and globular clusters in the form of stellar streams and over-densities in the space of orbital properties (e.g. integrals of motion).\emph{Aims{$<$}i/{$>$}. While several over-densities have been uncovered and characterised dynamically using \emph{Gaia{$<$}i/{$>$} data, their nature is not always clear. Especially for a complete understanding of the smaller halo substructures, the kinematic information from \emph{Gaia{$<$}i/{$>$} needs to be coupled with chemical information.\emph{Methods{$<$}i/{$>$}. In this work, we combine \emph{Gaia{$<$}i/{$>$} data with targeted high-resolution UVES spectroscopy of five small substructures that were recently discovered in the local halo, namely ED-2, -3, -4, -5, and -6 (the ED streams). We present the chemical abundances measured from our newly obtained UVES spectra (20 stars) and from archival UVES spectra (nine stars). We compared these with homogeneously derived abundances from archive spectra of 12 \emph{Gaia{$<$}i/{$>$} Enceladus (GE) stars.\emph{Results{$<$}i/{$>$}. The chemical abundances of all five substructures suggest that they are of accreted origin, except for two stars that present a high [{$\alpha$}/Fe] at high [Fe/H] more in line with an in situ origin. All but ED-2 present a significant spread in [Fe/H] suggestive of a dwarf galaxy origin. ED-3 and ED-4 tend to exhibit a lower [\emph{{$\alpha<$}i/{$>$}/Fe] compared to GE stars. As for ED-5 and ED-6, they are consistent with the GE chemical track and could be high-energy tails of GE that were lost earlier in the accretion process. We present new elemental abundances for five ED-2 stars, including more elements for the \emph{Gaia{$<$}i/{$>$} BH3 companion star. Our findings are in line with the picture that ED-2 is a disrupted ancient star cluster.}}}}}}}}}}},
  copyright = {\copyright{} The Authors 2025},
  langid = {english},
  file = {/Users/daniel/Zotero/storage/WRANG953/Dodd et al. - 2025 - Chemical characterisation of small substructures in the local stellar halo.pdf}
}
