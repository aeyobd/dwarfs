  keywords = {Astrophysics - Solar and Stellar Astrophysics,stars: abundances,stars: evolution,stars: interiors},
  annotation = {ADS Bibcode: 2018MNRAS.480..538R},
  file = {/Users/daniel/Zotero/storage/67V78M5W/Ritter et al. - 2018 - NuGrid stellar data set - II. Stellar yields from .pdf}
