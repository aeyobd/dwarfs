@article{chiti+2023,
  title = {Detailed Chemical Abundances of Stars in the Outskirts of the Tucana {{II}} Ultrafaint Dwarf Galaxy},
  author = {Chiti, Anirudh and Frebel, Anna and Ji, Alexander P. and Mardini, Mohammad K. and Ou, Xiaowei and Simon, Joshua D. and Jerjen, Helmut and Kim, Dongwon and Norris, John E.},
