@article{moreno+pichardo+velazquez2014,
  title = {{{TIDAL RADII AND DESTRUCTION RATES OF GLOBULAR CLUSTERS IN THE MILKY WAY DUE TO BULGE}}--{{BAR AND DISK SHOCKING}}},
  author = {Moreno, Edmundo and Pichardo, B{\'a}rbara and Vel{\'a}zquez, H{\'e}ctor},
  year = 2014,
