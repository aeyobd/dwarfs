@misc{bechtol+2022,
  title = {Snowmass2021 Cosmic Frontier White Paper: Dark Matter Physics from Halo Measurements},
  shorttitle = {Snowmass2021 Cosmic Frontier White Paper},
  author = {Bechtol, Keith and Birrer, Simon and {Cyr-Racine}, Francis-Yan and Schutz, Katelin and Adhikari, Susmita and Amin, Mustafa and Banerjee, Arka and Bird, Simeon and Blinov, Nikita and Boddy, Kimberly K. and Boehm, Celine and Bundy, Kevin and Buschmann, Malte and Chakrabarti, Sukanya and Curtin, David and Dai, Liang and {Drlica-Wagner}, Alex and Dvorkin, Cora and Erickcek, Adrienne L. and Gilman, Daniel and Heeba, Saniya and Kim, Stacy and Ir{\v s}i{\v c}, Vid and Leauthaud, Alexie and Lovell, Mark and Luki{\'c}, Zarija and Mao, Yao-Yuan and Mau, Sidney and Mitridate, Andrea and Mocz, Philip and Mu{\~n}oz, Julian B. and Nadler, Ethan O. and Peter, Annika H. G. and {Price-Whelan}, Adrian and Robertson, Andrew and Sabti, Nashwan and Sehgal, Neelima and Shipp, Nora and Simon, Joshua D. and Singh, Rajeev and Van Tilburg, Ken and Wechsler, Risa H. and Widmark, Axel and Yu, Hai-Bo},
  year = 2022,
  month = mar,
  journal = {arXiv e-prints},
  doi = {10.48550/arXiv.2203.07354},
  url = {https://ui.adsabs.harvard.edu/abs/2022arXiv220307354B},
  urldate = {2025-03-19},
  abstract = {The non-linear process of cosmic structure formation produces gravitationally bound overdensities of dark matter known as halos. The abundances, density profiles, ellipticities, and spins of these halos can be tied to the underlying fundamental particle physics that governs dark matter at microscopic scales. Thus, macroscopic measurements of dark matter halos offer a unique opportunity to determine the underlying properties of dark matter across the vast landscape of dark matter theories. This white paper summarizes the ongoing rapid development of theoretical and experimental methods, as well as new opportunities, to use dark matter halo measurements as a pillar of dark matter physics.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,High Energy Physics - Phenomenology},
  annotation = {ADS Bibcode: 2022arXiv220307354B},
  file = {/Users/daniel/Zotero/storage/YS2BTL85/Bechtol et al. - 2022 - Snowmass2021 Cosmic Frontier White Paper Dark Matter Physics from Halo Measurements.pdf}
}
