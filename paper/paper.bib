@article{caproni+2017,
  title = {Gas Removal in the Ursa Minor Galaxy: Linking Hydrodynamics and Chemical Evolution Models},
  shorttitle = {Gas Removal in the Ursa Minor Galaxy},
  author = {Caproni, Anderson and Amaral Lanfranchi, Gustavo and Campos Baio, Gabriel Henrique and Kowal, Grzegorz and {Falceta-Gon{\c c}alves}, Diego},
