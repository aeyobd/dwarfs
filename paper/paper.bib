@misc{santos-santos+frenk+navarro2026,
  title = {The Missing Ultra-Faint Satellites of the {{Milky Way}}},
  author = {{Santos-Santos}, Isabel M. E. and Frenk, Carlos S. and Navarro, Julio F.},
  year = 2026,
  month = apr,
  number = {arXiv:2604.09539},
  eprint = {2604.09539},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2604.09539},
  url = {http://arxiv.org/abs/2604.09539},
  urldate = {2026-04-14},
  abstract = {We combine the highest resolution N-body simulation of a \$\textbackslash sim 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash, M\_\textbackslash odot\$ \${$\Lambda\$$}CDM halo (Aquarius-A) with the \textbraceleft\textbackslash sc GALFORM\textbraceright{} galaxy formation semianalytic model to study the full satellite population expected in a MW-like galaxy. The model assumes that galaxies only form in subhalos whose peak circular velocity exceeds the H-cooling threshold, all of which are well resolved in the simulation. The number of luminous subhalos ever accreted into the main halo is thus well defined, and implies that the total number of MW satellites, down to arbitrarily low luminosity, should not exceed a few hundred. The model tracks satellites even after their halos cease to be resolved ("orphan" galaxies), and includes a novel treatment of dark matter and stellar tidal stripping which takes into account that all \${$\Lambda\$$}CDM subhalos survive until the present because of their cuspy inner density profiles. After accounting for tides, our results match well the massive end of the observed MW satellite mass function and predict that a large number of ultra-faint dwarfs are missing from the current MW satellite census. The missing UFDs are predicted to avoid the innermost regions of the host, and to have properties that overlap with those of the many ultra-faint compact MW satellites (UFCSs) discovered recently, with properties intermediate between globular clusters and dwarf galaxies. Our results suggest that many UFCS systems are dark matter-dominated dwarfs with velocity dispersions between \$1-3\$km/s, which have survived disruption because they reside in the dense cusp of \${$\Lambda\$$}CDM subhalos. UFCSs should have mean densities of order \$10\textasciicircum\textbraceleft 10\textbraceright\$-\$10\textasciicircum\textbraceleft 11\textbraceright\textbackslash,M\_\textbackslash odot/\$kpc\$\textasciicircum 3\$, higher than those of more extended ultra-faint systems. If confirmed, our results would provide support for the cuspy nature of \${$\Lambda\$$}CDM dark matter halos and for the hydrogen-cooling threshold for galaxy formation.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies},
  file = {/Users/daniel/Zotero/storage/YDIFIJW8/Santos-Santos et al. - 2026 - The missing ultra-faint satellites of the Milky Way.pdf}
}

@article{sarajedini+2007,
  title = {The {{ACS}} Survey of Galactic Globular Clusters. {{I}}. {{Overview}} and Clusters without Previous Hubble Space Telescope Photometry},
  author = {Sarajedini, Ata and Bedin, Luigi R. and Chaboyer, Brian and Dotter, Aaron and Siegel, Michael and Anderson, Jay and Aparicio, Antonio and King, Ivan and Majewski, Steven and {Mar{\'i}n-Franch}, A. and Piotto, Giampaolo and Reid, I. Neill and Rosenberg, Alfred},
  year = 2007,
  month = apr,
  journal = {\aj},
  volume = {133},
  pages = {1658--1672},
  publisher = {IOP},
  issn = {0004-6256},
  doi = {10.1086/511979},
  url = {https://ui.adsabs.harvard.edu/abs/2007AJ....133.1658S},
  urldate = {2026-03-30},
  abstract = {We present the first results of a large Advanced Camera for Surveys (ACS) survey of Galactic globular clusters. This Hubble Space Telescope (HST) Treasury project is designed to obtain photometry with S/N (signal-to-noise ratio) gtrsim10 for main-sequence stars with masses gtrsim0.2 Modot in a sample of globulars using the ACS Wide Field Channel. Here we focus on clusters without previous HST imaging data. These include NGC 5466, NGC 6779, NGC 5053, NGC 6144, Palomar 2, E3, Lyng\aa{} 7, Palomar 1, and NGC 6366. Our color-magnitude diagrams (CMDs) extend reliably from the horizontal branch to as much as 7 mag fainter than the main-sequence turnoff and represent the deepest CMDs published to date for these clusters. Using fiducial sequences for three standard clusters (M92, NGC 6752, and 47 Tuc) with well-known metallicities and distances, we perform main-sequence fitting on the target clusters in order to obtain estimates of their distances and reddenings. These comparisons, along with fitting the cluster main sequences to theoretical isochrones, yield ages for the target clusters. We find that the majority of the clusters have ages that are consistent with the standard clusters at their metallicities. The exceptions are E3, which appears \textasciitilde 2 Gyr younger than 47 Tuc, and Pal 1, which could be as much as 8 Gyr younger than 47 Tuc. Based on observations with the NASA/ESA Hubble Space Telescope, obtained at the Space Telescope Science Institute, which is operated by AURA, Inc., under NASA contract NAS5-26555, under program GO-10775 (PI: A. Sarajedini).},
  langid = {english},
  keywords = {Astrophysics,globular clusters: individual: E3: Lynga 7: NGC 5053: NGC 5466: NGC 6144: NGC 6366: NGC 6779: Palomar 1: Palomar 2,Hertzsprung-Russell diagram},
  annotation = {ADS Bibcode: 2007AJ....133.1658S},
  file = {/Users/daniel/Zotero/storage/3UG7IAJV/Sarajedini et al. - 2007 - The ACS survey of galactic globular clusters. I. Overview and clusters without previous hubble space.pdf}
}
