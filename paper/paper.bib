  eprint = {2509.12313},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2509.12313},
  url = {http://arxiv.org/abs/2509.12313},
  urldate = {2025-11-05},
  abstract = {The properties of Milky Way satellite galaxies have important implications for galaxy formation, reionization, and the fundamental physics of dark matter. However, the population of Milky Way satellites includes the faintest known galaxies, and current observations are incomplete. To understand the impact of observational selection effects on the known satellite population, we perform rigorous, quantitative estimates of the Milky Way satellite galaxy detection efficiency in three wide-field survey datasets: the Dark Energy Survey Year 6, the DECam Local Volume Exploration Data Release 3, and the Pan-STARRS1 Data Release 1. Together, these surveys cover \$\textbackslash sim\$13,600 deg\$\textasciicircum 2\$ to \$g \textbackslash sim 24.0\$ and \$\textbackslash sim\$27,700 deg\$\textasciicircum 2\$ to \$g \textbackslash sim 22.5\$, spanning \$\textbackslash sim\$91\% of the high-Galactic-latitude sky (\$\textbar b\textbar{} \textbackslash geq 15\textasciicircum\textbackslash circ\$). We apply multiple detection algorithms over the combined footprint and recover 49 known satellites above a strict census detection threshold. To characterize the sensitivity of our census, we run our detection algorithms on a large set of simulated galaxies injected into the survey data, which allows us to develop models that predict the detectability of satellites as a function of their properties. We then fit an empirical model to our data and infer the luminosity function, radial distribution, and size-luminosity relation of Milky Way satellite galaxies. Our empirical model predicts a total of \$265\textasciicircum\textbraceleft +79\textbraceright\_\textbraceleft -47\textbraceright\$ satellite galaxies with \$-20 \textbackslash leq M\_V \textbackslash leq 0\$, half-light radii of \$15 \textbackslash leq r\_\textbraceleft 1/2\textbraceright{} (\textbackslash rm pc) \textbackslash leq 3000\$, and galactocentric distances of \$10 \textbackslash leq D\_\textbraceleft\textbackslash rm GC\textbraceright{} (\textbackslash rm kpc) \textbackslash leq 300\$. We also identify a mild anisotropy in the angular distribution of the observed galaxies, at a significance of \$\textbackslash sim\$\$2\textbackslash sigma\$, which can be attributed to the clustering of satellites associated with the LMC.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,to read},
  file = {/Users/daniel/Zotero/storage/TQPYVQZ4/Tan et al. - 2025 - DELVE Milky Way Satellite Census I Satellite Population and Survey Selection Function.pdf}
}
