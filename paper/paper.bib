@article{correamagnus+vasiliev2022,
  title = {Measuring the Milky Way Mass Distribution in the Presence of the {{LMC}}},
  author = {Correa Magnus, Lilia and Vasiliev, Eugene},
  year = 2022,
  month = apr,
  journal = {\mnras},
  volume = {511},
  pages = {2610--2630},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stab3726},
  url = {https://ui.adsabs.harvard.edu/abs/2022MNRAS.511.2610C},
  urldate = {2025-04-30},
  abstract = {The ongoing interaction between the Milky Way (MW) and its largest satellite - the Large Magellanic Cloud (LMC) - creates a significant perturbation in the distribution and kinematics of distant halo stars, globular clusters and satellite galaxies, and leads to biases in MW mass estimates from these tracer populations. We present a method for compensating these perturbations for any choice of MW potential by computing the past trajectory of LMC and MW and then integrating the orbits of tracer objects back in time until the influence of the LMC is negligible, at which point the equilibrium approximation can be used with any standard dynamical modelling approach. We add this orbit-rewinding step to the mass estimation approach based on simultaneous fitting of the potential and the distribution function of tracers, and apply it to two data sets with the latest Gaia EDR3 measurements of 6D phase-space coordinates: globular clusters and satellite galaxies. We find that models with LMC mass in the range \$(1\textbackslash!-\textbackslash!2) \textbackslash times 10\textasciicircum\textbraceleft 11\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbackslash odot\$ better fit the observed distribution of tracers, and measure MW mass within 100 kpc to be \$(0.75\textbackslash pm 0.1)\textbackslash times 10\textasciicircum\textbraceleft 12\textbraceright\textbackslash, \textbackslash mathrm\textbraceleft M\textbraceright\_\textbackslash odot\$, while neglecting the LMC perturbation increases it by \textasciitilde 15 per cent.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,Galaxy: kinematics and dynamics,globular clusters: general,Local Group,Magellanic Clouds,Milky Way},
  annotation = {ADS Bibcode: 2022MNRAS.511.2610C},
  file = {/Users/daniel/Zotero/storage/THWYX22A/Correa Magnus and Vasiliev - 2022 - Measuring the Milky Way mass distribution in the presence of the LMC.pdf}
}
