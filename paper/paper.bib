@article{senchyna+2017,
  title = {Ultraviolet Spectra of Extreme Nearby Star-Forming Regions - Approaching a Local Reference Sample for {{JWST}}},
  author = {Senchyna, Peter and Stark, Daniel P. and {Vidal-Garc{\'i}a}, Alba and Chevallard, Jacopo and Charlot, St{\'e}phane and Mainali, Ramesh and Jones, Tucker and Wofford, Aida and Feltre, Anna and Gutkin, Julia},
  year = 2017,
  month = dec,
  journal = {MNRAS},
  volume = {472},
  pages = {2608--2632},
  publisher = {OUP},
  issn = {0035-8711},
  doi = {10.1093/mnras/stx2059},
  url = {https://ui.adsabs.harvard.edu/abs/2017MNRAS.472.2608S},
  urldate = {2024-05-12},
  abstract = {Nearby dwarf galaxies provide a unique laboratory in which to test stellar population models below Z{$\odot$}/2. Such tests are particularly important for interpreting the surprising high-ionization ultraviolet (UV) line emission detected at z {$>$} 6 in recent years. We present HST/COS UV spectra of 10 nearby metal-poor star-forming galaxies selected to show He II emission in SDSS optical spectra. The targets span nearly a dex in gas-phase oxygen abundance (7.8 {$<$} 12 + log O/H {$<$} 8.5) and present uniformly large specific star formation rates (sSFR {$\sim$}102 Gyr-1). The UV spectra confirm that metal-poor stellar populations can power extreme nebular emission in high-ionization UV lines, reaching C III] equivalent widths comparable to those seen in systems at z {$\sim$} 6-7. Our data reveal a marked transition in UV spectral properties with decreasing metallicity, with systems below 12 + log O/H {$\lessequivlnt$} 8.0 (Z/Z{$\odot$} {$\lessequivlnt$} 1/5) presenting minimal stellar wind features and prominent nebular emission in He II and C IV. This is consistent with nearly an order of magnitude increase in ionizing photon production beyond the He+-ionizing edge relative to H-ionizing flux as metallicity decreases below a fifth solar, well in excess of standard stellar population synthesis predictions. Our results suggest that often-neglected sources of energetic radiation such as stripped binary products and very massive O-stars produce a sharper change in the ionizing spectrum with decreasing metallicity than expected. Consequently, nebular emission in C IV and He II powered by these stars may provide useful metallicity constraints in the reionization era.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: evolution,galaxies: stellar content,stars: massive,ultraviolet: galaxies},
  annotation = {ADS Bibcode: 2017MNRAS.472.2608S},
  file = {/Users/daniel/Zotero/storage/C7RGET4V/Senchyna et al. - 2017 - Ultraviolet spectra of extreme nearby star-forming.pdf}
}
