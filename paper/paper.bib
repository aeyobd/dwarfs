@article{garcia-rojas+2006,
  title = {Faint Emission Lines in the Galactic {{HII}} Regions {{M16}}, {{M20}} and {{NGC}} 3603*},
  author = {{Garc{\'i}a-Rojas}, J. and Esteban, C. and Peimbert, M. and Costado, M. T. and Rodr{\'i}guez, M. and Peimbert, A. and Ruiz, M. T.},
  year = 2006,
