@article{fellhauer+2008,
  title = {Modelling the Dynamical Evolution of the Bootes Dwarf Spheroidal Galaxy},
  author = {Fellhauer, M. and Wilkinson, M. I. and Evans, N. W. and Belokurov, V. and Irwin, M. J. and Gilmore, G. and Zucker, D. B. and Kleyna, J. T.},
  year = 2008,
  month = apr,
  journal = {\mnras},
  volume = {385},
