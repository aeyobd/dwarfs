@article{cicuendez+battaglia2018,
  title = {Appearances Can Be Deceiving: Clear Signs of Accretion in the Seemingly Ordinary Sextans {{dSph}}},
  shorttitle = {Appearances Can Be Deceiving},
  author = {Cicu{\'e}ndez, L. and Battaglia, G.},
  year = 2018,
  month = oct,
  journal = {\mnras},
  volume = {480},
  pages = {251--260},
