  urldate = {2025-09-21},
  abstract = {The orbits of satellite galaxies encode rich information about their histories. We investigate the orbital dynamics and histories of satellite galaxies around Milky Way (MW)-mass host galaxies using the FIRE-2 cosmological simulations, which, as previous works have shown, produce satellite mass functions and spatial distributions that broadly agree with observations. We first examine trends in orbital dynamics at z = 0, including total velocity, specific angular momentum, and specific total energy: the time of infall into the MW-mass halo primarily determines these orbital properties. We then examine orbital histories, focusing on the lookback time of first infall into a host halo and pericentre distances, times, and counts. Roughly 37 per cent of galaxies with \$M\_\textbraceleft\textbackslash rm star\textbraceright\textbackslash lesssim 10\textasciicircum 7\textbackslash, \textbraceleft\textbackslash rm M\textbraceright\_\textbraceleft\textbackslash odot \textbraceright\$ were 'pre-processed' as a satellite in a lower-mass group, typically \$\textbackslash approx 2.7\textbackslash, \textbraceleft\textbackslash rm Gyr\textbraceright\$ before falling into the MW-mass halo. Half of all satellites at z = 0 experienced multiple pericentres about their MW-mass host. Remarkably, for most (67 per cent) of these satellites, their most recent pericentre was not their minimum pericentre: the minimum typically was \textasciitilde 40 per cent smaller and occurred \$\textbackslash sim 6\textbackslash, \textbraceleft\textbackslash rm Gyr\textbraceright\$ earlier. These satellites with growing pericentres appear to have multiple origins: for about half, their specific angular momentum gradually increased over time, while for the other half, most rapidly increased near their first apocentre, suggesting that a combination of a time-dependent MW-mass halo potential and dynamical perturbations in the outer halo caused these satellites' pericentres to grow. Our results highlight the limitations of idealized, static orbit modelling, especially for pericentre histories.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,dynamics theory,galaxies: kinematics and dynamics,Local Group,methods: numerical},
  annotation = {ADS Bibcode: 2023MNRAS.518.1427S},
  file = {/Users/daniel/Zotero/storage/ZU9GSWEL/Santistevan et al. - 2023 - Orbital dynamics and histories of satellite galaxies around milky way - mass galaxies in the FIRE si.pdf}
}
