@misc{porras-bedmar+sanchez-conde+aguirre-santaella2026,
  title = {Impact of Baryons on the Population of {{Galactic}} Subhalos and Implications for Dark Matter Searches},
  author = {{Porras-Bedmar}, Sara and {S{\'a}nchez-Conde}, Miguel {\'A} and {Aguirre-Santaella}, Alejandra},
  year = 2026,
  month = jan,
  number = {arXiv:2601.11452},
  eprint = {2601.11452},
  primaryclass = {astro-ph},
  doi = {10.48550/arXiv.2601.11452},
  url = {http://arxiv.org/abs/2601.11452},
  urldate = {2026-01-20},
  abstract = {We have used Auriga -- a set of state-of-the-art cosmological hydrodynamical simulations of Milky Way-size systems -- to study the impact of baryons on the Galactic subhalo population. A DM-only run counterpart of Auriga allows us to compare results with and without baryons. We repopulate the original suites with low-mass subhalos orders of magnitude lighter than the mass resolution limit, starting from a detailed characterization of Auriga data in the well-resolved subhalo mass range. The survival of low-mass subhalos to tidal forces is unclear and under debate nowadays, thus in our study we stay agnostic and consider two different levels of subhalo resilience to tidal stripping ('fragile' and 'resilient' subhalos). We find baryons to alter the Galactic substructure significantly, by decreasing its overall abundance by a factor \$\textbackslash sim2.4\$ (fragile) and \$\textbackslash sim1.9\$ (resilient) and subhalo concentration -- here defined in terms of maximum circular velocity -- by \$\textbackslash sim1.5\$ with respect to the DM-only scenario. This has important consequences for indirect searches of DM. As an example, we investigated the case of using unidentified gamma-ray sources to set constraints on the DM particle properties, assuming some of them may be dark satellites. We find the DM annihilation cross-section constraints to worsen by a factor \$\textbackslash sim3.6\$ in the most realistic scenario of including baryons, compared to DM-only simulations in the 'fragile' setup. Yet, a stronger resilience of subhalos to tidal stripping improves these DM limits by a factor \$\textbackslash sim4.5\$ and \$\textbackslash sim10\$ compared to the DM-only and hydrodynamical 'fragile' cases, respectively. Our results show the importance of including baryons to properly characterize the Galactic subhalo population, as well as to propose the most optimal subhalo search strategies, not only via its potential DM annihilation products but also through their gravitational signatures.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Cosmology and Nongalactic Astrophysics,Astrophysics - High Energy Astrophysical Phenomena},
  file = {/Users/daniel/Zotero/storage/WVWYY5YM/Porras-Bedmar et al. - 2026 - Impact of baryons on the population of Galactic subhalos and implications for dark matter searches.pdf}
}

