  title = {Dark Matter Cores in the Fornax and Sculptor Dwarf Galaxies: Joining Halo Assembly and Detailed Star Formation Histories},
  shorttitle = {Dark Matter Cores in the Fornax and Sculptor Dwarf Galaxies},
