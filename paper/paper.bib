@misc{hammer+2025,
  title = {Young Stars Discovered in Dwarf Spheroidal Galaxies Confirm Their Recent Infall into the Milky Way},
  author = {Hammer, Francois and Bonifacio, Piercarlo and Caffau, Elisabetta and Yang, Yanbin and Arenou, Frederic and Babusiaux, Carine and Spite, Monique and Francois, Patrick and Gomez, Ana and Katz, David and Monaco, Lorenzo and Pawlowski, Marcel and Wang, Jianling},
  year = 2025,
  month = may,
  publisher = {arXiv},
  doi = {10.48550/arXiv.2505.11587},
  url = {https://ui.adsabs.harvard.edu/abs/2025arXiv250511587H},
  urldate = {2025-05-30},
  abstract = {Recent observations from the ESA Gaia satellite and with the ESO VLT, have identified the presence of a population of young, 0.5 to 2 Gyr old, stars in the halo and in dwarf spheroidal galaxies surrounding the Milky Way. It suggests that MW dwarf galaxies, currently devoid of gas, had, until recent times, enough gas to sustain a burst of star formation. The recent loss of gas coincides with their arrival in the vicinity of the Milky Way, in agreement with orbital predictions from Gaia that indicate that most dwarf galaxies reached the Milky Way halo less than 3 Gyr years ago. This completely changes the interpretation of their dynamics, mass, and dark matter content.},
