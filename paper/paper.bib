  url = {https://ui.adsabs.harvard.edu/abs/2023MNRAS.526.5084J},
  urldate = {2024-05-07},
  abstract = {We model the stellar abundances and ages of two disrupted dwarf galaxies in the Milky Way stellar halo: Gaia-Sausage Enceladus (GSE) and Wukong/LMS-1. Using a statistically robust likelihood function, we fit one-zone models of galactic chemical evolution with exponential infall histories to both systems, deriving e-folding time-scales of {$\tau$}in = 1.01 \textpm{} 0.13 Gyr for GSE and \$\textbackslash tau \_\textbackslash text\textbraceleft in\textbraceright{} = 3.08\textasciicircum\textbraceleft +3.19\textbraceright\_\textbraceleft -1.16\textbraceright\$ Gyr for Wukong/LMS-1. GSE formed stars for \$\textbackslash tau \_\textbackslash text\textbraceleft tot\textbraceright{} = 5.40\textasciicircum\textbraceleft +0.32\textbraceright\_\textbraceleft -0.31\textbraceright\$ Gyr, sustaining star formation for \textasciitilde 1.5-2 Gyr after its first infall into the Milky Way \textasciitilde 10 Gyr ago. Our fit suggests that star formation lasted for \$\textbackslash tau \_\textbackslash text\textbraceleft tot\textbraceright{} = 3.36\textasciicircum\textbraceleft +0.55\textbraceright\_\textbraceleft -0.47\textbraceright\$ Gyr in Wukong/LMS-1, though our sample does not contain any age measurements. The differences in evolutionary parameters between the two are qualitatively consistent with trends with stellar mass M{$\star$} predicted by simulations and semi-analytic models of galaxy formation. Our inferred values of the outflow mass-loading factor reasonably match \$\textbackslash eta \textbackslash propto M\_\textbackslash star \textasciicircum\textbraceleft -1/3\textbraceright\$ as predicted by galactic wind models. Our fitting method is based only on Poisson sampling from an evolutionary track and requires no binning of the data. We demonstrate its accuracy by testing against mock data, showing that it accurately recovers the input model across a broad range of sample sizes (20 {$\leq$} N {$\leq$} 2000) and measurement uncertainties (0.01 {$\leq$} {$\sigma$}[{$\alpha$}/Fe], {$\sigma$}[Fe/H] {$\leq$} 0.5; \$0.02 \textbackslash le \textbackslash sigma \_\textbraceleft\textbackslash log \_\textbraceleft 10\textbraceright (\textbackslash text\textbraceleft age\textbraceright )\textbraceright{} \textbackslash le 1\$). Due to the generic nature of our derivation, this likelihood function should be applicable to one-zone models of any parametrization and easily extensible to other astrophysical models which predict tracks in some observed space.},
  langid = {english},
  keywords = {Astrophysics - Astrophysics of Galaxies,galaxies: abundances,galaxies: evolution,galaxies: star formation,galaxies: stellar content,methods: numerical},
  annotation = {ADS Bibcode: 2023MNRAS.526.5084J},
  file = {/Users/daniel/Zotero/storage/CGW8QR6P/Johnson et al. - 2023 - Dwarf galaxy archaeology from chemical abundances .pdf}
}
