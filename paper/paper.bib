@article{correnti+bellazzini+ferraro2009,
  title = {Red Clump Stars in the Bo\"otes {{III}} Stellar System},
  author = {Correnti, M. and Bellazzini, M. and Ferraro, F. R.},
  year = 2009,
  month = jul,
  journal = {\mnras},
  volume = {397},
