@article{vasiliev+baumgardt2021,
  title = {Gaia {{EDR3}} View on Galactic Globular Clusters},
  author = {Vasiliev, Eugene and Baumgardt, Holger},
  year = 2021,
  month = aug,
  journal = {\mnras},
  volume = {505},
  pages = {5978--6002},
  issn = {0035-8711},
  doi = {10.1093/mnras/stab1475},
  url = {https://ui.adsabs.harvard.edu/abs/2021MNRAS.505.5978V},
  urldate = {2024-04-09},
  abstract = {We use the data from Gaia Early Data Release 3 (EDR3) to study the kinematic properties of Milky Way globular clusters. We measure the mean parallaxes and proper motions (PM) for 170 clusters, determine the PM dispersion profiles for more than 100 clusters, uncover rotation signatures in more than 20 objects, and find evidence for radial or tangential PM anisotropy in a dozen richest clusters. At the same time, we use the selection of cluster members to explore the reliability and limitations of the Gaia catalogue itself. We find that the formal uncertainties on parallax and PM are underestimated by \$10\textbraceleft -\textbraceright 20\textbraceleft\textbraceleft\textbackslash{} \textbackslash rm per\textbackslash{} cent\textbraceright\textbraceright\$ in dense central regions even for stars that pass numerous quality filters. We explore the spatial covariance function of systematic errors, and determine a lower limit on the uncertainty of average parallaxes and PM at the level 0.01 mas and 0.025 mas yr\$\textasciicircum\textbraceleft -1\textbraceright\$ , respectively. Finally, a comparison of mean parallaxes of clusters with distances from various literature sources suggests that the parallaxes for stars with \$G{$>$}13\$ (after applying the zero-point correction suggested by Lindegren et al.) are overestimated by \$\textbackslash sim 0.01\textbackslash pm 0.003\$ mas. Despite these caveats, the quality of Gaia astrometry has been significantly improved in EDR3 and provides valuable insights into the properties of star clusters.},
  keywords = {Astrophysics - Astrophysics of Galaxies,Galaxy: kinematics and dynamics,globular clusters: general,parallaxes,proper motions,to read},
  annotation = {ADS Bibcode: 2021MNRAS.505.5978V},
  file = {/Users/daniel/Zotero/storage/3UM9WQ4B/Vasiliev and Baumgardt - 2021 - Gaia EDR3 view on galactic globular clusters.pdf;/Users/daniel/Zotero/storage/SWX4ZMAS/Vasiliev and Baumgardt - 2021 - Gaia EDR3 view on galactic globular clusters.pdf}
}
