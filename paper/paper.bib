  author = {Geha, Marla and Pelliccia, Debora and Prochaska, J. Xavier and Cerny, William and Davies, Frederick B. and Hennawi, Joseph and Holden, Brad and Reichwein, Dusty and Westfall, Kyle B.},
  year = 2026,
